{% extends "layouts/mobile_base.twig" %}
{% import "components/_icons.twig" as icons %}
{% set active_nav = 'tasks' %}

{% block title %}Tâches — Panel consultant{% endblock %}

{% set total = tasks | length %}
{% set done_count = 0 %}
{% set mandatory_count = 0 %}
{% for t in tasks %}
    {% if t.is_done %}{% set done_count = done_count + 1 %}{% endif %}
    {% if t.is_mandatory %}{% set mandatory_count = mandatory_count + 1 %}{% endif %}
{% endfor %}

{% block topbar %}
<div class="app-topbar">
    <div class="container">
        <div class="scr-head">
            <div>
                <div class="scr-title">Tâches</div>
                <div class="scr-sub">Assignées à votre poste</div>
            </div>
            <button class="app-hamburger" id="appHamburger" aria-label="Menu" aria-expanded="false" aria-controls="appNavSheet">
                {{ icons.svg('menu', 22) }}
            </button>
        </div>
    </div>
</div>
{% endblock %}

{% block content %}
<div class="page-content-loaded tk">

    {# ── Résumé poste ── #}
    <div class="tk-summary">
        <div class="tk-summary-eyebrow">{{ position.position_name ?? 'Poste consultant' }}</div>
        <div class="tk-summary-big">{{ done_count }} sur {{ total }} tâches faites</div>
        <div class="tk-summary-chips">
            <span class="tk-chip">{{ icons.svg('list', 13) }}{{ total }} tâches</span>
            {% if mandatory_count > 0 %}<span class="tk-chip">{{ mandatory_count }} obligatoires</span>{% endif %}
            {% if position.level_name %}<span class="tk-chip">{{ position.level_name }}</span>{% endif %}
        </div>
    </div>

    {% if total == 0 %}
        <div class="cl-empty">{{ icons.svg('list-checks', 34) }}<div>Aucune tâche assignée pour le moment.</div></div>
    {% else %}
        {% for task in tasks %}
            {% set is_done = task.is_done %}
            <div class="tk-card" style="border-left-color:{{ is_done ? '#2D7A3E' : '#8D1D2C' }}">
                <div class="tk-card-top">
                    <div class="tk-card-id">
                        <div class="tk-card-name">{{ task.name }}</div>
                        <div class="tk-card-path">{{ task.section_name ?? task.category_name ?? '' }}{% if task.subcategory_name %} · {{ task.subcategory_name }}{% endif %}</div>
                    </div>
                    {% if is_done %}
                        <span class="tk-badge tk-badge-done">{{ icons.svg('check', 13) }}Fait</span>
                    {% else %}
                        <span class="tk-badge tk-badge-prio">P{{ task.priority ?? 5 }}</span>
                    {% endif %}
                </div>
                {% if task.description %}<p class="tk-card-desc">{{ task.description }}</p>{% endif %}
                <div class="tk-meta">
                    {% if task.execution_time %}<span class="tk-metachip">{{ icons.svg('clock', 12) }}{{ task.execution_time }}</span>{% endif %}
                    {% if task.is_mandatory %}<span class="tk-metachip">Obligatoire</span>{% endif %}
                    {% if task.requires_photo %}<span class="tk-metachip">{{ icons.svg('camera', 12) }}Photo requise</span>{% endif %}
                </div>
                {% if is_done and task.completion_id %}
                    <a href="{{ ROOT }}/tasks/completion/{{ task.completion_id }}" class="tk-btn tk-btn-ghost">{{ icons.svg('eye', 15) }}Voir la réalisation</a>
                {% elseif not is_done %}
                    <a href="{{ ROOT }}/tasks/{{ task.id }}" class="tk-btn tk-btn-primary">{{ icons.svg('check', 15) }}Réaliser</a>
                {% endif %}
            </div>
        {% endfor %}
    {% endif %}

</div>
{% endblock %}
