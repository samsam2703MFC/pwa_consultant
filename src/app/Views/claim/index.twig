{% extends "layouts/mobile_base.twig" %}

{% import "components/_icons.twig" as icons %}
{% block title %}Reklamacje — Consultant Panel{% endblock %}
{% block page_title %}Reklamacje{% endblock %}
{% block page_subtitle %}Claims od wszystkich dostawców{% endblock %}

{% block head %}
<style>
    .claim-filter {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 2px 10px rgba(0,0,0,.06);
        padding: 14px;
        margin-bottom: 14px;
    }
    .claim-select {
        width: 100%;
        padding: 9px 12px;
        border: 1.5px solid #e9ecef;
        border-radius: 10px;
        background: #f8f9ff;
        color: #212529;
        font-size: .9rem;
        outline: none;
    }
    .claim-select:focus {
        border-color: #435ebe;
        background: #fff;
    }
    .claim-card {
        border-radius: 14px;
        border: 0;
        box-shadow: 0 1px 7px rgba(0,0,0,.07);
    }
    .claim-status {
        font-size: .68rem;
        font-weight: 800;
        border-radius: 999px;
        padding: 4px 9px;
        white-space: nowrap;
    }
    .claim-status-new { background: rgba(13,110,253,.12); color: #0d6efd; }
    .claim-status-review { background: rgba(255,193,7,.2); color: #9a7100; }
    .claim-status-accepted { background: rgba(40,167,69,.13); color: #198754; }
    .claim-status-rejected { background: rgba(220,53,69,.12); color: #dc3545; }
    .claim-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 6px 12px;
        color: #6c757d;
        font-size: .76rem;
    }
    .claim-meta-item {
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }
    .claim-description {
        background: #f8f9ff;
        border-left: 3px solid #435ebe;
        border-radius: 8px;
        color: #495057;
        font-size: .82rem;
        line-height: 1.45;
        padding: 8px 10px;
    }
    .claim-section-label {
        color: #6c757d;
        font-size: .68rem;
        font-weight: 800;
        letter-spacing: .04em;
        margin-bottom: 4px;
        text-transform: uppercase;
    }
    .claim-attachment-link {
        align-items: center;
        background: rgba(67,94,190,.08);
        border: 1px solid rgba(67,94,190,.18);
        border-radius: 8px;
        color: #435ebe;
        display: inline-flex;
        font-size: .76rem;
        font-weight: 700;
        gap: 5px;
        max-width: 100%;
        padding: 5px 9px;
        text-decoration: none;
    }
    .claim-attachment-link span {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    /* Zdjęcia w załączniku — siatka 2 na wiersz, wyrównane do lewej */
    .claim-photos {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-start;
        gap: 8px;
        margin-top: 4px;
    }
    .claim-photo,
    .claim-photo-ph {
        flex: 0 0 calc(50% - 4px);
        max-width: calc(50% - 4px);
        min-width: 0;
        aspect-ratio: 4 / 3;
        border-radius: 10px;
        overflow: hidden;
    }
    .claim-photo {
        padding: 0;
        border: 0;
        background: #f1f3f5;
        cursor: pointer;
        -webkit-tap-highlight-color: transparent;
    }
    .claim-photo img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }
    /* Placeholder décoratif (emplacement vide quand nombre de photos impair) */
    .claim-photo-ph {
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f6f5f2;
        color: #7a7168;
    }
    .claim-photo-ph svg {
        width: 34px;
        height: 34px;
        opacity: .18;
    }

    /* Lightbox / podgląd pełnoekranowy */
    .claim-lightbox {
        position: fixed;
        inset: 0;
        z-index: 1080;
        display: none;
        align-items: center;
        justify-content: center;
        background: rgba(0,0,0,.9);
        padding: 20px;
    }
    .claim-lightbox.open { display: flex; }
    .claim-lightbox img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        border-radius: 8px;
    }
    .claim-lightbox-close {
        position: absolute;
        top: 14px;
        right: 14px;
        width: 40px;
        height: 40px;
        border: 0;
        border-radius: 50%;
        background: rgba(255,255,255,.15);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }

    /* ── Badges de statut (filtre) ── */
    .claim-status-bar {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 14px;
    }
    .claim-status-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border: 1px solid transparent;
        border-radius: 999px;
        padding: 6px 10px;
        font-size: .78rem;
        font-weight: 700;
        cursor: pointer;
        background: #fff;
        -webkit-tap-highlight-color: transparent;
        transition: background .15s, color .15s, border-color .15s;
    }
    .claim-status-badge-count {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 18px;
        height: 18px;
        padding: 0 5px;
        border-radius: 999px;
        font-size: .68rem;
        font-weight: 800;
        background: rgba(0,0,0,.10);
        color: inherit;
    }
    /* Couleurs par statut (reprises du module) — état inactif : teinte claire */
    .claim-status-badge.s-new      { color:#0d6efd; border-color:rgba(13,110,253,.28);  background:rgba(13,110,253,.08); }
    .claim-status-badge.s-review   { color:#9a7100; border-color:rgba(255,193,7,.45);   background:rgba(255,193,7,.16); }
    .claim-status-badge.s-accepted { color:#198754; border-color:rgba(25,135,84,.28);   background:rgba(25,135,84,.10); }
    .claim-status-badge.s-rejected { color:#dc3545; border-color:rgba(220,53,69,.26);   background:rgba(220,53,69,.09); }
    .claim-status-badge.s-new      .claim-status-badge-count { background:rgba(13,110,253,.18); }
    .claim-status-badge.s-review   .claim-status-badge-count { background:rgba(154,113,0,.20); }
    .claim-status-badge.s-accepted .claim-status-badge-count { background:rgba(25,135,84,.18); }
    .claim-status-badge.s-rejected .claim-status-badge-count { background:rgba(220,53,69,.18); }
    /* État actif : fond plein, texte blanc */
    .claim-status-badge.is-active { color:#fff; border-color:transparent; }
    .claim-status-badge.s-new.is-active      { background:#0d6efd; }
    .claim-status-badge.s-review.is-active   { background:#9a7100; }
    .claim-status-badge.s-accepted.is-active { background:#198754; }
    .claim-status-badge.s-rejected.is-active { background:#dc3545; }
    .claim-status-badge.is-active .claim-status-badge-count { background:rgba(255,255,255,.28); color:#fff; }
    /* Statut à 0 : grisé */
    .claim-status-badge.is-zero {
        color:#adb5bd;
        background:#f1f3f5;
        border-color:#e9ecef;
    }
    .claim-status-badge.is-zero .claim-status-badge-count { background:rgba(0,0,0,.06); color:#adb5bd; }
</style>
{% endblock %}

{% block content %}
<div class="page-content-loaded px-3 pb-4">

    {% if shops is empty %}
        <div class="text-center text-muted py-5">
            <span style="font-size:2.5rem;opacity:.3;">{{ icons.svg('circle-alert') }}</span>
            <p class="mt-3">Brak dostępnych sklepów.</p>
        </div>
    {% else %}
        <form method="GET" action="{{ ROOT }}/claims" class="claim-filter">
            <div class="d-flex flex-column gap-2">
                <div>
                    <label class="form-label small fw-700 text-muted mb-1">Sklep</label>
                    <select name="shop_id" class="claim-select" onchange="this.form.submit()">
                        <option value="all" {{ selected_shop_id == 'all' ? 'selected' : '' }}>Wszystkie sklepy</option>
                        {% for shop in shops %}
                            <option value="{{ shop.id }}" {{ selected_shop_id == shop.id ? 'selected' : '' }}>
                                {{ shop.representative_name ?? shop.name ?? 'Sklep' }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
            </div>
        </form>

        {# ── Badges de statut (filtre) — comptes réels, un badge par statut ── #}
        {% set status_css = {
            'NEW': 'new', 'IN_REVIEW': 'review', 'ACCEPTED': 'accepted', 'REJECTED': 'rejected'
        } %}
        {% set status_labels = {
            'NEW': 'Nouvelle', 'IN_REVIEW': 'En cours', 'ACCEPTED': 'Résolue', 'REJECTED': 'Rejetée'
        } %}
        <div class="claim-status-bar" data-active="{{ active_status }}">
            {% for st in status_order %}
                {% set cnt = status_counts[st] ?? 0 %}
                <button type="button"
                        class="claim-status-badge s-{{ status_css[st] ?? 'new' }}{{ cnt == 0 ? ' is-zero' : '' }}"
                        data-status="{{ st }}"
                        aria-pressed="false">
                    <span class="claim-status-badge-lbl">{{ status_labels[st] ?? st }}</span>
                    <span class="claim-status-badge-count">{{ cnt }}</span>
                </button>
            {% endfor %}
        </div>

        {# Message quand un filtre statut ne renvoie aucune réclamation (client-side) #}
        <div class="text-center text-muted py-5" id="claim-empty-filter" style="display:none;">
            <span style="font-size:2.5rem;opacity:.3;">{{ icons.svg('inbox') }}</span>
            <p class="mt-3">Brak reklamacji dla wybranego statusu.</p>
        </div>

        {% if claims is empty %}
            <div class="text-center text-muted py-5">
                <span style="font-size:2.5rem;opacity:.3;">{{ icons.svg('inbox') }}</span>
                <p class="mt-3">Brak reklamacji dla wybranych filtrów.</p>
            </div>
        {% else %}
            <div class="d-flex flex-column gap-2">
                {% for claim in claims %}
                    {% set status = claim.status ?? 'NEW' %}
                    {% set status_class = {
                        'NEW': 'claim-status-new',
                        'IN_REVIEW': 'claim-status-review',
                        'ACCEPTED': 'claim-status-accepted',
                        'REJECTED': 'claim-status-rejected'
                    }[status] ?? 'claim-status-new' %}

                    <div class="card claim-card" data-claim-card data-status="{{ status }}">
                        <div class="card-body p-3">
                            <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                                <div class="min-w-0">
                                    <div class="fw-700 text-dark text-truncate" style="font-size:.92rem;">
                                        {{ claim.complaint_key ?? ('Reklamacja #' ~ claim.id) }}
                                    </div>
                                    <div class="text-muted text-truncate" style="font-size:.76rem;">
                                        {{ claim.supplier_name ?? 'Dostawca nieznany' }}
                                    </div>
                                    {% if selected_shop_id == 'all' %}
                                        <div class="text-muted text-truncate" style="font-size:.76rem;">
                                            <span class="me-1">{{ icons.svg('store') }}</span>{{ claim.shop_name ?? 'Sklep' }}
                                        </div>
                                    {% endif %}
                                </div>
                                <span class="claim-status {{ status_class }}">{{ status }}</span>
                            </div>

                            <div class="claim-meta mb-2">
                                <span class="claim-meta-item">
                                    {{ icons.svg('package') }}
                                    {{ claim.material_name ?? claim.supplier_sku ?? 'Materiał nieznany' }}
                                </span>
                                {% if claim.qty is defined and claim.qty is not empty %}
                                    <span class="claim-meta-item">
                                        {{ icons.svg('hash') }}
                                        {{ claim.qty }} {{ claim.unit_name ?? '' }}
                                    </span>
                                {% endif %}
                                {% if claim.order_key is defined and claim.order_key %}
                                    <span class="claim-meta-item">
                                        {{ icons.svg('receipt') }}
                                        {{ claim.order_key }}
                                    </span>
                                {% endif %}
                                {% if claim.reported_at is defined and claim.reported_at %}
                                    <span class="claim-meta-item">
                                        {{ icons.svg('calendar') }}
                                        {{ claim.reported_at|slice(0,10) }}
                                    </span>
                                {% endif %}
                            </div>

                            <div class="d-flex flex-wrap gap-1 mb-2">
                                <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill">
                                    {{ claim.reason_name ?? claim.reason_code ?? 'Powód nieznany' }}
                                </span>
                                {% if claim.attachments is defined and claim.attachments|length > 0 %}
                                    {# Style autonome : le thème force .bg-primary en plein → illisible #}
                                    <span class="badge rounded-pill" style="background:rgba(141,29,44,.10);color:#8D1D2C;">
                                        {{ claim.attachments|length }} annexe{{ claim.attachments|length > 1 ? 's' : '' }}
                                    </span>
                                {% endif %}
                            </div>

                            {% if claim.description is defined and claim.description %}
                                <div class="claim-section-label">Opis sklepu</div>
                                <div class="claim-description mb-2">{{ claim.description }}</div>
                            {% endif %}

                            {# Podział załączników: zdjęcia (miniatury na dole) vs pozostałe pliki (linki) #}
                            {% set claim_photos = (claim.attachments ?? [])|filter(a =>
                                ((a.mime_type ?? a.content_type ?? a.mime ?? '')|lower starts with 'image/')
                                or ((a.original_name ?? '')|lower matches '/\\.(jpe?g|png|gif|webp|heic|heif|bmp|avif)$/')
                            ) %}
                            {% set claim_files = (claim.attachments ?? [])|filter(a =>
                                not ((a.mime_type ?? a.content_type ?? a.mime ?? '')|lower starts with 'image/')
                                and not ((a.original_name ?? '')|lower matches '/\\.(jpe?g|png|gif|webp|heic|heif|bmp|avif)$/')
                            ) %}

                            {% if claim_files|length > 0 %}
                                <div class="claim-section-label">Załączniki sklepu</div>
                                <div class="d-flex flex-wrap gap-2 mb-2">
                                    {% for attachment in claim_files %}
                                        {% set attachment_name = attachment.original_name ?? ('Załącznik #' ~ attachment.id) %}
                                        <a href="{{ ROOT }}/claims/attachments/{{ attachment.id }}/preview"
                                           class="claim-attachment-link"
                                           target="_blank"
                                           rel="noopener">
                                            {{ icons.svg('paperclip') }}
                                            <span>{{ attachment_name }}</span>
                                        </a>
                                    {% endfor %}
                                </div>
                            {% endif %}

                            {% if claim.production_response is defined and claim.production_response %}
                                <div class="claim-section-label">Odpowiedź produkcji</div>
                                <div class="claim-description" style="border-left-color:#198754;">
                                    {{ claim.production_response }}
                                </div>
                            {% endif %}

                            {# ── Zdjęcia w załączniku (dolna część kafelka) ── #}
                            {% if claim_photos|length > 0 %}
                                <div class="claim-section-label mt-2">Zdjęcia</div>
                                <div class="claim-photos">
                                    {% for photo in claim_photos %}
                                        {% set photo_url = ROOT ~ '/claims/attachments/' ~ photo.id ~ '/preview' %}
                                        <button type="button"
                                                class="claim-photo"
                                                data-full="{{ photo_url }}"
                                                aria-label="{{ photo.original_name ?? 'Zdjęcie' }}">
                                            <img src="{{ photo_url }}"
                                                 alt="{{ photo.original_name ?? '' }}"
                                                 loading="lazy">
                                        </button>
                                    {% endfor %}
                                    {# Nombre impair → placeholder décoratif à droite pour garder la ligne alignée #}
                                    {% if claim_photos|length is odd %}
                                        <div class="claim-photo-ph" aria-hidden="true">{{ icons.svg('camera', 34) }}</div>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    {% endif %}

</div>

{# Lightbox współdzielony przez wszystkie kafelki #}
<div id="claim-lightbox" class="claim-lightbox" role="dialog" aria-modal="true" aria-hidden="true">
    <button type="button" class="claim-lightbox-close" aria-label="Zamknij">{{ icons.svg('x') }}</button>
    <img id="claim-lightbox-img" src="" alt="">
</div>
{% endblock %}

{% block scripts %}
<script>
(function () {
    var lb = document.getElementById('claim-lightbox');
    if (!lb) return;
    var lbImg = document.getElementById('claim-lightbox-img');

    function openLightbox(src, alt) {
        lbImg.setAttribute('src', src);
        lbImg.setAttribute('alt', alt || '');
        lb.classList.add('open');
        lb.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
    }
    function closeLightbox() {
        lb.classList.remove('open');
        lb.setAttribute('aria-hidden', 'true');
        lbImg.setAttribute('src', '');
        document.body.style.overflow = '';
    }

    document.addEventListener('click', function (e) {
        var thumb = e.target.closest('.claim-photo');
        if (thumb) {
            e.preventDefault();
            var img = thumb.querySelector('img');
            openLightbox(thumb.getAttribute('data-full'), img ? img.getAttribute('alt') : '');
            return;
        }
        // Klik w tło lub przycisk zamknięcia
        if (e.target === lb || e.target.closest('.claim-lightbox-close')) {
            closeLightbox();
        }
    });

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && lb.classList.contains('open')) closeLightbox();
    });
})();

// ── Filtre par badges de statut (client-side, un seul actif à la fois) ──
(function () {
    var bar = document.querySelector('.claim-status-bar');
    if (!bar) return;
    var badges = Array.prototype.slice.call(bar.querySelectorAll('.claim-status-badge'));
    var cards  = Array.prototype.slice.call(document.querySelectorAll('[data-claim-card]'));
    var emptyMsg = document.getElementById('claim-empty-filter');
    var active = null;

    function apply(status) {
        cards.forEach(function (c) {
            c.style.display = (!status || c.getAttribute('data-status') === status) ? '' : 'none';
        });
        badges.forEach(function (b) {
            var on = !!status && b.getAttribute('data-status') === status;
            b.classList.toggle('is-active', on);
            b.setAttribute('aria-pressed', on ? 'true' : 'false');
        });
        if (emptyMsg) {
            var anyVisible = cards.some(function (c) { return c.style.display !== 'none'; });
            emptyMsg.style.display = (status && !anyVisible) ? '' : 'none';
        }
    }

    badges.forEach(function (b) {
        b.addEventListener('click', function () {
            var st = b.getAttribute('data-status');
            active = (active === st) ? null : st; // re-clic → retire le filtre
            apply(active);
        });
    });

    // Pré-activation éventuelle via ?status=
    var pre = bar.getAttribute('data-active');
    if (pre) { active = pre; apply(active); }
})();
</script>
{% endblock %}
