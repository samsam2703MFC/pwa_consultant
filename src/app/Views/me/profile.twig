{% extends "layouts/mobile_base.twig" %}
{% import "components/_icons.twig" as icons %}
{% set active_nav = 'profile' %}

{% block title %}{{ translations.title ?? 'Profil' }} — Panel consultant{% endblock %}

{% set uname = current_user.display_name ?? '' %}
{% set uparts = uname|trim|split(' ')|filter(p => p is not empty) %}
{% set uinit = (uparts|first|default('')|slice(0,1)) ~ (uparts|length > 1 ? uparts[1]|slice(0,1) : '') %}
{% set langs = {'en':'English','fr':'Français','it':'Italiano','pl':'Polski','nl':'Nederlands'} %}
{% set app_lang = lang_code ?? 'fr' %}

{% block topbar %}
<div class="app-topbar">
    <div class="container">
        <div class="scr-head">
            <div>
                <div class="scr-title">{{ translations.title ?? 'Profil' }}</div>
                <div class="scr-sub">{{ translations.subtitle ?? 'Mon compte' }}</div>
            </div>
            <button class="app-hamburger" id="appHamburger" aria-label="Menu" aria-expanded="false" aria-controls="appNavSheet">
                {{ icons.svg('menu', 22) }}
            </button>
        </div>
    </div>
</div>
{% endblock %}

{% block head %}
<style>
    /* Sélecteur de langue préférée (liste déroulante) */
    .pf-lang-wrap {
        padding: 12px 14px 4px;
    }
    .pf-lang-select {
        width: 100%;
        padding: 11px 40px 11px 14px;
        border: 1.5px solid rgba(0,0,0,.12);
        border-radius: 12px;
        background: #fff url("data:image/svg+xml;utf8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='%238D1D2C' stroke-width='2.2' stroke-linecap='round' stroke-linejoin='round'%3E%3Cpath d='m6 9 6 6 6-6'/%3E%3C/svg%3E") no-repeat right 14px center;
        font-size: .9rem;
        font-weight: 700;
        color: #241f1c;
        appearance: none;
        -webkit-appearance: none;
        outline: none;
        cursor: pointer;
    }
    .pf-lang-select:focus { border-color: #8D1D2C; }
    .pf-lang-hint {
        padding: 8px 14px 12px;
        font-size: .74rem;
        color: #7a7168;
    }
</style>
{% endblock %}

{% block content %}
<div class="page-content-loaded pf">

    {# ── Carte identité ── #}
    <div class="pf-card pf-identity">
        <span class="pf-avatar">{% if uinit|trim %}{{ uinit|upper }}{% else %}{{ icons.svg('user', 30) }}{% endif %}</span>
        <div class="pf-name">{{ uname ?: (translations.consultant ?? 'Consultant') }}</div>
        <div class="pf-role">{{ current_user.scope_type ?: (translations.consultant ?? 'Consultant') }}</div>
    </div>

    {# ── Langue préférée (liste déroulante) ── #}
    {% set lang_options = [
        {code: 'en', flag: '🇬🇧', name: 'English'},
        {code: 'fr', flag: '🇫🇷', name: 'Français'},
        {code: 'it', flag: '🇮🇹', name: 'Italiano'},
        {code: 'pl', flag: '🇵🇱', name: 'Polski'},
        {code: 'nl', flag: '🇳🇱', name: 'Nederlands'},
    ] %}
    <div class="pf-eyebrow">{{ translations.preferred_language ?? 'Langue préférée' }}</div>
    <div class="pf-card">
        <div class="pf-lang-wrap">
            <select class="pf-lang-select" id="pfLangSelect" aria-label="{{ translations.preferred_language ?? 'Langue préférée' }}">
                {% for l in lang_options %}
                    <option value="{{ l.code }}" {{ app_lang == l.code ? 'selected' : '' }}>{{ l.flag }} {{ l.name }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="pf-lang-hint">{{ translations.preferred_language_hint ?? "S'applique à l'affichage du panel sur cet appareil." }}</div>
    </div>

    {# ── Détails ── #}
    <div class="pf-eyebrow">{{ translations.account ?? 'Compte' }}</div>
    <div class="pf-card pf-list">
        <div class="pf-row">
            <span class="pf-row-ic" style="color:#1F4F6B">{{ icons.svg('user', 18) }}</span>
            <div class="pf-row-txt"><div class="pf-row-l">{{ translations.name ?? 'Nom' }}</div><div class="pf-row-v">{{ uname ?: '—' }}</div></div>
        </div>
        {% if current_user.scope_type %}
        <div class="pf-row">
            <span class="pf-row-ic" style="color:#8D1D2C">{{ icons.svg('store', 18) }}</span>
            <div class="pf-row-txt"><div class="pf-row-l">{{ translations.scope ?? 'Périmètre' }}</div><div class="pf-row-v">{{ current_user.scope_type }}{% if current_user.scope_id %} · #{{ current_user.scope_id }}{% endif %}</div></div>
        </div>
        {% endif %}
        <div class="pf-row">
            <span class="pf-row-ic" style="color:#C17A2A">{{ icons.svg('globe', 18) }}</span>
            <div class="pf-row-txt"><div class="pf-row-l">{{ translations.language ?? 'Langue' }}</div><div class="pf-row-v">{{ langs[app_lang] ?? app_lang|upper }}</div></div>
        </div>
        {% if current_user.membership_id %}
        <div class="pf-row">
            <span class="pf-row-ic" style="color:#5C4A8A">{{ icons.svg('id-card', 18) }}</span>
            <div class="pf-row-txt"><div class="pf-row-l">{{ translations.membership ?? 'Adhésion' }}</div><div class="pf-row-v">#{{ current_user.membership_id }}</div></div>
        </div>
        {% endif %}
    </div>

    {# ── Déconnexion ── #}
    <a href="{{ ROOT }}/logout" class="pf-logout">{{ icons.svg('log-out', 17) }} {{ translations.logout ?? 'Déconnexion' }}</a>

</div>
{% endblock %}

{% block scripts %}
<script>
// Langue préférée : cookie 1 an, appliqué immédiatement (rechargement).
(function () {
    var sel = document.getElementById('pfLangSelect');
    if (!sel) return;
    var current = sel.value;
    sel.addEventListener('change', function () {
        var lang = sel.value;
        if (!lang || lang === current) return;
        var exp = new Date(Date.now() + 365 * 24 * 3600 * 1000).toUTCString();
        document.cookie = 'consultant_lang=' + lang + '; expires=' + exp + '; path=/; SameSite=Lax';
        location.reload();
    });
})();
</script>
{% endblock %}
