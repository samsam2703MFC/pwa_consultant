{% extends "layouts/mobile_base.twig" %}
{% import "components/_icons.twig" as icons %}
{% set active_nav = 'profile' %}

{% block title %}Profil — Panel consultant{% endblock %}

{% set uname = current_user.display_name ?? '' %}
{% set uparts = uname|trim|split(' ')|filter(p => p is not empty) %}
{% set uinit = (uparts|first|default('')|slice(0,1)) ~ (uparts|length > 1 ? uparts[1]|slice(0,1) : '') %}
{% set langs = {'fr':'Français','en':'English','pl':'Polski'} %}

{% block topbar %}
<div class="app-topbar">
    <div class="container">
        <div class="scr-head">
            <div>
                <div class="scr-title">Profil</div>
                <div class="scr-sub">Mon compte</div>
            </div>
            <button class="app-hamburger" id="appHamburger" aria-label="Menu" aria-expanded="false" aria-controls="appNavSheet">
                {{ icons.svg('menu', 22) }}
            </button>
        </div>
    </div>
</div>
{% endblock %}

{% block content %}
<div class="page-content-loaded pf">

    {# ── Carte identité ── #}
    <div class="pf-card pf-identity">
        <span class="pf-avatar">{% if uinit|trim %}{{ uinit|upper }}{% else %}{{ icons.svg('user', 30) }}{% endif %}</span>
        <div class="pf-name">{{ uname ?: 'Consultant' }}</div>
        <div class="pf-role">{{ current_user.scope_type ?: 'Consultant' }}</div>
    </div>

    {# ── Détails ── #}
    <div class="pf-eyebrow">Compte</div>
    <div class="pf-card pf-list">
        <div class="pf-row">
            <span class="pf-row-ic" style="color:#1F4F6B">{{ icons.svg('user', 18) }}</span>
            <div class="pf-row-txt"><div class="pf-row-l">Nom</div><div class="pf-row-v">{{ uname ?: '—' }}</div></div>
        </div>
        {% if current_user.scope_type %}
        <div class="pf-row">
            <span class="pf-row-ic" style="color:#8D1D2C">{{ icons.svg('store', 18) }}</span>
            <div class="pf-row-txt"><div class="pf-row-l">Périmètre</div><div class="pf-row-v">{{ current_user.scope_type }}{% if current_user.scope_id %} · #{{ current_user.scope_id }}{% endif %}</div></div>
        </div>
        {% endif %}
        <div class="pf-row">
            <span class="pf-row-ic" style="color:#C17A2A">{{ icons.svg('globe', 18) }}</span>
            <div class="pf-row-txt"><div class="pf-row-l">Langue</div><div class="pf-row-v">{{ langs[current_user.lang_code] ?? (current_user.lang_code|upper) ?: 'Français' }}</div></div>
        </div>
        {% if current_user.membership_id %}
        <div class="pf-row">
            <span class="pf-row-ic" style="color:#5C4A8A">{{ icons.svg('id-card', 18) }}</span>
            <div class="pf-row-txt"><div class="pf-row-l">Adhésion</div><div class="pf-row-v">#{{ current_user.membership_id }}</div></div>
        </div>
        {% endif %}
    </div>

    {# ── Déconnexion ── #}
    <a href="{{ ROOT }}/logout" class="pf-logout">{{ icons.svg('log-out', 17) }} Déconnexion</a>

</div>
{% endblock %}
