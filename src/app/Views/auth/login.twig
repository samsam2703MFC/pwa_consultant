{% import "components/_icons.twig" as icons %}
<!DOCTYPE html>
<html lang="{{ lang_code ?? 'fr' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>{{ translations.title ?? 'Panel consultant — Connexion' }}</title>

    <link rel="stylesheet" href="{{ ROOT }}/assets/mazer/compiled/css/app.css">
    <link rel="stylesheet" href="{{ ROOT }}/assets/mazer/extensions/bootstrap-icons/font/bootstrap-icons.css">
    <link rel="stylesheet" href="{{ ROOT }}/assets/css/atelier-theme.css">

    <link rel="manifest" href="{{ ROOT }}/manifest.webmanifest">
    <meta name="theme-color" content="#8D1D2C">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <link rel="apple-touch-icon" href="{{ ROOT }}/assets/pwa/icon-192.png">

    <style>
        .auth-screen {
            min-height:100vh; display:flex; flex-direction:column; justify-content:center;
            padding:calc(env(safe-area-inset-top,0px) + 28px) 26px calc(env(safe-area-inset-bottom,0px) + 28px);
            background:radial-gradient(120% 60% at 50% 0%,#f2ece3 0%,rgba(242,236,227,0) 55%),#F4EFE8;
        }
        .auth-wrap { width:100%; max-width:420px; margin:0 auto; }
        .auth-logo { height:34px; width:auto; display:block; margin:0 auto; }
        .auth-title { font-family:'Vank','Gotham',serif; font-size:27px; color:#241f1c; margin-top:8px; }
        .auth-sub { font-size:13px; color:#7a7168; margin-top:5px; }
        .auth-field { position:relative; }
        .auth-field-ic { position:absolute; left:15px; top:50%; transform:translateY(-50%); color:#a89e93; display:flex; }
        .auth-input {
            width:100%; border:1px solid rgba(36,26,22,.16); background:#fff; border-radius:14px;
            padding:15px 15px 15px 44px; font-size:15px; font-family:inherit; color:#241f1c; outline:none;
            transition:border-color .15s, box-shadow .15s;
        }
        .auth-input::placeholder { color:#a89e93; }
        .auth-input:focus { border-color:#F2C9A0; box-shadow:0 0 0 3px rgba(141,29,44,.14); }
        .auth-input.is-invalid { border-color:#c0392b; }
        .auth-btn {
            width:100%; border:none; background:#8D1D2C; color:#fff; border-radius:14px; padding:15px;
            font-size:15px; font-weight:600; font-family:inherit; cursor:pointer;
            box-shadow:0 10px 24px -10px rgba(141,29,44,.6);
            display:flex; align-items:center; justify-content:center; gap:8px; margin-top:4px;
        }
        .auth-btn:active { background:#731722; }
        .auth-help { text-align:center; font-size:12.5px; color:#7a7168; margin-top:8px; }
        .invalid-feedback { display:block; }
    </style>
</head>

<body>
<div class="auth-screen">
    <div class="auth-wrap">
        <div style="text-align:center;margin-bottom:26px">
            <img src="{{ ROOT }}/assets/brand/logo.png" alt="L'Atelier" class="auth-logo">
            <div class="auth-title">{{ translations.panel ?? 'Panel consultant' }}</div>
            <div class="auth-sub">{{ translations.sign_in_continue ?? 'Connectez-vous pour continuer' }}</div>
        </div>

        <form method="POST" autocomplete="on" style="display:flex;flex-direction:column;gap:12px">
            <div class="auth-field">
                <span class="auth-field-ic">{{ icons.svg('phone', 18) }}</span>
                <input type="tel" name="phone" value="{{ old('phone') }}"
                       placeholder="{{ translations.phone_ph ?? 'Numéro de téléphone' }}"
                       inputmode="tel" autocomplete="tel" autocapitalize="none" spellcheck="false"
                       class="auth-input {{ errors.phone is not empty ? 'is-invalid' : '' }}">
                {% if errors.phone is not empty %}<div class="invalid-feedback mt-1">{{ errors.phone }}</div>{% endif %}
            </div>

            <div class="auth-field">
                <span class="auth-field-ic">{{ icons.svg('shield', 18) }}</span>
                <input type="password" name="password" value="{{ old('password') }}"
                       placeholder="{{ translations.password_ph ?? 'Mot de passe' }}" autocomplete="current-password"
                       class="auth-input {{ errors.password is not empty ? 'is-invalid' : '' }}">
                {% if errors.password is not empty %}<div class="invalid-feedback mt-1">{{ errors.password }}</div>{% endif %}
            </div>

            {% if errors.login_error is not empty %}
                {% set errCode = errors.login_error %}
                {% if errCode == 'MEMBERSHIP_INACTIVE' %}
                    <div class="alert alert-warning d-flex align-items-start gap-2 mb-0 py-2 px-3" role="alert" style="border-radius:12px;">
                        <span class="mt-1 flex-shrink-0" style="font-size:1.1rem;">{{ icons.svg('lock') }}</span>
                        <div>
                            <div class="fw-semibold" style="font-size:.92rem;">{{ translations.no_access ?? "Pas d'accès à l'application" }}</div>
                            <div style="font-size:.85rem; margin-top:2px;">{{ translations.no_access_desc ?? "Votre compte n'est pas actif. Contactez l'administrateur du réseau pour rétablir l'accès." }}</div>
                        </div>
                    </div>
                {% elseif errCode == 'ACCOUNT_DISABLED' %}
                    <div class="alert alert-danger d-flex align-items-start gap-2 mb-0 py-2 px-3" role="alert" style="border-radius:12px;">
                        <span class="mt-1 flex-shrink-0" style="font-size:1.1rem;">{{ icons.svg('user-x') }}</span>
                        <div>
                            <div class="fw-semibold" style="font-size:.92rem;">{{ translations.account_blocked ?? 'Compte bloqué' }}</div>
                            <div style="font-size:.85rem; margin-top:2px;">{{ translations.account_blocked_desc ?? "Votre compte a été bloqué. Contactez l'administrateur du réseau." }}</div>
                        </div>
                    </div>
                {% else %}
                    <div class="invalid-feedback" style="display:block;">
                        {{ translations.invalid_credentials ?? 'Numéro de téléphone ou mot de passe invalide.' }}
                    </div>
                {% endif %}
            {% endif %}

            <button type="submit" class="auth-btn">
                {{ icons.svg('log-in', 17) }} {{ translations.log_in ?? 'Se connecter' }}
            </button>

            <div class="auth-help">
                Problème de connexion ? Contactez votre administrateur.
            </div>
        </form>
    </div>
</div>

<script>
    (function () {
        if (!("serviceWorker" in navigator)) return;
        window.addEventListener("load", async () => {
            try {
                await navigator.serviceWorker.register("/pwa_consultant/sw.js", { scope: "/pwa_consultant/" });
            } catch (e) {
                console.warn("SW register failed", e);
            }
        });
    })();
</script>

{# ── PWA install banner ── #}
<style>
    #pwa-banner {
        position: fixed; bottom: calc(env(safe-area-inset-bottom, 0px) + 16px);
        left: 12px; right: 12px; z-index: 2000;
        background: #fff; border-radius: 18px;
        box-shadow: 0 8px 32px rgba(70,40,25,.18), 0 2px 8px rgba(0,0,0,.08);
        padding: 14px 16px 14px 14px;
        display: flex; align-items: center; gap: 12px;
        animation: pwa-slide-up .35s cubic-bezier(.34,1.56,.64,1) both;
        border: 1px solid rgba(36,26,22,.14);
    }
    @keyframes pwa-slide-up {
        from { opacity: 0; transform: translateY(24px) scale(.97); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    #pwa-banner .pwa-icon { width: 48px; height: 48px; border-radius: 12px; flex-shrink: 0; object-fit: cover; }
    #pwa-banner .pwa-body { flex: 1; min-width: 0; }
    #pwa-banner .pwa-title { font-weight: 700; font-size: .9rem; color: #241f1c; line-height: 1.2; }
    #pwa-banner .pwa-sub   { font-size: .72rem; color: #7a7168; margin-top: 2px; }
    #pwa-banner .pwa-btn-install {
        background: linear-gradient(135deg,#8D1D2C,#b5354a);
        color: #fff; border: none; padding: 7px 14px; border-radius: 20px;
        font-size: .78rem; font-weight: 700; white-space: nowrap; cursor: pointer; flex-shrink: 0;
    }
    #pwa-banner .pwa-btn-close {
        background: none; border: none; color: #adb5bd; font-size: 1.1rem;
        cursor: pointer; padding: 0 0 0 6px; line-height: 1; flex-shrink: 0;
    }
</style>

<script>
(function () {
    const SNOOZE_KEY  = 'pwa_banner_snoozed';
    const SNOOZE_DAYS = 30;
    function isSnoozed() {
        try { const ts = localStorage.getItem(SNOOZE_KEY); return ts && (Date.now() - parseInt(ts, 10)) < SNOOZE_DAYS * 86400_000; }
        catch { return false; }
    }
    function snooze() { try { localStorage.setItem(SNOOZE_KEY, Date.now()); } catch {} }

    const isStandalone = window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone === true;
    if (isStandalone || isSnoozed()) return;

    let deferredPrompt = null;
    window.addEventListener('beforeinstallprompt', (e) => {
        e.preventDefault();
        deferredPrompt = e;

        const banner = document.createElement('div');
        banner.id = 'pwa-banner';
        banner.innerHTML = `
            <img class="pwa-icon" src="/pwa_consultant/assets/pwa/icon-192.png" alt="icon">
            <div class="pwa-body">
                <div class="pwa-title">{{ translations.install_app ?? "Installer l'application" }}</div>
                <div class="pwa-sub">{{ translations.add_to_home ?? "Ajouter à l'écran d'accueil" }}</div>
            </div>
            <button class="pwa-btn-install">{{ translations.install ?? 'Installer' }}</button>
            <button class="pwa-btn-close" aria-label="{{ translations.close ?? 'Fermer' }}">✕</button>`;
        document.body.appendChild(banner);

        banner.querySelector('.pwa-btn-install').onclick = async () => {
            banner.remove(); deferredPrompt.prompt();
            const { outcome } = await deferredPrompt.userChoice;
            if (outcome === 'accepted') snooze();
            deferredPrompt = null;
        };
        banner.querySelector('.pwa-btn-close').onclick = () => { snooze(); banner.remove(); };
    });
    window.addEventListener('appinstalled', () => { snooze(); const b = document.getElementById('pwa-banner'); if (b) b.remove(); });
})();
</script>

</body>
</html>
