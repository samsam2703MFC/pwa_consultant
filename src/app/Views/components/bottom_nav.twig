{# components/bottom_nav.twig #}
{#
  Top-sheet navigation — otwierana przyciskiem hamburger w topbarze.
  Wysuwa się z góry ekranu. Zawiera siatkę 2-kolumnową z kartami sekcji.
  Parametry:
    active_nav  — klucz aktywnej pozycji (string, np. 'shops')
    items       — opcjonalna tablica pozycji (nadpisuje domyślne)
#}
{% import "components/_icons.twig" as icons %}
{% set items = items ?? [
    {
        key: 'dashboard',
        label: translations.nav_home ?? 'Accueil',
        sub:   translations.nav_home_sub ?? 'Aperçu du jour',
        icon:  'home',
        color: '#8D1D2C',
        bg:    'rgba(141,29,44,.12)',
        href:  ROOT ~ '/dashboard',
        full:  true
    },
    {
        key: 'shops',
        label: translations.nav_shops ?? 'Boutiques',
        sub:   translations.nav_shops_sub ?? 'Chiffre d\'affaires et synthèse',
        icon:  'store',
        color: '#8D1D2C',
        bg:    'rgba(141,29,44,.12)',
        href:  ROOT ~ '/shops'
    },
    {
        key: 'sixl',
        label: translations.nav_sixl ?? 'HEXm',
        sub:   translations.nav_sixl_sub ?? 'Management — les 6 leviers de gestion',
        icon:  'hexm',
        color: '#8D1D2C',
        bg:    'rgba(141,29,44,.12)',
        href:  ROOT ~ '/levers'
    },
    {
        key: 'reports',
        label: translations.nav_reports ?? 'Rapports',
        sub:   translations.nav_reports_sub ?? 'Envoi de rapports PDF',
        icon:  'file-text',
        color: '#2D7A3E',
        bg:    'rgba(45,122,62,.12)',
        href:  ROOT ~ '/reports'
    },
    {
        key: 'helpdesk',
        label: translations.nav_helpdesk ?? 'Demandes',
        sub:   translations.nav_helpdesk_sub ?? 'Tickets Helpdesk',
        icon:  'life-buoy',
        color: '#C17A2A',
        bg:    'rgba(193,122,42,.14)',
        href:  ROOT ~ '/helpdesk'
    },
    {
        key: 'tasks',
        label: translations.nav_tasks ?? 'Tâches',
        sub:   translations.nav_tasks_sub ?? 'Tâches du consultant',
        icon:  'square-check',
        color: '#1F4F6B',
        bg:    'rgba(31,79,107,.12)',
        href:  ROOT ~ '/tasks'
    },
    {
        key: 'claims',
        label: translations.nav_claims ?? 'Réclamations',
        sub:   translations.nav_claims_sub ?? 'Réclamations CENTRAL',
        icon:  'circle-alert',
        color: '#8D1D2C',
        bg:    'rgba(141,29,44,.12)',
        href:  ROOT ~ '/claims'
    },
    {
        key: 'notes',
        label: translations.nav_notes ?? 'Notes',
        sub:   translations.nav_notes_sub ?? 'Commentaires par boutique',
        icon:  'square-pen',
        color: '#5C4A8A',
        bg:    'rgba(92,74,138,.12)',
        href:  ROOT ~ '/notes'
    },
    {
        key: 'checklists',
        label: translations.nav_checklists ?? 'Checklists',
        sub:   translations.nav_checklists_sub ?? 'Réalisation des tâches en boutique',
        icon:  'clipboard-check',
        color: '#1F4F6B',
        bg:    'rgba(31,79,107,.12)',
        href:  ROOT ~ '/checklists'
    },
    {
        key: 'targets',
        label: translations.nav_targets ?? 'Targets',
        sub:   translations.nav_targets_sub ?? 'Seuils d\'évaluation des boutiques',
        icon:  'target',
        color: '#C17A2A',
        bg:    'rgba(193,122,42,.14)',
        href:  ROOT ~ '/targets'
    },
] %}
{# Le profil ne vit plus dans la grille : ligne-bouton rouge avec l'avatar,
   tout en bas du menu (voir app-nav-profile). #}
{# Backdrop #}
<div class="app-nav-backdrop" id="appNavBackdrop" aria-hidden="true"></div>
{# Top Sheet #}
<div class="app-nav-sheet"
     id="appNavSheet"
     role="dialog"
     aria-modal="true"
     aria-label="{{ translations.primary_navigation ?? 'Navigation principale' }}">
    <div class="app-nav-sheet-header">
        <p class="app-nav-sheet-title">{{ translations.menu ?? 'Menu' }}</p>
        <button class="app-nav-sheet-close" id="appNavClose" aria-label="{{ translations.close ?? 'Fermer' }}">
            {{ icons.svg('x', 20) }}
        </button>
    </div>
    <div class="app-nav-grid">
        {% for it in items %}
            {% set is_active = (active_nav ?? '') == it.key %}
            <a href="{{ it.href }}"
               class="app-nav-card {{ is_active ? 'is-active' : '' }}"
               aria-current="{{ is_active ? 'page' : 'false' }}">
                <span class="app-nav-card-icon" aria-hidden="true">
                    {{ icons.svg(it.icon, 20) }}
                </span>
                <span class="app-nav-card-label">{{ it.label }}</span>
            </a>
        {% endfor %}
    </div>
    {# ── Plein écran : toggle DANS le menu, valable toute la visite ── #}
    <button type="button" class="app-nav-fstoggle" id="appFsToggle" role="switch" aria-checked="false">
        <span class="app-nav-fstoggle-ic">{{ icons.svg('maximize', 18) }}</span>
        <span class="app-nav-fstoggle-lbl">{{ translations.fullscreen_on ?? 'Plein écran' }}</span>
        <span class="app-nav-fstoggle-sw" aria-hidden="true"><i></i></span>
    </button>
    {# ── Profil : ligne-bouton rouge avec l'avatar, tout en bas du menu ── #}
    {% set _dn = (current_user.display_name ?? 'Consultant')|trim %}
    {% set _parts = _dn|split(' ') %}
    {% set _initials = (_parts[0]|first ~ (_parts[1] is defined ? _parts[1]|first : ''))|upper %}
    <a href="{{ ROOT }}/me" class="app-nav-profile {{ (active_nav ?? '') == 'profile' ? 'is-active' : '' }}">
        <span class="app-nav-profile-avatar" aria-hidden="true">{{ _initials }}</span>
        <span class="app-nav-profile-txt">
            <span class="app-nav-profile-name">{{ _dn }}</span>
            <span class="app-nav-profile-sub">{{ translations.nav_profile_sub ?? 'Mon compte et réglages' }}</span>
        </span>
        <span class="app-nav-profile-chev">{{ icons.svg('chevron-right', 16) }}</span>
    </a>
    <div class="app-nav-sheet-handle"></div>
</div>
<style>
    /* Toggle plein écran dans le menu — état on/off visible */
    .app-nav-fstoggle {
        display: flex; align-items: center; gap: 10px;
        width: calc(100% - 24px); margin: 10px 12px 4px; min-height: 46px;
        padding: 0 12px; border: 0; border-radius: 12px;
        background: rgba(0,0,0,.04); color: #241f1c;
        font-size: .84rem; font-weight: 800; cursor: pointer; text-align: left;
        -webkit-tap-highlight-color: transparent;
    }
    .app-nav-fstoggle:active { background: rgba(0,0,0,.08); }
    .app-nav-fstoggle-ic { display: inline-flex; color: #8D1D2C; flex-shrink: 0; }
    .app-nav-fstoggle-lbl { flex: 1; }
    .app-nav-fstoggle-sw {
        width: 40px; height: 22px; border-radius: 999px; flex-shrink: 0;
        background: #d8d2c9; position: relative; transition: background .18s ease;
    }
    .app-nav-fstoggle-sw i {
        position: absolute; top: 2px; left: 2px; width: 18px; height: 18px;
        border-radius: 50%; background: #fff; box-shadow: 0 1px 3px rgba(0,0,0,.25);
        transition: left .18s ease;
    }
    .app-nav-fstoggle[aria-checked="true"] .app-nav-fstoggle-sw { background: #2D7A3E; }
    .app-nav-fstoggle[aria-checked="true"] .app-nav-fstoggle-sw i { left: 20px; }

    /* Profil : ligne-bouton ROUGE tout en bas du menu, avec l'avatar */
    .app-nav-profile {
        display: flex; align-items: center; gap: 11px;
        width: calc(100% - 24px); margin: 8px 12px 6px; min-height: 54px;
        padding: 0 14px; border-radius: 14px;
        background: #8D1D2C; color: #fff; text-decoration: none;
        box-shadow: 0 8px 18px -12px rgba(141,29,44,.6);
        -webkit-tap-highlight-color: transparent;
    }
    .app-nav-profile:hover, .app-nav-profile:focus { color: #fff; text-decoration: none; }
    .app-nav-profile:active { background: #7a1826; }
    .app-nav-profile-avatar {
        width: 34px; height: 34px; border-radius: 50%; flex-shrink: 0;
        background: #fff; color: #8D1D2C;
        display: flex; align-items: center; justify-content: center;
        font-size: .78rem; font-weight: 800; letter-spacing: .02em;
    }
    .app-nav-profile-txt { flex: 1; min-width: 0; display: flex; flex-direction: column; }
    .app-nav-profile-name { font-size: .84rem; font-weight: 800; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .app-nav-profile-sub { font-size: .62rem; opacity: .75; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .app-nav-profile-chev { display: inline-flex; opacity: .8; flex-shrink: 0; }
</style>
<script>
(function () {
    const btn      = document.getElementById('appHamburger');
    const sheet    = document.getElementById('appNavSheet');
    const backdrop = document.getElementById('appNavBackdrop');
    const closeBtn = document.getElementById('appNavClose');
    if (!btn || !sheet || !backdrop) return;
    function openMenu() {
        sheet.classList.add('is-open');
        backdrop.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
        const icOpen = btn.querySelector('i');
        if (icOpen) icOpen.className = 'bi bi-x-lg';   // hamburger legacy <i> ; SVG → rien
        document.body.style.overflow = 'hidden';
        closeBtn && closeBtn.focus();
    }
    function closeMenu() {
        sheet.classList.remove('is-open');
        backdrop.classList.remove('is-open');
        btn.setAttribute('aria-expanded', 'false');
        const icClose = btn.querySelector('i');
        if (icClose) icClose.className = 'bi bi-list';
        document.body.style.overflow = '';
    }
    btn.addEventListener('click', function () {
        sheet.classList.contains('is-open') ? closeMenu() : openMenu();
    });
    backdrop.addEventListener('click', closeMenu);
    closeBtn && closeBtn.addEventListener('click', closeMenu);
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && sheet.classList.contains('is-open')) closeMenu();
    });
    // Swipe up to close (top sheet swipe)
    let startY = 0;
    sheet.addEventListener('touchstart', function (e) {
        startY = e.touches[0].clientY;
    }, { passive: true });
    sheet.addEventListener('touchend', function (e) {
        if (startY - e.changedTouches[0].clientY > 60) closeMenu();
    }, { passive: true });

})();

// ── Plein écran PERSISTANT (toggle dans le menu) ────────────────────────
// Le toggle vaut pour TOUTE LA VISITE : l'état voulu vit dans
// sessionStorage (partagé entre les pages, mort à la fermeture de
// session). L'app est multi-pages : le navigateur sort du plein écran à
// chaque navigation → l'état est RÉAPPLIQUÉ au premier geste utilisateur
// sur la nouvelle page (l'API Fullscreen exige un geste, impossible de le
// forcer au chargement). Sortie voulue = Échap ou toggle off → état oublié.
(function () {
    'use strict';
    const root = document.documentElement;
    const req = root.requestFullscreen || root.webkitRequestFullscreen;
    const btn = document.getElementById('appFsToggle');
    if (!btn) return;
    if (!req) { btn.style.display = 'none'; return; }   // API absente (iPhone)

    const KEY = 'consultant_fs';
    const LBL_ON  = {{ (translations.fullscreen_on ?? 'Plein écran')|json_encode|raw }};
    const LBL_OFF = {{ (translations.fullscreen_off ?? 'Quitter le plein écran')|json_encode|raw }};
    const lbl = btn.querySelector('.app-nav-fstoggle-lbl');

    const isFs = () => !!(document.fullscreenElement || document.webkitFullscreenElement);
    const wanted = () => sessionStorage.getItem(KEY) === '1';
    const enter = () => { try { const p = req.call(root); if (p && p.catch) p.catch(() => {}); } catch (e) {} };
    const exit  = () => { try { (document.exitFullscreen || document.webkitExitFullscreen).call(document); } catch (e) {} };
    // L'interrupteur affiche l'INTENTION (l'état voulu pour la visite), pas
    // seulement l'état instantané : sur une nouvelle page, le plein écran
    // n'est pas encore réappliqué (il attend le premier geste) mais le
    // toggle doit déjà être « on » — l'information voyage entre les pages.
    const refresh = () => {
        const on = isFs() || wanted();
        btn.setAttribute('aria-checked', on ? 'true' : 'false');
        if (lbl) lbl.textContent = on ? LBL_OFF : LBL_ON;
    };

    btn.addEventListener('click', function () {
        if (isFs() || wanted()) { sessionStorage.removeItem(KEY); exit(); }
        else { sessionStorage.setItem(KEY, '1'); enter(); }
        refresh();
        // referme le menu pour voir l'effet immédiatement
        const sheet = document.getElementById('appNavSheet');
        const backdrop = document.getElementById('appNavBackdrop');
        const ham = document.getElementById('appHamburger');
        if (sheet) sheet.classList.remove('is-open');
        if (backdrop) backdrop.classList.remove('is-open');
        if (ham) ham.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
    });

    // Échap pendant le plein écran = sortie VOULUE → intention oubliée.
    // (Seule action, avec le toggle, qui efface l'état : une sortie due à
    // une navigation ne l'efface jamais — c'était le bug de transmission
    // entre les pages.)
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && isFs()) sessionStorage.removeItem(KEY);
    }, true);

    // Le changement d'état réel ne fait que rafraîchir l'affichage :
    // l'état demandé (sessionStorage) ne s'efface QUE sur action explicite
    // (toggle off, ou Échap ci-dessus). Une sortie due à une navigation ne
    // l'efface jamais. Si on est sorti alors que l'intention est toujours
    // active (ex. sortie système), on ré-arme la ré-application au geste.
    function onChange() {
        refresh();
        if (!isFs() && wanted()) armReapply();
    }
    document.addEventListener('fullscreenchange', onChange);
    document.addEventListener('webkitfullscreenchange', onChange);

    // Ré-application après une navigation : au geste utilisateur sur la
    // nouvelle page, tant que l'état demandé est actif.
    // ⚠ Le navigateur n'accorde l'« activation utilisateur » (obligatoire
    // pour requestFullscreen) qu'au RELÂCHER sur tactile : pointerup /
    // click / touchend / keydown — jamais pointerdown (c'était le bug :
    // la ré-application échouait silencieusement à chaque page). On
    // réessaie à CHAQUE geste tant que le plein écran n'est pas
    // effectivement rétabli ; on désarme quand il l'est (fullscreenchange)
    // ou quand l'intention disparaît.
    let reapplyArmed = false;
    function armReapply() {
        if (reapplyArmed) return;
        reapplyArmed = true;
        const disarm = function () {
            document.removeEventListener('pointerup', tryEnter, true);
            document.removeEventListener('touchend', tryEnter, true);
            document.removeEventListener('click', tryEnter, true);
            document.removeEventListener('keydown', tryEnter, true);
            document.removeEventListener('fullscreenchange', onEntered, true);
            document.removeEventListener('webkitfullscreenchange', onEntered, true);
            reapplyArmed = false;
        };
        const tryEnter = function () {
            if (!wanted() || isFs()) { disarm(); return; }
            enter();
        };
        const onEntered = function () { if (isFs()) disarm(); };
        document.addEventListener('pointerup', tryEnter, true);
        document.addEventListener('touchend', tryEnter, true);
        document.addEventListener('click', tryEnter, true);
        document.addEventListener('keydown', tryEnter, true);
        document.addEventListener('fullscreenchange', onEntered, true);
        document.addEventListener('webkitfullscreenchange', onEntered, true);
    }
    if (wanted() && !isFs()) armReapply();
    refresh();
})();
</script>
