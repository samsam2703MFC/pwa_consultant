{# components/bottom_nav.twig #}
{#
  Top-sheet navigation — otwierana przyciskiem hamburger w topbarze.
  Wysuwa się z góry ekranu. Zawiera siatkę 2-kolumnową z kartami sekcji.
  Parametry:
    active_nav  — klucz aktywnej pozycji (string, np. 'shops')
    items       — opcjonalna tablica pozycji (nadpisuje domyślne)
#}
{% import "components/_icons.twig" as icons %}
{% set items = items ?? [
    {
        key: 'dashboard',
        label: translations.nav_home ?? 'Accueil',
        sub:   translations.nav_home_sub ?? 'Aperçu du jour',
        icon:  'home',
        color: '#8D1D2C',
        bg:    'rgba(141,29,44,.12)',
        href:  ROOT ~ '/dashboard',
        full:  true
    },
    {
        key: 'shops',
        label: translations.nav_shops ?? 'Boutiques',
        sub:   translations.nav_shops_sub ?? 'Chiffre d\'affaires et synthèse',
        icon:  'store',
        color: '#8D1D2C',
        bg:    'rgba(141,29,44,.12)',
        href:  ROOT ~ '/shops'
    },
    {
        key: 'reports',
        label: translations.nav_reports ?? 'Rapports',
        sub:   translations.nav_reports_sub ?? 'Envoi de rapports PDF',
        icon:  'file-text',
        color: '#2D7A3E',
        bg:    'rgba(45,122,62,.12)',
        href:  ROOT ~ '/reports'
    },
    {
        key: 'helpdesk',
        label: translations.nav_helpdesk ?? 'Demandes',
        sub:   translations.nav_helpdesk_sub ?? 'Tickets Helpdesk',
        icon:  'life-buoy',
        color: '#C17A2A',
        bg:    'rgba(193,122,42,.14)',
        href:  ROOT ~ '/helpdesk'
    },
    {
        key: 'tasks',
        label: translations.nav_tasks ?? 'Tâches',
        sub:   translations.nav_tasks_sub ?? 'Tâches du consultant',
        icon:  'square-check',
        color: '#1F4F6B',
        bg:    'rgba(31,79,107,.12)',
        href:  ROOT ~ '/tasks'
    },
    {
        key: 'claims',
        label: translations.nav_claims ?? 'Réclamations',
        sub:   translations.nav_claims_sub ?? 'Réclamations CENTRAL',
        icon:  'circle-alert',
        color: '#8D1D2C',
        bg:    'rgba(141,29,44,.12)',
        href:  ROOT ~ '/claims'
    },
    {
        key: 'notes',
        label: translations.nav_notes ?? 'Notes',
        sub:   translations.nav_notes_sub ?? 'Commentaires par boutique',
        icon:  'square-pen',
        color: '#5C4A8A',
        bg:    'rgba(92,74,138,.12)',
        href:  ROOT ~ '/notes'
    },
    {
        key: 'checklists',
        label: translations.nav_checklists ?? 'Checklists',
        sub:   translations.nav_checklists_sub ?? 'Réalisation des tâches en boutique',
        icon:  'clipboard-check',
        color: '#1F4F6B',
        bg:    'rgba(31,79,107,.12)',
        href:  ROOT ~ '/checklists'
    },
    {
        key: 'targets',
        label: translations.nav_targets ?? 'Targets',
        sub:   translations.nav_targets_sub ?? 'Seuils d\'évaluation des boutiques',
        icon:  'target',
        color: '#C17A2A',
        bg:    'rgba(193,122,42,.14)',
        href:  ROOT ~ '/targets'
    },
    {
        key: 'profile',
        label: translations.nav_profile ?? 'Profil',
        sub:   translations.nav_profile_sub ?? 'Mon compte et réglages',
        icon:  'user',
        color: '#8a4a24',
        bg:    'rgba(138,74,36,.12)',
        href:  ROOT ~ '/me'
    },
] %}
{# Backdrop #}
<div class="app-nav-backdrop" id="appNavBackdrop" aria-hidden="true"></div>
{# Top Sheet #}
<div class="app-nav-sheet"
     id="appNavSheet"
     role="dialog"
     aria-modal="true"
     aria-label="{{ translations.primary_navigation ?? 'Navigation principale' }}">
    <div class="app-nav-sheet-header">
        <p class="app-nav-sheet-title">{{ translations.menu ?? 'Menu' }}</p>
        <button class="app-nav-sheet-close" id="appNavClose" aria-label="{{ translations.close ?? 'Fermer' }}">
            {{ icons.svg('x', 20) }}
        </button>
    </div>
    <div class="app-nav-grid">
        {% for it in items %}
            {% set is_active = (active_nav ?? '') == it.key %}
            <a href="{{ it.href }}"
               class="app-nav-card {{ is_active ? 'is-active' : '' }}"
               aria-current="{{ is_active ? 'page' : 'false' }}">
                <span class="app-nav-card-icon" aria-hidden="true">
                    {{ icons.svg(it.icon, 20) }}
                </span>
                <span class="app-nav-card-label">{{ it.label }}</span>
            </a>
        {% endfor %}
    </div>
    <div class="app-nav-sheet-handle"></div>
</div>
<style>
    /* Icône plein écran discrète, insérée par JS à côté du bouton menu ☰ */
    .app-fs-toggle {
        display: inline-flex; align-items: center; justify-content: center;
        width: 36px; height: 36px; margin-right: 2px;
        border: 0; border-radius: 10px; background: transparent;
        color: #7a7168; opacity: .75; cursor: pointer; flex-shrink: 0;
        -webkit-tap-highlight-color: transparent;
    }
    .app-fs-toggle:active { background: rgba(0,0,0,.07); opacity: 1; }
</style>
<script>
(function () {
    const btn      = document.getElementById('appHamburger');
    const sheet    = document.getElementById('appNavSheet');
    const backdrop = document.getElementById('appNavBackdrop');
    const closeBtn = document.getElementById('appNavClose');
    if (!btn || !sheet || !backdrop) return;
    function openMenu() {
        sheet.classList.add('is-open');
        backdrop.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
        btn.querySelector('i').className = 'bi bi-x-lg';
        document.body.style.overflow = 'hidden';
        closeBtn && closeBtn.focus();
    }
    function closeMenu() {
        sheet.classList.remove('is-open');
        backdrop.classList.remove('is-open');
        btn.setAttribute('aria-expanded', 'false');
        btn.querySelector('i').className = 'bi bi-list';
        document.body.style.overflow = '';
    }
    btn.addEventListener('click', function () {
        sheet.classList.contains('is-open') ? closeMenu() : openMenu();
    });
    backdrop.addEventListener('click', closeMenu);
    closeBtn && closeBtn.addEventListener('click', closeMenu);
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && sheet.classList.contains('is-open')) closeMenu();
    });
    // Swipe up to close (top sheet swipe)
    let startY = 0;
    sheet.addEventListener('touchstart', function (e) {
        startY = e.touches[0].clientY;
    }, { passive: true });
    sheet.addEventListener('touchend', function (e) {
        if (startY - e.changedTouches[0].clientY > 60) closeMenu();
    }, { passive: true });

})();

// ── Plein écran PERSISTANT ──────────────────────────────────────────────
// Petite icône discrète insérée à côté du bouton menu ☰ (toutes les pages).
// L'app est multi-pages : le navigateur sort du plein écran à chaque
// navigation. L'état VOULU vit donc dans sessionStorage (partagé entre les
// pages) et il est RÉAPPLIQUÉ au premier geste utilisateur sur la nouvelle
// page — l'API Fullscreen exige un geste, impossible de le forcer au
// chargement. Sortie voulue = Échap ou re-clic sur l'icône → état oublié.
(function () {
    'use strict';
    const root = document.documentElement;
    const req = root.requestFullscreen || root.webkitRequestFullscreen;
    const ham = document.getElementById('appHamburger');
    if (!req || !ham || !ham.parentNode) return;   // API absente (iPhone) → pas d'icône

    const KEY = 'consultant_fs';
    const SVG_ON  = '<svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3"/><path d="M21 8V5a2 2 0 0 0-2-2h-3"/><path d="M3 16v3a2 2 0 0 0 2 2h3"/><path d="M16 21h3a2 2 0 0 0 2-2v-3"/></svg>';
    const SVG_OFF = '<svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3v3a2 2 0 0 1-2 2H3"/><path d="M21 8h-3a2 2 0 0 1-2-2V3"/><path d="M3 16h3a2 2 0 0 1 2 2v3"/><path d="M16 21v-3a2 2 0 0 1 2-2h3"/></svg>';
    const LBL_ON  = {{ (translations.fullscreen_on ?? 'Plein écran')|json_encode|raw }};
    const LBL_OFF = {{ (translations.fullscreen_off ?? 'Quitter le plein écran')|json_encode|raw }};

    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'app-fs-toggle';
    btn.id = 'appFsToggle';
    ham.parentNode.insertBefore(btn, ham);

    const isFs = () => !!(document.fullscreenElement || document.webkitFullscreenElement);
    const enter = () => { try { const p = req.call(root); if (p && p.catch) p.catch(() => {}); } catch (e) {} };
    const exit  = () => { try { (document.exitFullscreen || document.webkitExitFullscreen).call(document); } catch (e) {} };
    const refresh = () => {
        btn.innerHTML = isFs() ? SVG_OFF : SVG_ON;
        btn.setAttribute('aria-label', isFs() ? LBL_OFF : LBL_ON);
        btn.title = isFs() ? LBL_OFF : LBL_ON;
    };

    btn.addEventListener('click', function () {
        if (isFs()) { sessionStorage.removeItem(KEY); exit(); }
        else { sessionStorage.setItem(KEY, '1'); enter(); }
    });

    // L'icône reflète TOUJOURS l'état réel. Sortie détectée sans re-clic :
    // navigation (la page se décharge → on GARDE l'état pour la suivante)
    // ou Échap (la page reste vivante → on oublie l'état après un court
    // délai de confirmation).
    function onChange() {
        refresh();
        if (!isFs() && sessionStorage.getItem(KEY) === '1') {
            setTimeout(function () {
                if (!document.hidden && !isFs()) sessionStorage.removeItem(KEY);
            }, 400);
        }
    }
    document.addEventListener('fullscreenchange', onChange);
    document.addEventListener('webkitfullscreenchange', onChange);

    // Ré-application après une navigation : au premier geste utilisateur
    // sur la nouvelle page, tant que l'état demandé est actif.
    if (sessionStorage.getItem(KEY) === '1' && !isFs()) {
        const reapply = function () {
            document.removeEventListener('pointerdown', reapply, true);
            document.removeEventListener('keydown', reapply, true);
            if (sessionStorage.getItem(KEY) === '1' && !isFs()) enter();
        };
        document.addEventListener('pointerdown', reapply, true);
        document.addEventListener('keydown', reapply, true);
    }
    refresh();
})();
</script>
