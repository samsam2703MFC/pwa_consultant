{% extends "layouts/mobile_base.twig" %}

{% import "components/_icons.twig" as icons %}
{% set active_nav = 'shops' %}
{% block title %}{{ translations.title ?? 'Boutiques' }} — Panel consultant{% endblock %}

{% block topbar %}
<div class="app-topbar">
    <div class="container">
        <div class="scr-head">
            <div>
                <div class="scr-title">{{ translations.title ?? 'Boutiques' }}</div>
                <div class="scr-sub">{{ translations.subtitle ?? "Aperçu financier · aujourd'hui" }}</div>
            </div>
            <button class="app-hamburger" id="appHamburger" aria-label="Menu" aria-expanded="false" aria-controls="appNavSheet">
                {{ icons.svg('menu', 22) }}
            </button>
        </div>
    </div>
</div>
{% endblock %}

{% block head %}
<style>
    /* ── P&L BLOCK ─────────────────────────────────────────── */
    .pnl-card {
        border-top: 1px solid rgba(0,0,0,.06);
        padding: 12px 16px 14px;
        display: none;
    }
    .pnl-card.is-open { display: block; }

    /* Period badges */
    .pnl-period-bar {
        display: flex;
        gap: 6px;
        margin-bottom: 14px;
    }
    .pnl-badge {
        flex: 1;
        text-align: center;
        padding: 5px 0;
        border-radius: 20px;
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .02em;
        cursor: pointer;
        border: 1.5px solid #dee2e6;
        color: #6c757d;
        background: transparent;
        transition: all .15s;
        -webkit-tap-highlight-color: transparent;
    }
    .pnl-badge.active {
        background: #8D1D2C;
        border-color: #8D1D2C;
        color: #fff;
    }

    /* P&L rows */
    .pnl-rows { display: flex; flex-direction: column; gap: 2px; }
    .pnl-row {
        display: flex;
        align-items: center;
        padding: 7px 10px;
        border-radius: 10px;
        cursor: default;
        transition: background .12s;
    }
    .pnl-row.is-expandable { cursor: pointer; -webkit-tap-highlight-color: transparent; }
    .pnl-row.is-expandable:active { background: rgba(141,29,44,.06); }
    .pnl-row-label {
        flex: 1;
        font-size: .8rem;
        font-weight: 700;
        color: #495057;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .pnl-row-label i { font-size: .75rem; color: #adb5bd; transition: transform .2s; }
    .pnl-row.expanded .pnl-row-label i { transform: rotate(90deg); }

    /* Levier de gestion — tags colorés (Masse salariale / Frais généraux) */
    .pnl-lever {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: .74rem; font-weight: 700; letter-spacing: .01em;
        padding: 3px 10px 3px 8px; border-radius: 999px; line-height: 1;
    }
    .pnl-lever::before {
        content: ''; width: 7px; height: 7px; border-radius: 1.5px;
        transform: rotate(45deg); background: currentColor;
    }
    .pnl-lever-food   { color: #10b981; background: rgba(16,185,129,.12); }
    .pnl-lever-labour { color: #8b5cf6; background: rgba(139,92,246,.12); }
    .pnl-lever-oc     { color: #06b6d4; background: rgba(6,182,212,.14); }

    /* % par rapport au TurnOver */
    .pnl-row-pct { font-size: .72rem; font-weight: 700; min-width: 48px; text-align: right; padding-left: 6px; color: #8a8079; }
    /* Marge brute — ligne calculée mise en avant */
    .pnl-row-sub { background: rgba(36,26,22,.035); border-radius: 10px; }
    .pnl-row-sub .pnl-row-label { font-weight: 800; color: #241f1c; }
    .pnl-row-sub .pnl-row-value { color: #241f1c; }
    .pnl-row-sub .pnl-row-pct   { color: #241f1c; }
    .pnl-row-value {
        font-size: .82rem;
        font-weight: 700;
        color: #212529;
        min-width: 70px;
        text-align: right;
    }
    .pnl-row-delta {
        font-size: .7rem;
        font-weight: 700;
        min-width: 46px;
        text-align: right;
        padding-left: 6px;
    }
    .pnl-row-delta.pos { color: #28a745; }
    .pnl-row-delta.neg { color: #dc3545; }
    .pnl-row-delta.neu { color: #adb5bd; }

    /* Result row highlight */
    .pnl-row.result-row {
        background: rgba(141,29,44,.06);
        border-radius: 10px;
    }
    .pnl-row.result-row .pnl-row-label { color: #8D1D2C; }
    .pnl-row.result-row .pnl-row-value { color: #8D1D2C; }

    /* Category breakdown — treemap (surface ∝ poids CA) */
    .pnl-categories {
        display: none;
        flex-direction: column;
        padding: 6px 0 4px;
    }
    .pnl-categories.is-open { display: flex; }
    .pnl-treemap { position: relative; width: 100%; border-radius: 12px; overflow: hidden; }
    .tm-cell {
        position: absolute; box-sizing: border-box; border-radius: 7px; overflow: hidden;
        color: #fff; display: flex; flex-direction: column; justify-content: flex-start;
    }
    .tm-name {
        font-size: .76rem; font-weight: 900; line-height: 1.2; letter-spacing: .01em;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        text-shadow: 0 1px 2px rgba(0,0,0,.25);
    }
    .tm-val  { font-size: .8rem; font-weight: 800; margin-top: 3px; text-shadow: 0 1px 2px rgba(0,0,0,.2); font-variant-numeric: tabular-nums; }
    .tm-share { font-size: .64rem; font-weight: 700; opacity: .95; margin-top: 1px; letter-spacing: .03em; text-transform: uppercase; }
    .tm-fc   { font-size: .62rem; font-weight: 700; opacity: .92; margin-top: 4px; }
    .tm-chip {
        display: inline-block; align-self: flex-start; margin-top: 5px;
        background: rgba(255,255,255,.28); border-radius: 999px; padding: 1px 7px;
        font-size: .6rem; font-weight: 800;
    }
    .tm-mini { font-size: .68rem; font-weight: 900; text-shadow: 0 1px 2px rgba(0,0,0,.3); margin: auto; }
    .tm-legend { font-size: .62rem; color: #8a8079; font-weight: 700; margin-top: 4px; padding: 0 2px; }
    .tm-scale { display: flex; flex-wrap: wrap; gap: 3px 9px; margin-top: 8px; padding: 0 2px; font-size: .6rem; font-weight: 800; color: #5f574f; }
    .tm-scale i { display: inline-block; width: 8px; height: 8px; border-radius: 3px; margin-right: 3px; vertical-align: -1px; }
    .tm-detail {
        display: none; margin-top: 8px; padding: 7px 10px;
        background: rgba(36,26,22,.045); border-radius: 9px;
        font-size: .72rem; font-weight: 700; color: #241f1c;
    }
    .tm-detail.show { display: block; }
    .tm-cell.sel { box-shadow: inset 0 0 0 2px #fff, inset 0 0 0 4px rgba(36,26,22,.35); }
    .pnl-cat-empty { font-size: .75rem; color: #adb5bd; font-style: italic; padding: 8px; }

    /* Halo d'auto-focus : signale la carte du magasin ciblé depuis l'accueil */
    .shop-focus-glow {
        animation: shopFocusGlow 2.2s ease-out 1;
        border-radius: 12px;
    }
    @keyframes shopFocusGlow {
        0%   { box-shadow: 0 0 0 0 rgba(141, 29, 44, 0); }
        25%  { box-shadow: 0 0 0 4px rgba(141, 29, 44, .45), 0 0 26px 6px rgba(141, 29, 44, .30); }
        60%  { box-shadow: 0 0 0 4px rgba(141, 29, 44, .30), 0 0 18px 4px rgba(141, 29, 44, .18); }
        100% { box-shadow: 0 0 0 0 rgba(141, 29, 44, 0); }
    }

    /* ── Comparaison structure (catégories × magasins) ── */
    .cmp-struct-wrap { margin-top: 16px; }
    .cmp-struct-btn {
        width: 100%; display: flex; align-items: center; justify-content: center; gap: 8px;
        background: #8D1D2C; color: #fff; border: 0; border-radius: 14px;
        padding: 12px 16px; font-size: .85rem; font-weight: 700;
        -webkit-tap-highlight-color: transparent;
    }
    .cmp-struct-chev { display: inline-flex; transition: transform .2s; }
    .cmp-struct-btn[aria-expanded="true"] .cmp-struct-chev { transform: rotate(180deg); }
    .cmp-struct-panel {
        background: #fff; border-radius: 14px; margin-top: 10px; padding: 12px;
        box-shadow: 0 1px 5px rgba(0,0,0,.05);
    }
    .cmp-sub { font-size: .66rem; color: #7a7168; margin-bottom: 8px; }
    .cmp-detail {
        display: none; font-size: .72rem; color: #241f1c; background: #F4EFE8;
        border-radius: 9px; padding: 7px 10px; margin-bottom: 8px; line-height: 1.35;
    }
    .cmp-detail.show { display: block; }
    .cmp-scroll { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .cmp-table { border-collapse: collapse; width: 100%; }
    .cmp-table th, .cmp-table td { font-size: .68rem; padding: 6px 5px; text-align: center; white-space: nowrap; }
    .cmp-table th {
        font-size: .58rem; text-transform: uppercase; letter-spacing: .05em;
        color: #7a7168; font-weight: 700; border-bottom: 1px solid #e7ded2;
    }
    /* Deux premières colonnes FIGÉES (Catégorie + Réseau) : seuls les
       magasins défilent horizontalement sur petit écran. La 1re colonne a
       une largeur fixe pour que la 2e puisse se coller juste après. */
    .cmp-table td.cmp-rowh, .cmp-table th.cmp-rowh {
        text-align: left; font-weight: 700; color: #241f1c; position: sticky; left: 0;
        background: #fff; width: 88px; min-width: 88px; max-width: 88px;
        overflow: hidden; text-overflow: ellipsis; z-index: 2;
    }
    .cmp-table td.cmp-netcol, .cmp-table th.cmp-netcol {
        position: sticky; left: 88px; background: #fff; z-index: 2;
        box-shadow: 3px 0 4px -2px rgba(70,40,25,.18);
    }
    .cmp-table tr + tr td { border-top: 1px solid #f3ece2; }
    .cmp-table td { cursor: pointer; -webkit-tap-highlight-color: transparent; }
    .cmp-table td.sel { box-shadow: inset 0 0 0 2px rgba(141,29,44,.45); border-radius: 6px; }
    .cmp-pct { font-weight: 700; }
    .cmp-dlt { display: block; font-size: .56rem; font-weight: 700; margin-top: 1px; }
    .cmp-zero { background: #fdeaea; color: #8B0000; }
    .cmp-low  { background: #fdf3e6; }
    .cmp-nd   { color: #adb5bd; }
    .cmp-legend { display: flex; flex-wrap: wrap; gap: 6px 12px; margin-top: 9px; font-size: .58rem; color: #7a7168; }
    .cmp-legend i { display: inline-block; width: 9px; height: 9px; border-radius: 3px; margin-right: 4px; vertical-align: -1px; }
    .cmp-empty { font-size: .75rem; color: #adb5bd; font-style: italic; padding: 8px; }

    /* Légende des couleurs en tête de page */
    .result-legend {
        background: #fff; border-radius: 12px; padding: 9px 12px; margin-bottom: 12px;
        box-shadow: 0 1px 5px rgba(0,0,0,.05);
    }
    .rl-title { display: block; font-size: .62rem; font-weight: 800; text-transform: uppercase; letter-spacing: .06em; color: #7a7168; margin-bottom: 6px; }
    .rl-row + .rl-row { margin-top: 8px; padding-top: 8px; border-top: 1px solid #f4f0e9; }
    .rl-items { display: flex; flex-wrap: wrap; gap: 5px 12px; }
    .rl-item { display: inline-flex; align-items: center; gap: 4px; font-size: .68rem; font-weight: 800; color: #241f1c; white-space: nowrap; }
    .rl-item i { width: 11px; height: 11px; border-radius: 4px; flex-shrink: 0; }

    .oc-breakdown {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 8px;
        margin-top: 8px;
        margin-bottom: 2px;
    }
    .oc-breakdown-item {
        background: #f8f9ff;
        border: 1px solid rgba(141,29,44,.12);
        border-radius: 10px;
        padding: 8px 10px;
        text-align: center;
    }
    .oc-breakdown-label {
        display: block;
        font-size: .68rem;
        font-weight: 700;
        color: #6c757d;
        text-transform: uppercase;
        letter-spacing: .04em;
        margin-bottom: 3px;
    }
    .oc-breakdown-value {
        display: block;
        font-size: .78rem;
        font-weight: 700;
        color: #212529;
    }

    /* Comparatif N vs N-1 — panneau de l'onglet dédié (masqué par défaut) */
    .pnl-compare { display: none; margin-bottom: 12px; }
    .pnl-compare.is-open { display: block; }
    .pnl-compare table { width: 100%; border-collapse: collapse; }
    .pnl-compare th {
        font-size: .62rem; font-weight: 800; text-transform: uppercase;
        letter-spacing: .04em; color: #8a8079; padding: 2px 4px 6px;
        text-align: left; border-bottom: 1px solid rgba(0,0,0,.07);
    }
    .pnl-compare td {
        font-size: .74rem; font-weight: 600; color: #241f1c;
        padding: 5px 4px; border-bottom: 1px solid rgba(0,0,0,.04);
        white-space: nowrap;
    }
    .pnl-compare tr:last-child td { border-bottom: 0; }
    .pnl-compare .num { text-align: right; }
    .pnl-compare td:first-child { color: #6c757d; font-weight: 700; font-size: .7rem; }
    .pnl-compare .dotcell { width: 16px; text-align: right; }
    .cmp-dot { display: inline-block; width: 9px; height: 9px; border-radius: 50%; }
    .cmp-dot-ok   { background: #2D7A3E; }
    .cmp-dot-warn { background: #C17A2A; }
    .cmp-dot-late { background: #8D1D2C; }
    .cmp-dot-na   { background: #cfc9c2; }
    .cmp-ok   { color: #2D7A3E; }
    .cmp-warn { color: #C17A2A; }
    .cmp-late { color: #8D1D2C; }
    .cmp-na   { color: #adb5bd; }

    /* Loading skeleton */
    .pnl-skeleton { padding: 4px 0; }
    .pnl-skel-line {
        height: 14px; border-radius: 7px; margin-bottom: 8px;
        background: linear-gradient(90deg,#f0f0f0 25%,#e4e4e4 50%,#f0f0f0 75%);
        background-size: 200% 100%;
        animation: shimmer 1.4s infinite;
    }

    /* Shop header row toggle */
    .shop-toggle-btn {
        background: none;
        border: none;
        padding: 0;
        display: flex;
        align-items: center;
        gap: 14px;
        width: 100%;
        text-align: left;
        cursor: pointer;
        -webkit-tap-highlight-color: transparent;
    }
    .shop-toggle-chevron { transition: transform .2s; }
    .shop-toggle-btn.open .shop-toggle-chevron { transform: rotate(90deg); }

    /* Divider between shops */
    .shop-pnl-divider {
        height: 1px;
        background: rgba(0,0,0,.06);
        margin: 0 16px;
    }

    /* Nom du magasin : jusqu'à 2 lignes, puis ellipse */
    .shop-name {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.25;
        overflow-wrap: anywhere;
    }

    /* Rang du magasin (1 = plus gros CA) */
    .shop-rank {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: #8D1D2C;
        color: #fff;
        font-size: .78rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        line-height: 1;
    }

    /* Synthèse magasin (CA / tickets / panier / produits) — grille 2×2 */
    .shop-synthese {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 12px;
    }
    .shop-kpi {
        flex: 1 1 calc(50% - 4px);
        min-width: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 8px 4px;
        border-radius: 10px;
        background: #F4EFE8;
    }
    .shop-kpi-val {
        font-size: .9rem;
        font-weight: 700;
        color: #241f1c;
        white-space: nowrap;
    }
    .shop-kpi-lbl {
        font-size: .66rem;
        color: #7a7168;
        margin-top: 2px;
    }
</style>
{% endblock %}

{% block content %}
<div class="page-content-loaded">

    {# ── Légende des couleurs du Result (la légende de marge des catégories
         vit dans le treemap, affichée à son ouverture) ── #}
    <div class="result-legend">
        <span class="rl-title">{{ translations.legend_result ?? 'Couleur du Result (marge en % du CA)' }}</span>
        <span class="rl-items">
            <span class="rl-item"><i style="background:#8B0000;"></i>{{ translations.loss ?? 'Perte' }}</span>
            <span class="rl-item"><i style="background:#dc3545;"></i>0–5&nbsp;%</span>
            <span class="rl-item"><i style="background:#e67e22;"></i>5–10&nbsp;%</span>
            <span class="rl-item"><i style="background:#8FA31E;"></i>10–15&nbsp;%</span>
            <span class="rl-item"><i style="background:#27ae60;"></i>15–25&nbsp;%</span>
            <span class="rl-item"><i style="background:#C9A227;"></i>&gt;&nbsp;25&nbsp;%</span>
        </span>
    </div>

    {% if shops is empty %}
        <div class="text-center text-muted py-5">
            <span style="font-size:2.5rem;opacity:.3;">{{ icons.svg('store') }}</span>
            <p class="mt-3">{{ translations.none ?? 'Aucune boutique disponible.' }}</p>
        </div>
    {% else %}
        <div class="d-flex flex-column gap-2">
            {% for shop in shops %}
                <div class="card border-0 shadow-sm" style="border-radius:14px;overflow:hidden;">

                    {# ── Shop header (tap to open notes / long-press / chevron to expand P&L) ── #}
                    <div class="card-body py-3">
                        <div class="d-flex align-items-center gap-3">
                            {% if shop.rank is defined %}
                            <div class="shop-rank flex-shrink-0" aria-label="{{ translations.rank ?? 'Rang' }} {{ shop.rank }}">{{ shop.rank }}</div>
                            {% endif %}
                            <div class="flex-grow-1 min-w-0">
                                <a href="{{ ROOT }}/shops/{{ shop.id }}/notes" class="text-decoration-none">
                                    <div class="fw-700 shop-name" style="font-size:.95rem;color:#212529;">{{ shop.representative_name ?? shop.name }}</div>
                                    <div class="text-muted text-truncate" style="font-size:.78rem;">{{ shop.city ?? '' }}</div>
                                </a>
                            </div>
                            {# P&L toggle button #}
                            <button class="btn btn-sm border-0 pnl-toggle-btn flex-shrink-0"
                                    data-shop-id="{{ shop.id }}"
                                    style="background:rgba(141,29,44,.08);color:#8D1D2C;border-radius:10px;padding:5px 9px;"
                                    aria-label="P&L"
                                    aria-expanded="false">
                                <span style="font-size:.9rem;">{{ icons.svg('bar-chart') }}</span>
                                <span class="ms-1 shop-toggle-chevron" style="font-size:.7rem;">{{ icons.svg('chevron-down') }}</span>
                            </button>
                        </div>

                        {# ── Synthèse magasin : CA du mois, tickets/jour, panier moyen ── #}
                        {% if shop.ca_month is defined %}
                        <div class="shop-synthese">
                            <div class="shop-kpi">
                                <span class="shop-kpi-val">{{ shop.ca_month|number_format(0, ',', ' ') }} €</span>
                                <span class="shop-kpi-lbl">{{ translations.ca_month ?? 'CA du mois' }}</span>
                            </div>
                            <div class="shop-kpi">
                                <span class="shop-kpi-val">{{ shop.tickets_per_day|round }}</span>
                                <span class="shop-kpi-lbl">{{ translations.tickets_per_day ?? 'tickets / jour' }}</span>
                            </div>
                            <div class="shop-kpi">
                                <span class="shop-kpi-val">{{ shop.avg_basket|number_format(2, ',', ' ') }} €</span>
                                <span class="shop-kpi-lbl">{{ translations.avg_basket ?? 'panier moyen' }}</span>
                            </div>
                            <div class="shop-kpi">
                                <span class="shop-kpi-val">{{ shop.products_per_client is not null ? shop.products_per_client|number_format(1, ',', ' ') : '—' }}</span>
                                <span class="shop-kpi-lbl">{{ translations.products_per_client ?? 'produits / client' }}</span>
                            </div>
                        </div>
                        {% endif %}
                    </div>

                    {# ── P&L Block (hidden by default) ── #}
                    <div class="pnl-card" id="pnl-{{ shop.id }}" data-shop-id="{{ shop.id }}" data-loaded="">

                        {# Period selector #}
                        <div class="pnl-period-bar">
                            <button class="pnl-badge active" data-period="day">{{ translations.period_today ?? "Aujourd'hui" }}</button>
                            <button class="pnl-badge" data-period="week">{{ translations.period_week ?? 'Semaine' }}</button>
                            <button class="pnl-badge" data-period="month">{{ translations.period_month ?? 'Mois' }}</button>
                            <button class="pnl-badge" data-period="compare">{{ translations.compare_tab ?? 'N vs N-1' }}</button>
                        </div>

                        {# ── Comparatif N vs N-1 (affiché par l'onglet dédié) ── #}
                        {% if shop.compare is defined and shop.compare %}
                        {% set cmp_labels = {
                            'ytd':  translations.compare_ytd ?? 'Année à date',
                            'mtd':  translations.compare_mtd ?? 'Mois à date',
                            'week': translations.period_week ?? 'Semaine',
                        } %}
                        <div class="pnl-compare" id="pnl-compare-{{ shop.id }}">
                            <table>
                                <thead>
                                    <tr>
                                        <th>{{ translations.compare_period ?? 'Période' }}</th>
                                        <th class="num">N-1</th>
                                        <th class="num">N</th>
                                        <th class="num">{{ translations.compare_gap ?? 'Écart' }}</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for row in shop.compare %}
                                    <tr>
                                        <td>{{ cmp_labels[row.key] ?? row.key }}</td>
                                        <td class="num">{{ row.n1 >= 100000 ? ((row.n1 / 1000)|number_format(0, ',', ' ') ~ ' k€') : (row.n1|number_format(0, ',', ' ') ~ ' €') }}</td>
                                        <td class="num">{{ row.n >= 100000 ? ((row.n / 1000)|number_format(0, ',', ' ') ~ ' k€') : (row.n|number_format(0, ',', ' ') ~ ' €') }}</td>
                                        <td class="num cmp-{{ row.status }}">{{ row.pct is not null ? ((row.pct >= 0 ? '+' : '') ~ row.pct|number_format(0, ',', ' ') ~ '%') : '—' }}</td>
                                        <td class="dotcell"><span class="cmp-dot cmp-dot-{{ row.status }}" aria-label="{{ row.status }}"></span></td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                        {% endif %}

                        {# Skeleton (shown while loading) #}
                        <div class="pnl-skeleton" id="pnl-skel-{{ shop.id }}">
                            <div class="pnl-skel-line" style="width:80%;"></div>
                            <div class="pnl-skel-line" style="width:65%;"></div>
                            <div class="pnl-skel-line" style="width:72%;"></div>
                            <div class="pnl-skel-line" style="width:60%;"></div>
                        </div>

                        {# Data area (filled by JS) #}
                        <div class="pnl-rows" id="pnl-data-{{ shop.id }}" style="display:none;"></div>

                    </div>
                </div>
            {% endfor %}
        </div>

        {# ── Comparaison structure : tableau croisé catégories × magasins ──
             Vue « écart vs moyenne réseau » (± points) ; montant € au tap
             sur une cellule. Données : mêmes P&L que les cartes ci-dessus. #}
        <div class="cmp-struct-wrap">
            <button class="cmp-struct-btn" id="cmpStructBtn" aria-expanded="false">
                <span style="font-size:1rem;">⇄</span>
                <span>{{ translations.cmp_structure ?? 'Comparaison structure' }}</span>
                <span class="cmp-struct-chev">{{ icons.svg('chevron-down') }}</span>
            </button>
            <div class="cmp-struct-panel" id="cmpStructPanel" style="display:none;">
                <div class="pnl-period-bar" id="cmpPeriodBar">
                    <button class="pnl-badge active" data-period="day">{{ translations.period_today ?? "Aujourd'hui" }}</button>
                    <button class="pnl-badge" data-period="week">{{ translations.period_week ?? 'Semaine' }}</button>
                    <button class="pnl-badge" data-period="month">{{ translations.period_month ?? 'Mois' }}</button>
                </div>
                <div class="cmp-sub">{{ translations.cmp_structure_sub ?? 'Poids de chaque catégorie dans le CA (%) · écart vs la moyenne réseau en points' }}</div>
                <div class="cmp-detail" id="cmpDetail"></div>
                <div class="pnl-skeleton" id="cmpSkel" style="display:none;">
                    <div class="pnl-skel-line" style="width:80%;"></div>
                    <div class="pnl-skel-line" style="width:65%;"></div>
                    <div class="pnl-skel-line" style="width:72%;"></div>
                </div>
                <div class="cmp-scroll"><table class="cmp-table" id="cmpTable"></table></div>
                <div class="cmp-legend">
                    <span><i style="background:#fdeaea;border:1px solid #f5c6cb;"></i>{{ translations.cmp_zero ?? '0 % — ne se vend pas' }}</span>
                    <span><i style="background:#fdf3e6;border:1px solid #f0ddc0;"></i>{{ translations.cmp_low ?? 'nettement sous la moyenne réseau' }}</span>
                </div>
            </div>
        </div>
    {% endif %}

</div>
{% endblock %}

{% block scripts %}
<script>
const I18N = {
    turnover:  {{ (translations.turnover ?? 'TurnOver')|json_encode|raw }},
    food:      {{ (translations.food_cost ?? 'Food Cost')|json_encode|raw }},
    gross:     {{ (translations.gross_margin ?? 'Marge brute')|json_encode|raw }},
    labour:    {{ (translations.labour_cost ?? 'Labour Cost')|json_encode|raw }},
    overhead:  {{ (translations.overhead ?? 'Overhead Cost (OC)')|json_encode|raw }},
    result:    {{ (translations.result ?? 'Result')|json_encode|raw }},
    noData:    {{ (translations.no_data ?? 'Aucune donnée')|json_encode|raw }},
    loadError: {{ (translations.load_error ?? 'Erreur de chargement')|json_encode|raw }},
    caShare:   {{ (translations.ca_share ?? 'du CA')|json_encode|raw }},
    marginLabel: {{ (translations.margin_label ?? 'marge')|json_encode|raw }},
    loss:      {{ (translations.loss ?? 'Perte')|json_encode|raw }},
    tmLegendDelta:  {{ (translations.tm_legend_delta ?? 'Surface : poids dans le CA · Couleur : évolution vs N-1')|json_encode|raw }},
    tmLegendMargin: {{ (translations.tm_legend_margin ?? 'Surface : poids dans le CA · Couleur : niveau de marge')|json_encode|raw }},
    cmpCategory:  {{ (translations.cmp_category ?? 'Catégorie')|json_encode|raw }},
    cmpNetwork:   {{ (translations.cmp_network ?? 'Réseau')|json_encode|raw }},
    cmpVsNetwork: {{ (translations.cmp_vs_network ?? 'vs réseau')|json_encode|raw }}
};
// Magasins de la page (pour la comparaison de structure).
const CMP_SHOPS = [{% for s in shops %}{ id: {{ s.id }}, name: {{ (s.representative_name ?? s.name)|json_encode|raw }} }{{ loop.last ? '' : ',' }}{% endfor %}];
(function () {
    'use strict';

    const ROOT = window.__consultantRoot || '';

    // ── FORMAT HELPERS ──────────────────────────────────────────────────────

    function fmt(val) {
        if (val == null) return '—';
        return new Intl.NumberFormat('fr-BE', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(val) + ' €';
    }

    function fmtDelta(delta) {
        if (delta == null) return { text: '—', cls: 'neu' };
        const sign = delta > 0 ? '+' : '';
        const cls  = delta > 0 ? 'pos' : (delta < 0 ? 'neg' : 'neu');
        return { text: sign + delta.toFixed(1).replace('.', ',') + '%', cls };
    }

    // Couleur de la ligne Result selon la marge (Result en % du TurnOver) :
    // perte → rouge sang · 0–5 % → rouge · 5–10 % → orange ·
    // 10–15 % → vert orangé · 15–25 % → vert · > 25 % → gold.
    function resultColor(r, t) {
        if (r < 0) return '#8B0000';
        const p = t > 0 ? (r / t) * 100 : 0;
        if (p <= 5)  return '#dc3545';
        if (p <= 10) return '#e67e22';
        if (p <= 15) return '#8FA31E';
        if (p <= 25) return '#27ae60';
        return '#C9A227';
    }

    // ── RENDER ──────────────────────────────────────────────────────────────

    function renderPnl(shopId, data) {
        const container = document.getElementById('pnl-data-' + shopId);
        if (!container) return;

        const rows = [];

        // Compte de résultat simplifié — tous les postes dérivés des 4 champs API
        // (turnover, labour, overhead [proratisé], result). Identité validée :
        //   Result = TurnOver − Food − Labour − Overhead
        //   ⇒ Food = TurnOver − Labour − Overhead − Result
        //   ⇒ Marge brute = TurnOver − Food
        const T    = Number(data.turnover && data.turnover.value) || 0;
        const L    = Number(data.labour   && data.labour.value)   || 0;
        const OC   = Number(data.overhead && data.overhead.value) || 0; // déjà proratisé (semaine/jour)
        const Rapi = Number(data.result   && data.result.value)   || 0;
        // Food Cost RÉEL : coût matière (tables recipe_cost) lu sur
        // /shops/{id}/statistics/daily-summary pour la même fenêtre que le P&L
        // (injecté dans data.food_cost par loadFoodCost). Le result de l'API
        // vaut T − labour − overhead (sans matière) → on le recalcule avec le
        // food réel. Repli : food dérivé de l'identité (≈ 0 tant que l'API ne
        // renvoie rien).
        const FC   = (data.food_cost != null && isFinite(data.food_cost) && Number(data.food_cost) > 0)
            ? Number(data.food_cost) : null;
        const food  = FC != null ? FC : (T - L - OC - Rapi);
        const gross = T - food;        // Marge brute
        const R     = FC != null ? (T - FC - L - OC) : Rapi;

        // % par rapport au TurnOver de la même période/magasin, arrondi à l'entier.
        const pct = (x) => (T > 0 ? Math.round((x / T) * 100) + '%' : '—');

        // 1. TurnOver — sans % (toujours 100%). Reste dépliable (catégories).
        rows.push(`
            <div class="pnl-row is-expandable" id="pnl-to-row-${shopId}">
                <span class="pnl-row-label"><i class="bi bi-chevron-right"></i>${I18N.turnover}</span>
                <span class="pnl-row-value">${fmt(T)}</span>
                <span class="pnl-row-pct"></span>
            </div>
            <div class="pnl-categories" id="pnl-cats-${shopId}">
                <div class="pnl-treemap" id="pnl-tm-${shopId}"></div>
                <div class="tm-detail" id="pnl-tmd-${shopId}"></div>
                <div class="tm-scale" id="pnl-tms-${shopId}"></div>
                <div class="tm-legend" id="pnl-tml-${shopId}"></div>
            </div>
        `);
        // Données du treemap, construit au premier dépliage (le conteneur doit
        // être visible pour connaître sa largeur). from/to = fenêtre du P&L,
        // utilisée pour charger les coûts matière par catégorie.
        _tmData[shopId] = {
            cats: (data.turnover && data.turnover.categories) || [],
            total: T,
            from: data.date_from ? String(data.date_from).slice(0, 10) : null,
            to:   data.date_to   ? String(data.date_to).slice(0, 10)   : null,
            costs: null,
        };

        // 2. Food Cost + 3. Marge brute
        {
            rows.push(`
                <div class="pnl-row">
                    <span class="pnl-row-label"><span class="pnl-lever pnl-lever-food">${I18N.food}</span></span>
                    <span class="pnl-row-value">${fmt(food)}</span>
                    <span class="pnl-row-pct">${pct(food)}</span>
                </div>
                <div class="pnl-row pnl-row-sub">
                    <span class="pnl-row-label">${I18N.gross}</span>
                    <span class="pnl-row-value">${fmt(gross)}</span>
                    <span class="pnl-row-pct">${pct(gross)}</span>
                </div>
            `);
        }

        // 4. Labour Cost
        rows.push(`
            <div class="pnl-row">
                <span class="pnl-row-label"><span class="pnl-lever pnl-lever-labour">${I18N.labour}</span></span>
                <span class="pnl-row-value">${fmt(L)}</span>
                <span class="pnl-row-pct">${pct(L)}</span>
            </div>
        `);

        // 5. Overhead Cost (OC)
        rows.push(`
            <div class="pnl-row">
                <span class="pnl-row-label"><span class="pnl-lever pnl-lever-oc">${I18N.overhead}</span></span>
                <span class="pnl-row-value">${fmt(OC)}</span>
                <span class="pnl-row-pct">${pct(OC)}</span>
            </div>
        `);

        // 6. Result (= Marge brute − Labour − Overhead) — couleur selon la
        // marge en % du TurnOver (voir resultColor).
        const resultStyle = `style="color:${resultColor(R, T)};"`;
        rows.push(`
            <div class="pnl-row result-row" ${resultStyle}>
                <span class="pnl-row-label" ${resultStyle}>${I18N.result}</span>
                <span class="pnl-row-value" ${resultStyle}>${fmt(R)}</span>
                <span class="pnl-row-pct" ${resultStyle}>${pct(R)}</span>
            </div>
        `);

        container.innerHTML = rows.join('');

        // Bind TurnOver expand
        const toRow = document.getElementById('pnl-to-row-' + shopId);
        const cats  = document.getElementById('pnl-cats-' + shopId);
        if (toRow && cats) {
            toRow.addEventListener('click', () => {
                const open = cats.classList.toggle('is-open');
                toRow.classList.toggle('expanded', open);
                if (open && !cats.dataset.built) {
                    cats.dataset.built = '1';
                    buildTreemap(shopId);
                }
            });
        }
    }

    // ── TREEMAP CATÉGORIES ─────────────────────────────────────────────────
    // Surface ∝ poids de la catégorie dans le CA. Couleur : niveau de marge
    // quand le coefficient food cost de la catégorie est connu (FOOD_COEF),
    // sinon évolution vs N-1 (delta API). Textes progressifs selon la taille
    // de la tuile : nom + CA + part + delta → nom + part → part seule
    // (info complète dans le title / appui long).
    const _tmData = {};

    // Coefficients food cost par catégorie (part matière du CA, ex. 0.24).
    // Clé = fragment de nom en minuscules. À remplir dès réception des
    // coefficients ; le treemap bascule alors en couleurs « marge ».
    const FOOD_COEF = {};

    function foodCoefOf(name) {
        const n = String(name || '').toLowerCase();
        for (const k in FOOD_COEF) {
            if (Object.prototype.hasOwnProperty.call(FOOD_COEF, k) && n.indexOf(k) !== -1) return FOOD_COEF[k];
        }
        return null;
    }

    // Marge réelle de la catégorie (% du CA) : d'abord les coûts matière par
    // catégorie chargés depuis l'API (costs = {nom → {sales, cost}}), sinon
    // le coefficient FOOD_COEF, sinon null (→ couleur par delta N-1).
    function marginPctFor(name, costs) {
        const n = String(name || '').toLowerCase().trim();
        if (costs && n !== '') {
            let e = costs[n];
            if (!e) {
                for (const k in costs) {
                    if (k !== '' && (k.indexOf(n) !== -1 || n.indexOf(k) !== -1)) { e = costs[k]; break; }
                }
            }
            if (e && e.sales > 0 && e.cost >= 0) return (1 - e.cost / e.sales) * 100;
        }
        const coef = foodCoefOf(name);
        return coef != null ? (1 - coef) * 100 : null;
    }

    // Marge de la catégorie (CA − food cost, en % du CA) → couleur.
    // Barème validé : perte → rouge sang · 0–40 % → rouge · 40–50 % → orange ·
    // 50–60 % → vert orangé · 60–70 % → vert · > 70 % → gold.
    function marginColor(mPct) {
        if (mPct < 0)  return '#8B0000';
        if (mPct < 40) return '#dc3545';
        if (mPct < 50) return '#e67e22';
        if (mPct < 60) return '#8FA31E';
        if (mPct < 70) return '#27ae60';
        return '#C9A227';
    }

    // Évolution vs N-1 → couleur (repli tant que la marge/catégorie manque).
    function deltaColor(delta) {
        if (delta == null || !isFinite(delta)) return '#9BA1A6';
        if (delta >= 5)  return '#27ae60';
        if (delta >= 0)  return '#8FA31E';
        if (delta >= -5) return '#e67e22';
        return '#C96A6A';
    }

    // Treemap « squarified » (Bruls et al.) : découpe W×H en rectangles
    // d'aires ∝ values, au ratio le plus proche du carré possible.
    // Retourne [{x,y,w,h}] dans l'ordre des values (triées au préalable).
    function squarify(values, W, H) {
        const total = values.reduce((a, b) => a + b, 0);
        if (total <= 0 || W <= 0 || H <= 0) return [];
        const areas = values.map(v => (v / total) * W * H);
        const rects = [];
        let x = 0, y = 0, w = W, h = H, row = [];

        const sum = r => r.reduce((a, b) => a + b, 0);
        function worst(r, side) {
            const s = sum(r), mx = Math.max.apply(null, r), mn = Math.min.apply(null, r);
            return Math.max((side * side * mx) / (s * s), (s * s) / (side * side * mn));
        }
        function layoutRow(r) {
            const s = sum(r);
            if (w >= h) {          // colonne posée sur le bord gauche
                const cw = s / h; let cy = y;
                r.forEach(a => { rects.push({ x: x, y: cy, w: cw, h: a / cw }); cy += a / cw; });
                x += cw; w -= cw;
            } else {               // rangée posée sur le bord haut
                const ch = s / w; let cx = x;
                r.forEach(a => { rects.push({ x: cx, y: y, w: a / ch, h: ch }); cx += a / ch; });
                y += ch; h -= ch;
            }
        }
        areas.forEach(a => {
            const side = Math.min(w, h);
            if (!row.length || worst(row.concat([a]), side) <= worst(row, side)) row.push(a);
            else { layoutRow(row); row = [a]; }
        });
        if (row.length) layoutRow(row);
        return rects;
    }

    function categoryCell(cat, r, total, costs) {
        const v = Number(cat.value) || 0;
        const sharePct = total > 0 ? Math.round((v / total) * 100) : 0;
        const delta = (cat.delta != null && isFinite(cat.delta)) ? Number(cat.delta) : null;
        const m = marginPctFor(cat.name, costs);   // marge % réelle ou coefficient, sinon null
        const color = m != null ? marginColor(m) : deltaColor(delta);
        const dTxt = fmtDelta(delta).text;
        const area = r.w * r.h;

        let inner;
        if (area >= 11000 && r.w >= 96) {
            // Grande tuile : hiérarchie complète.
            inner = `
                <div class="tm-name">${escHtml(cat.name)}</div>
                <div class="tm-val">${fmt(v)}</div>
                <div class="tm-share">${sharePct} % ${escHtml(I18N.caShare)}</div>
                ${m != null
                    ? `<div class="tm-fc">FC ${Math.round(100 - m)} %</div>`
                    : (delta != null ? `<span class="tm-chip">${dTxt} vs N-1</span>` : '')}`;
        } else if (area >= 4200 && r.w >= 64) {
            inner = `<div class="tm-name">${escHtml(cat.name)}</div><div class="tm-share">${sharePct} %</div>`;
        } else {
            inner = `<div class="tm-mini">${sharePct} %</div>`;
        }

        const pad = area >= 4200 ? 8 : 3;
        const title = `${cat.name} — ${fmt(v)} (${sharePct} %)` + (delta != null ? ` · ${dTxt} vs N-1` : '');
        return `<div class="tm-cell" title="${escHtml(title)}" style="left:${(r.x + 1).toFixed(1)}px;top:${(r.y + 1).toFixed(1)}px;width:${Math.max(0, r.w - 2).toFixed(1)}px;height:${Math.max(0, r.h - 2).toFixed(1)}px;background:${color};padding:${pad}px;">${inner}</div>`;
    }

    function renderTreemapInto(host, legendEl, cats, total, detailEl, scaleEl, costs) {
        const items = (cats || [])
            .map(c => Object.assign({}, c, { value: Number(c.value) || 0 }))
            .filter(c => c.value > 0)
            .sort((a, b) => b.value - a.value);
        if (detailEl) { detailEl.classList.remove('show'); detailEl.textContent = ''; }
        if (!items.length) {
            host.innerHTML = `<div class="pnl-cat-empty">${I18N.noData}</div>`;
            if (legendEl) legendEl.textContent = '';
            if (scaleEl) scaleEl.innerHTML = '';
            return;
        }
        const W = host.clientWidth || 300;
        const H = Math.min(300, Math.max(190, Math.round(W * 0.72)));
        host.style.height = H + 'px';
        const rects = squarify(items.map(c => c.value), W, H);
        host.innerHTML = items.map((c, i) => categoryCell(c, rects[i], total, costs)).join('');

        const marginMode = items.some(c => marginPctFor(c.name, costs) != null);
        if (legendEl) legendEl.textContent = marginMode ? I18N.tmLegendMargin : I18N.tmLegendDelta;
        // Mini-légende des couleurs, visible seulement treemap ouvert, au-dessus
        // de la ligne « Surface … » — barème du mode actif (marge ou delta N-1).
        if (scaleEl) {
            const sw = (color, label) => `<span><i style="background:${color};"></i>${label}</span>`;
            scaleEl.innerHTML = marginMode
                ? sw('#8B0000', I18N.loss) + sw('#dc3545', '0–40') + sw('#e67e22', '40–50')
                    + sw('#8FA31E', '50–60') + sw('#27ae60', '60–70') + sw('#C9A227', '&gt; 70 %')
                : sw('#C96A6A', '&lt; −5') + sw('#e67e22', '−5–0') + sw('#8FA31E', '0–5')
                    + sw('#27ae60', '&gt; +5 %') + sw('#9BA1A6', 'n/a');
        }

        // Tap sur une tuile → bandeau de détail sous le treemap (nom complet,
        // CA, part, delta). Indispensable pour les catégories < 1 % dont la
        // tuile est trop petite pour porter un texte. Re-tap → referme.
        if (detailEl) {
            const cells = host.querySelectorAll('.tm-cell');
            cells.forEach((cell, i) => {
                cell.addEventListener('click', () => {
                    const wasSel = cell.classList.contains('sel');
                    cells.forEach(c => c.classList.remove('sel'));
                    if (wasSel) { detailEl.classList.remove('show'); return; }
                    cell.classList.add('sel');
                    const c = items[i];
                    const share = total > 0 ? Math.round((c.value / total) * 1000) / 10 : 0;
                    const delta = (c.delta != null && isFinite(c.delta)) ? Number(c.delta) : null;
                    // La marge brute n'apparaît nulle part en texte : elle ne
                    // sert qu'à la couleur conditionnelle des tuiles. Le détail
                    // affiche le food cost, seul chiffre de coût montré.
                    const m = marginPctFor(c.name, costs);
                    detailEl.textContent = c.name + ' — ' + fmt(c.value) + ' · ' + String(share).replace('.', ',') + ' % ' + I18N.caShare
                        + (m != null ? ' · FC ' + Math.round(100 - m) + ' %' : '')
                        + (delta != null ? ' · ' + fmtDelta(delta).text.replace('.', ',') + ' vs N-1' : '');
                    detailEl.classList.add('show');
                });
            });
        }
    }

    function buildTreemap(shopId) {
        const host = document.getElementById('pnl-tm-' + shopId);
        const legendEl = document.getElementById('pnl-tml-' + shopId);
        const detailEl = document.getElementById('pnl-tmd-' + shopId);
        const scaleEl = document.getElementById('pnl-tms-' + shopId);
        const d = _tmData[shopId];
        if (!host || !d) return;
        const render = () => renderTreemapInto(host, legendEl, d.cats, d.total, detailEl, scaleEl, d.costs);
        render();
        // Coûts matière par catégorie chargés en arrière-plan : dès qu'ils
        // arrivent, le treemap se reconstruit en couleurs « marge ».
        if (!d.costs) fetchCatCosts(shopId, () => { if (d.costs) render(); });
    }

    // ── COÛT MATIÈRE PAR CATÉGORIE ─────────────────────────────────────────
    // Source : GET /shops/{id}/statistics/sales/product-category-groups
    //          ?date_from&date_to&grouping (StatisticsRepository::
    //          getSalesSplittedByGroupAndCategory) sur la fenêtre du P&L.
    // Le schéma exact et la valeur attendue de `grouping` n'étant pas encore
    // observés côté front, on tente plusieurs groupings et on extrait de
    // façon tolérante, par entrée nommée : un montant de ventes et un coût
    // (clés *cost*), sommés par nom de catégorie. Échec → repli silencieux
    // (couleurs par delta N-1), réponse loggée en console pour ajustement.
    const _catCostCache = {};

    function extractCategoryCosts(node) {
        const map = {};
        let foundCost = false;
        const numOf = v => (typeof v === 'number') ? v
            : (typeof v === 'string' && v !== '' && isFinite(v)) ? Number(v)
            : (v && typeof v === 'object' && typeof v.value === 'number') ? v.value : null;
        const SALES_PREFS = ['turnover', 'sales', 'revenue', 'gross', 'value', 'amount', 'total', 'net'];

        (function walk(n) {
            if (Array.isArray(n)) { n.forEach(walk); return; }
            if (!n || typeof n !== 'object') return;

            let name = null;
            ['category_name', 'category', 'group_name', 'name', 'label'].some(k => {
                if (typeof n[k] === 'string' && n[k].trim() !== '') { name = n[k].trim(); return true; }
                return false;
            });

            if (name) {
                // UNE seule valeur de coût par entrée (jamais de somme : les
                // réponses portent souvent plusieurs champs coût redondants —
                // material_cost, total_cost… — dont l'addition double le FC).
                // Noms exacts par priorité, puis première clé *cost* en repli.
                const COST_PREFS = ['material_cost', 'materials_cost', 'food_cost', 'goods_cost', 'cost_of_goods', 'purchase_cost', 'total_cost', 'cost'];
                const skip = k => /(pct|percent|ratio|rate|delta|margin|qty|quantity|count)/i.test(k);
                let cost = null, sales = null;
                for (let p = 0; p < COST_PREFS.length && cost == null; p++) {
                    for (const k in n) {
                        if (skip(k)) continue;
                        if (k.toLowerCase() === COST_PREFS[p]) { const x = numOf(n[k]); if (x != null) cost = x; break; }
                    }
                }
                if (cost == null) {
                    for (const k in n) {
                        if (skip(k)) continue;
                        if (/cost/i.test(k)) { const x = numOf(n[k]); if (x != null) { cost = x; break; } }
                    }
                }
                const hasCost = cost != null;
                for (let p = 0; p < SALES_PREFS.length && sales == null; p++) {
                    for (const k in n) {
                        if (/cost|pct|percent|ratio|rate|delta|margin|qty|quantity|count/i.test(k)) continue;
                        if (k.toLowerCase().indexOf(SALES_PREFS[p]) !== -1) {
                            const x = numOf(n[k]);
                            if (x != null) { sales = x; break; }
                        }
                    }
                }
                if (hasCost) {
                    const key = name.toLowerCase();
                    const e = map[key] || (map[key] = { sales: 0, cost: 0 });
                    e.cost += cost;
                    if (sales != null) e.sales += sales;
                    foundCost = true;
                }
            }
            for (const k in n) {
                if (Object.prototype.hasOwnProperty.call(n, k) && n[k] && typeof n[k] === 'object') walk(n[k]);
            }
        })(node);
        return foundCost ? map : null;
    }

    // Ventilation ventes/coût matière par catégorie sur une fenêtre ARBITRAIRE
    // — source commune du treemap ET du Food Cost du P&L (jour, semaine, mois) :
    // même agrégation partout, donc plus de divergence entre les périodes.
    function fetchCategoryCosts(shopId, from, to, done) {
        const cacheKey = shopId + '|' + from + '|' + to;
        if (cacheKey in _catCostCache) { done(_catCostCache[cacheKey]); return; }

        const groupings = ['category', 'group', 'month'];
        (function attempt(i) {
            if (i >= groupings.length) { _catCostCache[cacheKey] = null; done(null); return; }
            ConsultantAjax.load({
                endpoint: '/shops/' + shopId + '/statistics/sales/product-category-groups',
                params: { date_from: from, date_to: to, grouping: groupings[i] },
                onSuccess: (resp) => {
                    const costs = extractCategoryCosts(resp);
                    if (costs) {
                        // Table de contrôle : permet de comparer les valeurs
                        // extraites aux chiffres connus (ex. Halle/Viennoiserie
                        // 523,20 € / 219,83 € → marge 58 %).
                        try {
                            const dbg = {};
                            for (const k in costs) {
                                dbg[k] = {
                                    ventes: Math.round(costs[k].sales * 100) / 100,
                                    cout: Math.round(costs[k].cost * 100) / 100,
                                    marge: costs[k].sales > 0 ? (Math.round((1 - costs[k].cost / costs[k].sales) * 1000) / 10) + ' %' : 'n/a',
                                };
                            }
                            console.info('[pnl] marges par catégorie — magasin ' + shopId + ' (' + from + ' → ' + to + ')', dbg);
                        } catch (e) { /* debug uniquement */ }
                        _catCostCache[cacheKey] = costs; done(costs);
                    }
                    else {
                        console.warn('[pnl] product-category-groups (grouping=' + groupings[i] + ') sans coûts détectables', shopId, resp);
                        attempt(i + 1);
                    }
                },
                onError: (msg) => {
                    console.warn('[pnl] product-category-groups (grouping=' + groupings[i] + ') en erreur', shopId, msg);
                    attempt(i + 1);
                },
            });
        })(0);
    }

    function fetchCatCosts(shopId, done) {
        const d = _tmData[shopId];
        if (!d || !d.from || !d.to) { done(); return; }
        fetchCategoryCosts(shopId, d.from, d.to, (costs) => {
            if (costs) d.costs = costs;
            done();
        });
    }

    function escHtml(str) {
        return String(str)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
    }

    function showError(shopId, msg) {
        const skel = document.getElementById('pnl-skel-' + shopId);
        if (skel) {
            skel.innerHTML = `<div style="color:#c0392b;font-size:.78rem;text-align:center;padding:8px 0;">
                <i class="bi bi-exclamation-triangle-fill"></i> ${I18N.loadError}<br>
                <small style="opacity:.7;">${escHtml(msg)}</small>
            </div>`;
        }
    }

    // ── OVERHEAD (frais généraux) — proratisation semaine/jour ───────────────
    // Les frais généraux sont saisis au MOIS. Le backend ne les renvoie que
    // pour la vue mensuelle ; en semaine/jour ils arrivent à 0. On récupère le
    // montant mensuel et on le proratise :
    //   • semaine → mensuel / 4,3
    //   • jour    → mensuel / (nombre de jours du mois courant)
    // Puis on recalcule le Result (marge) avec cette valeur.
    const WEEKS_PER_MONTH = 4.3;
    const _monthlyOcCache = {};

    function daysInCurrentMonth() {
        const d = new Date();
        return new Date(d.getFullYear(), d.getMonth() + 1, 0).getDate();
    }

    function overheadOf(data) {
        const oc = data && data.overhead;
        if (!oc) return null;
        if (oc.value != null) return Number(oc.value);
        if (oc.breakdown && oc.breakdown.month && oc.breakdown.month.value != null) {
            return Number(oc.breakdown.month.value);
        }
        return null;
    }

    // Applique la proratisation à `data` (mutée) pour period ∈ {day, week}.
    function prorateOverhead(period, data, monthlyOc) {
        if (monthlyOc == null || !isFinite(monthlyOc)) return;
        const divisor = period === 'week' ? WEEKS_PER_MONTH : daysInCurrentMonth();
        const prorated = monthlyOc / divisor;

        const prev = overheadOf(data) || 0;
        data.overhead = Object.assign({}, data.overhead, { value: prorated, delta: null });

        // Le Result n'incluait pas (ou peu) les frais généraux → on retire le
        // complément proratisé pour que la marge soit correcte.
        if (data.result && data.result.value != null) {
            data.result = Object.assign({}, data.result, {
                value: Number(data.result.value) - (prorated - prev),
            });
        }
    }

    // ── FOOD COST (coût matière) ────────────────────────────────────────────
    // Source : GET /shops/{id}/statistics/daily-summary sur la fenêtre exacte
    // du P&L (date_from/date_to). Côté backend :
    // TransactionRepository::getMaterialCostInDataRange (tables recipe_cost /
    // recipe_cost_archive). Le schéma exact de la réponse pouvant varier, on
    // additionne récursivement les clés « coût matière » (material/food +
    // cost/value/amount), en excluant pourcentages et deltas. Échec ou zéro →
    // le P&L garde son affichage dérivé actuel.
    const _foodCache = {};

    function extractMaterialCost(node) {
        // UNE SEULE clé de coût est retenue (material_cost prioritaire) puis
        // sommée sur les buckets (jours) : additionner des clés redondantes
        // (material_cost + total_cost…) doublerait le food cost — même bug
        // que le FC à 84 % corrigé sur les catégories.
        const SKIP = /(pct|percent|ratio|rate|delta|margin)/i;
        const numOf = v => (typeof v === 'number') ? v
            : (typeof v === 'string' && v !== '' && isFinite(v)) ? Number(v)
            : (v && typeof v === 'object' && typeof v.value === 'number') ? v.value : null;

        const names = [];
        (function collect(n) {
            if (Array.isArray(n)) { n.forEach(collect); return; }
            if (!n || typeof n !== 'object') return;
            for (const k in n) {
                if (/(material|food)/i.test(k) && /(cost|value|amount)/i.test(k) && !SKIP.test(k) && numOf(n[k]) != null) {
                    if (names.indexOf(k) === -1) names.push(k);
                }
                if (n[k] && typeof n[k] === 'object') collect(n[k]);
            }
        })(node);
        if (!names.length) return null;

        const PREFS = ['material_cost', 'materials_cost', 'food_cost', 'goods_cost', 'cost_of_goods'];
        let key = null;
        for (let p = 0; p < PREFS.length && !key; p++) {
            key = names.find(n2 => n2.toLowerCase() === PREFS[p]) || null;
        }
        if (!key) key = names[0];

        let sum = 0, found = false;
        (function walk(n) {
            if (Array.isArray(n)) { n.forEach(walk); return; }
            if (!n || typeof n !== 'object') return;
            for (const k in n) {
                if (k === key) {
                    const x = numOf(n[k]);
                    if (x != null) { sum += x; found = true; continue; }
                }
                if (n[k] && typeof n[k] === 'object') walk(n[k]);
            }
        })(node);
        return found ? sum : null;
    }

    // Récupère le coût matière de la fenêtre du P&L, l'injecte dans
    // pnlData.food_cost puis appelle done() — TOUJOURS, même en erreur.
    function loadFoodCost(shopId, period, pnlData, done) {
        const key = shopId + '|' + period;
        if (key in _foodCache) {
            if (_foodCache[key] != null) pnlData.food_cost = _foodCache[key];
            done(); return;
        }
        const from = pnlData && pnlData.date_from ? String(pnlData.date_from).slice(0, 10) : null;
        const to   = pnlData && pnlData.date_to   ? String(pnlData.date_to).slice(0, 10)   : null;
        if (!from || !to) { done(); return; }

        // SOURCE PRIMAIRE : product-category-groups sur la fenêtre exacte du
        // P&L — le food cost de la période = SOMME des coûts matière de
        // toutes les catégories. Cette agrégation par fenêtre est VALIDÉE
        // (FC 42 % Viennoiserie) et identique pour jour, semaine et mois :
        // le FC de la semaine = somme de ses jours, par construction.
        // (daily-summary, pensé pour une journée, divergeait sur les plages.)
        fetchCategoryCosts(shopId, from, to, (costs) => {
            if (costs) {
                let total = 0;
                for (const k in costs) total += Number(costs[k].cost) || 0;
                if (total > 0) {
                    _foodCache[key] = total;
                    pnlData.food_cost = total;
                    console.info('[pnl] food cost ' + period + ' (' + from + ' → ' + to + ') = ' + (Math.round(total * 100) / 100) + ' € (somme des catégories)');
                    done(); return;
                }
            }
            // REPLI : daily-summary (extraction mono-clé).
            ConsultantAjax.load({
                endpoint: '/shops/' + shopId + '/statistics/daily-summary',
                params: { date_from: from, date_to: to, from: from, to: to },
                onSuccess: (resp) => {
                    const cost = extractMaterialCost(resp);
                    _foodCache[key] = cost;
                    if (cost != null && cost > 0) pnlData.food_cost = cost;
                    else console.warn('[pnl] aucun coût matière détectable (catégories + daily-summary)', shopId, period, resp);
                    done();
                },
                onError: (msg) => {
                    console.warn('[pnl] daily-summary indisponible', shopId, period, msg);
                    done();
                },
            });
        });
    }

    // ── LOAD DATA ───────────────────────────────────────────────────────────

    function loadPnl(shopId, period, dateFrom, dateTo) {
        const skel = document.getElementById('pnl-skel-' + shopId);
        const data = document.getElementById('pnl-data-' + shopId);

        if (skel) skel.style.display = '';
        if (data) data.style.display = 'none';

        const params = { period };

        const finish = (responseData) => {
            // Le vrai food cost (coût matière) est chargé sur la même fenêtre
            // que le P&L avant le rendu ; en cas d'échec on rend sans lui.
            loadFoodCost(shopId, period, responseData, () => {
                if (skel) skel.style.display = 'none';
                if (data) data.style.display = '';
                renderPnl(shopId, responseData);
            });
        };

        ConsultantAjax.load({
            endpoint: '/consultant/shops/' + shopId + '/pnl',
            params,
            onSuccess: (responseData) => {
                // Vues mois/custom : inchangées.
                if (period !== 'week' && period !== 'day') { finish(responseData); return; }

                // Overhead mensuel déjà connu → proratise tout de suite.
                if (_monthlyOcCache[shopId] != null) {
                    prorateOverhead(period, responseData, _monthlyOcCache[shopId]);
                    finish(responseData);
                    return;
                }

                // Sinon on va chercher le montant mensuel une fois, puis on met en cache.
                ConsultantAjax.load({
                    endpoint: '/consultant/shops/' + shopId + '/pnl',
                    params: { period: 'month' },
                    onSuccess: (monthData) => {
                        const monthlyOc = overheadOf(monthData);
                        if (monthlyOc != null) _monthlyOcCache[shopId] = monthlyOc;
                        prorateOverhead(period, responseData, monthlyOc);
                        finish(responseData);
                    },
                    onError: () => { finish(responseData); }, // repli : affichage brut
                });
            },
            onError: (msg) => {
                showError(shopId, msg);
            },
        });
    }

    // ── TOGGLE & PERIOD ─────────────────────────────────────────────────────

    document.querySelectorAll('.pnl-toggle-btn').forEach(btn => {
        btn.addEventListener('click', function () {
            const shopId   = this.dataset.shopId;
            const pnlCard  = document.getElementById('pnl-' + shopId);
            const isOpen   = pnlCard.classList.toggle('is-open');

            this.setAttribute('aria-expanded', isOpen);
            this.classList.toggle('open', isOpen);

            if (isOpen && !pnlCard.dataset.loaded) {
                pnlCard.dataset.loaded = 'day';
                loadPnl(shopId, 'day');
            }
        });
    });

    // Period badge switching — delegated to each pnl-card
    document.querySelectorAll('.pnl-card').forEach(card => {
        const shopId  = card.dataset.shopId;

        card.querySelectorAll('.pnl-badge').forEach(badge => {
            badge.addEventListener('click', function () {
                const period = this.dataset.period;

                // Update active badge
                card.querySelectorAll('.pnl-badge').forEach(b => b.classList.remove('active'));
                this.classList.add('active');

                // Onglet « N vs N-1 » : affiche le comparatif (déjà rendu côté
                // serveur), masque le P&L — aucune requête.
                const cmpPanel = document.getElementById('pnl-compare-' + shopId);
                const skelEl   = document.getElementById('pnl-skel-' + shopId);
                const dataEl   = document.getElementById('pnl-data-' + shopId);
                if (cmpPanel) cmpPanel.classList.toggle('is-open', period === 'compare');
                if (period === 'compare') {
                    if (skelEl) skelEl.style.display = 'none';
                    if (dataEl) dataEl.style.display = 'none';
                    return;
                }
                if (dataEl && card.dataset.loaded === period) { dataEl.style.display = ''; return; }

                card.dataset.loaded = period;
                loadPnl(shopId, period);
            });
        });

    });

    // ── COMPARAISON STRUCTURE ──────────────────────────────────────────────
    // Tableau croisé : catégories en lignes × magasins en colonnes. Chaque
    // cellule = poids de la catégorie dans le CA du magasin (%) + écart vs
    // la moyenne réseau en points. Tap sur une cellule → montant € dans le
    // bandeau détail. Source : les mêmes P&L que les cartes (une requête
    // par magasin, cache serveur), % calculés sur la somme des catégories
    // du magasin → chaque colonne totalise 100 %.
    (function () {
        const btn   = document.getElementById('cmpStructBtn');
        const panel = document.getElementById('cmpStructPanel');
        if (!btn || !panel || !CMP_SHOPS.length) return;
        const tableEl  = document.getElementById('cmpTable');
        const skelEl   = document.getElementById('cmpSkel');
        const detailEl = document.getElementById('cmpDetail');
        const barEl    = document.getElementById('cmpPeriodBar');

        const _cache = {};            // period → résultats pnl par magasin
        let curPeriod = 'day';

        const pct1 = p => (Math.round(p * 10) / 10).toFixed(1).replace(/\.0$/, '').replace('.', ',');
        const kOf  = n => String(n || '').trim().toLowerCase();

        btn.addEventListener('click', function () {
            const open = panel.style.display !== 'none';
            panel.style.display = open ? 'none' : '';
            btn.setAttribute('aria-expanded', open ? 'false' : 'true');
            if (!open && !_cache[curPeriod]) load(curPeriod);
        });

        barEl.querySelectorAll('.pnl-badge').forEach(badge => {
            badge.addEventListener('click', function () {
                barEl.querySelectorAll('.pnl-badge').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                curPeriod = this.dataset.period;
                detailEl.classList.remove('show');
                _cache[curPeriod] ? build(_cache[curPeriod]) : load(curPeriod);
            });
        });

        function load(period) {
            skelEl.style.display = '';
            tableEl.innerHTML = '';
            const results = {};
            let pending = CMP_SHOPS.length;
            CMP_SHOPS.forEach(s => {
                ConsultantAjax.load({
                    endpoint: '/consultant/shops/' + s.id + '/pnl',
                    params: { period: period },
                    onSuccess: d => { results[s.id] = d; if (--pending === 0) finish(period, results); },
                    onError:  () => { results[s.id] = null; if (--pending === 0) finish(period, results); },
                });
            });
        }

        function finish(period, results) {
            _cache[period] = results;
            skelEl.style.display = 'none';
            if (period === curPeriod) build(results);
        }

        function build(results) {
            // Par magasin : {clé catégorie → montant}, total = somme des
            // catégories (dénominateur des %, garantit un total de 100 %).
            const perShop = CMP_SHOPS.map(s => {
                const d = results[s.id];
                const cats = (d && d.turnover && d.turnover.categories) || [];
                const map = {}; let tot = 0;
                cats.forEach(c => {
                    const v = Number(c.value) || 0;
                    if (v < 0) return;
                    const k = kOf(c.name);
                    if (!k) return;
                    map[k] = (map[k] || 0) + v; tot += v;
                });
                return { shop: s, map: map, tot: tot };
            });

            // Union des catégories (nom d'affichage = premier rencontré),
            // triées par poids réseau décroissant.
            const disp = {};
            perShop.forEach(p => {
                Object.keys(p.map).forEach(k => { if (!(k in disp)) disp[k] = null; });
            });
            CMP_SHOPS.forEach(s => {
                const d = results[s.id];
                (((d || {}).turnover || {}).categories || []).forEach(c => {
                    const k = kOf(c.name);
                    if (k && disp[k] == null) disp[k] = String(c.name).trim();
                });
            });
            if (!perShop.some(p => p.tot > 0)) {
                detailEl.classList.remove('show');
                tableEl.innerHTML = '<tr><td class="cmp-empty">' + I18N.noData + '</td></tr>';
                return;
            }

            const rows = Object.keys(disp).map(k => {
                const pcts = perShop.map(p => p.tot > 0 ? ((p.map[k] || 0) / p.tot) * 100 : null);
                const have = pcts.filter(v => v != null);
                const avg = have.reduce((a, b) => a + b, 0) / have.length;
                return { key: k, name: disp[k], pcts: pcts, avg: avg };
            }).sort((a, b) => b.avg - a.avg);

            const cell = (row, i) => {
                const p = row.pcts[i];
                if (p == null) return '<td class="cmp-nd">—</td>';
                const v = perShop[i].map[row.key] || 0;
                const d = p - row.avg;
                let cls = '';
                if (p === 0) cls = 'cmp-zero';
                else if (row.avg > 0 && p < 0.65 * row.avg) cls = 'cmp-low';
                let dlt;
                if (p === 0) dlt = '<span class="cmp-dlt" style="color:#8B0000;">✕ 0</span>';
                else {
                    const col = d >= 1 ? '#27ae60' : (d <= -0.35 * row.avg ? '#8B0000' : (d < -1 ? '#e67e22' : '#7a7168'));
                    const arrow = d >= 1 ? '▲' : (d < -1 ? '▼' : '≈');
                    dlt = '<span class="cmp-dlt" style="color:' + col + ';">' + arrow + ' ' + (d > 0 ? '+' : '') + d.toFixed(1).replace('.', ',') + ' pt</span>';
                }
                return '<td class="' + cls + '" data-cat="' + escHtml(row.name) + '" data-shop="' + i + '" data-val="' + v + '" data-pct="' + p + '" data-dlt="' + d.toFixed(1) + '">'
                    + '<span class="cmp-pct">' + pct1(p) + ' %</span>' + dlt + '</td>';
            };

            tableEl.innerHTML =
                '<tr><th class="cmp-rowh">' + I18N.cmpCategory + '</th><th class="cmp-netcol">' + I18N.cmpNetwork + '</th>'
                + CMP_SHOPS.map(s => '<th>' + escHtml(shortName(s.name)) + '</th>').join('') + '</tr>'
                + rows.map(row =>
                    '<tr><td class="cmp-rowh">' + escHtml(row.name) + '</td>'
                    + '<td class="cmp-netcol" style="color:#7a7168;">' + pct1(row.avg) + ' %</td>'
                    + perShop.map((_, i) => cell(row, i)).join('') + '</tr>'
                ).join('');
        }

        // Nom court pour l'en-tête de colonne : dernier segment après « - »
        // (« Atelier by Berlo - Corbais » → « Corbais »).
        function shortName(n) {
            const parts = String(n || '').split(' - ');
            return (parts.length > 1 ? parts[parts.length - 1] : String(n || '')).trim();
        }

        // Tap sur une cellule → bandeau détail avec le montant €.
        tableEl.addEventListener('click', function (e) {
            const td = e.target.closest('td[data-cat]');
            if (!td) return;
            tableEl.querySelectorAll('td.sel').forEach(x => x.classList.remove('sel'));
            td.classList.add('sel');
            const shop = CMP_SHOPS[Number(td.dataset.shop)];
            const d = Number(td.dataset.dlt);
            const dTxt = (d > 0 ? '+' : '') + d.toFixed(1).replace('.', ',') + ' pt ' + I18N.cmpVsNetwork;
            detailEl.textContent = td.dataset.cat + ' — ' + shortName(shop.name) + ' · ' + fmt(Number(td.dataset.val))
                + ' · ' + pct1(Number(td.dataset.pct)) + ' % ' + I18N.caShare + ' · ' + dTxt;
            detailEl.classList.add('show');
        });
    })();

    // ── Ouverture directe depuis l'accueil ──────────────────────────────────
    // ?focus={id}&period=day&treemap=1 : scroll sur le magasin, P&L ouvert
    // sur la période demandée (défaut : AUJOURD'HUI), treemap des catégories
    // déplié dès que les données sont rendues. Exécuté APRÈS le binding des
    // toggles et badges (les clics simulés doivent avoir leurs handlers).
    (function () {
        const q = new URLSearchParams(window.location.search);
        const focusId = q.get('focus');
        if (!focusId) return;
        const period = ['day', 'week', 'month'].indexOf(q.get('period')) !== -1 ? q.get('period') : 'day';

        const toggle = document.querySelector('.pnl-toggle-btn[data-shop-id="' + focusId + '"]');
        if (!toggle) return;
        const shopCard = toggle.closest('.card');
        if (shopCard) {
            // Auto-focus : la carte glisse au CENTRE de l'écran, puis un halo
            // aux couleurs de la marque signale le magasin ciblé.
            setTimeout(() => {
                shopCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
                shopCard.classList.add('shop-focus-glow');
                shopCard.addEventListener('animationend', () => shopCard.classList.remove('shop-focus-glow'), { once: true });
            }, 80);
        }

        toggle.click();   // ouvre le P&L → charge la période « day » par défaut
        if (period !== 'day') {
            const badge = document.querySelector('#pnl-' + focusId + ' .pnl-badge[data-period="' + period + '"]');
            if (badge) badge.click();
        }

        if (q.get('treemap') === '1') {
            // Déplie le treemap dès que la ligne TurnOver est rendue (données
            // chargées) — le conteneur doit être visible pour que le treemap
            // mesure sa largeur.
            let tries = 0;
            const timer = setInterval(function () {
                const toRow = document.getElementById('pnl-to-row-' + focusId);
                if (toRow) {
                    clearInterval(timer);
                    const cats = document.getElementById('pnl-cats-' + focusId);
                    if (cats && !cats.classList.contains('is-open')) toRow.click();
                } else if (++tries > 60) {
                    clearInterval(timer);   // données jamais arrivées → abandon silencieux
                }
            }, 150);
        }
    })();

})();
</script>
{% endblock %}

