{% extends "layouts/mobile_base.twig" %}

{% block title %}{{ translations.dashboard ?? 'Panel główny' }} — {{ translations.consultant_panel ?? 'Consultant Panel' }}{% endblock %}

{% block page_title %}{{ translations.welcome_back ?? 'Witaj ponownie' }}{% endblock %}
{% block page_subtitle %}{{ translations.quick_overview_of_your_day ?? 'Szybki przegląd Twojego dnia' }}{% endblock %}

{% block topbar_actions %}
    <a href="{{ ROOT }}/logout" class="btn btn-sm btn-outline-secondary rounded-pill">
        <i class="bi bi-box-arrow-right"></i>
    </a>
{% endblock %}

{% block content %}
<div class="page-content-loaded">

    {# ── Nagłówek z datą ── #}
    <div class="d-flex align-items-center justify-content-between mb-3">
        <span class="fw-bold text-muted" style="font-size:.85rem;">
            <i class="bi bi-calendar3 me-1"></i> {{ date }}
        </span>
    </div>

    {# ── Karty sekcji (placeholder — dane ładowane iteracyjnie) ── #}
    <div class="row g-3">

        <div class="col-12">
            <a href="{{ ROOT }}/shops" class="text-decoration-none">
                <div class="card border-0 shadow-sm" style="border-radius:16px;">
                    <div class="card-body d-flex align-items-center gap-3 py-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                             style="width:44px;height:44px;background:rgba(67,94,190,.12);flex-shrink:0;">
                            <i class="bi bi-shop" style="font-size:1.2rem;color:#435ebe;"></i>
                        </div>
                        <div>
                            <div class="fw-700" style="font-size:.95rem;">{{ translations.shops ?? 'Sklepy' }}</div>
                            <div class="text-muted" style="font-size:.8rem;">Przychody i podsumowanie</div>
                        </div>
                        <i class="bi bi-chevron-right ms-auto text-muted"></i>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-12">
            <a href="{{ ROOT }}/reports" class="text-decoration-none">
                <div class="card border-0 shadow-sm" style="border-radius:16px;">
                    <div class="card-body d-flex align-items-center gap-3 py-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                             style="width:44px;height:44px;background:rgba(40,167,69,.12);flex-shrink:0;">
                            <i class="bi bi-file-earmark-pdf" style="font-size:1.2rem;color:#28a745;"></i>
                        </div>
                        <div>
                            <div class="fw-700" style="font-size:.95rem;">{{ translations.reports ?? 'Raporty' }}</div>
                            <div class="text-muted" style="font-size:.8rem;">Przesyłanie raportów PDF</div>
                        </div>
                        <i class="bi bi-chevron-right ms-auto text-muted"></i>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-12">
            <a href="{{ ROOT }}/helpdesk" class="text-decoration-none">
                <div class="card border-0 shadow-sm" style="border-radius:16px;">
                    <div class="card-body d-flex align-items-center gap-3 py-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                             style="width:44px;height:44px;background:rgba(255,193,7,.15);flex-shrink:0;">
                            <i class="bi bi-life-preserver" style="font-size:1.2rem;color:#ffc107;"></i>
                        </div>
                        <div>
                            <div class="fw-700" style="font-size:.95rem;">{{ translations.helpdesk ?? 'Zgłoszenia' }}</div>
                            <div class="text-muted" style="font-size:.8rem;">Zgłoszenia Helpdesk przypisane do Ciebie</div>
                        </div>
                        <i class="bi bi-chevron-right ms-auto text-muted"></i>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-12">
            <a href="{{ ROOT }}/claims" class="text-decoration-none">
                <div class="card border-0 shadow-sm" style="border-radius:16px;">
                    <div class="card-body d-flex align-items-center gap-3 py-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                             style="width:44px;height:44px;background:rgba(220,53,69,.12);flex-shrink:0;">
                            <i class="bi bi-exclamation-circle" style="font-size:1.2rem;color:#dc3545;"></i>
                        </div>
                        <div>
                            <div class="fw-700" style="font-size:.95rem;">{{ translations.claims ?? 'Reklamacje' }}</div>
                            <div class="text-muted" style="font-size:.8rem;">Reklamacje CENTRAL</div>
                        </div>
                        <i class="bi bi-chevron-right ms-auto text-muted"></i>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-12">
            <a href="{{ ROOT }}/shops" class="text-decoration-none">
                <div class="card border-0 shadow-sm" style="border-radius:16px;">
                    <div class="card-body d-flex align-items-center gap-3 py-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                             style="width:44px;height:44px;background:rgba(108,117,125,.12);flex-shrink:0;">
                            <i class="bi bi-journal-text" style="font-size:1.2rem;color:#6c757d;"></i>
                        </div>
                        <div>
                            <div class="fw-700" style="font-size:.95rem;">Notatki</div>
                            <div class="text-muted" style="font-size:.8rem;">Notatki i komentarze do placówek</div>
                        </div>
                        <i class="bi bi-chevron-right ms-auto text-muted"></i>
                    </div>
                </div>
            </a>
        </div>

    </div>

</div>
{% endblock %}

