{% extends "layouts/mobile_base.twig" %}
{% import "components/_icons.twig" as icons %}

{% block title %}Panel consultant — Consultant{% endblock %}

{% set jn = translations.day_names ?? ['dimanche','lundi','mardi','mercredi','jeudi','vendredi','samedi'] %}
{% set mn = translations.month_names ?? ['janvier','février','mars','avril','mai','juin','juillet','août','septembre','octobre','novembre','décembre'] %}
{% set frenchdate = (jn[date|date('w')]|capitalize) ~ ' ' ~ date|date('j') ~ ' ' ~ mn[date|date('n') - 1] ~ ' ' ~ date|date('Y') %}

{# ── Custom header: logo (left) · date (center) · menu (right) ── #}
{% block topbar %}
<div class="app-topbar">
    <div class="container">
        <div class="dash-head3">
            <img src="{{ ROOT }}/assets/brand/logo.png" alt="L'Atelier" class="dash-logo">
            <div class="dash-date3">{{ frenchdate }}</div>
            <button class="app-hamburger dash-menu-btn" id="appHamburger" aria-label="Menu" aria-expanded="false" aria-controls="appNavSheet">
                {{ icons.svg('menu', 24) }}
            </button>
        </div>
    </div>
</div>
{% endblock %}

{% block content %}
<div class="page-content-loaded dash">

    {# ── KPI grid ── #}
    <div class="dash-kpis">
        <div class="dash-kpi">
            <span class="dash-kpi-ic" style="--tint:141,29,44;color:#8D1D2C"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></span>
            <div class="dash-kpi-val">{{ kpis.ca_today ?? '—' }}</div>
            <div class="dash-kpi-lbl">{{ translations.kpi_ca_today ?? 'CA du jour' }}{% if kpis.ca_delta %} · <span style="color:{{ kpis.ca_delta_up ? '#2D7A3E' : '#8D1D2C' }};font-weight:600">{{ kpis.ca_delta }}</span>{% endif %}</div>
        </div>
        <div class="dash-kpi">
            <span class="dash-kpi-ic" style="--tint:45,122,62;color:#2D7A3E"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="3" width="8" height="4" rx="1"/><path d="M16 5h2a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h2"/><path d="m9 14 2 2 4-4"/></svg></span>
            <div class="dash-kpi-val">{{ kpis.checklist_pct ?? '—' }}</div>
            <div class="dash-kpi-lbl">{{ translations.kpi_checklists ?? 'Checklists' }}{% if kpis.checklist_ratio %} · {{ kpis.checklist_ratio }}{% endif %}</div>
        </div>
        <div class="dash-kpi">
            <span class="dash-kpi-ic" style="--tint:31,79,107;color:#1F4F6B"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="m3 17 2 2 4-4"/><path d="m3 7 2 2 4-4"/><path d="M13 6h8"/><path d="M13 12h8"/><path d="M13 18h8"/></svg></span>
            <div class="dash-kpi-val">{{ kpis.tasks_done ?? 0 }}<span style="font-size:15px;color:#7a7168">/{{ kpis.tasks_total ?? 0 }}</span></div>
            <div class="dash-kpi-lbl">{{ translations.kpi_tasks_done ?? 'Tâches faites' }}</div>
        </div>
        <div class="dash-kpi">
            <span class="dash-kpi-ic" style="--tint:138,74,36;color:#8a4a24"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/><path d="M21 15.5V11a9 9 0 0 0-18 0v4.5L1.5 18h21z"/></svg></span>
            <div class="dash-kpi-val">{{ kpis.alerts_count ?? 0 }}</div>
            <div class="dash-kpi-lbl">{{ translations.kpi_alerts ?? 'Alertes à traiter' }}</div>
        </div>
    </div>

    {# ── Tâches du jour ── #}
    {% if today_tasks is not empty %}
    <div class="dash-secthead">
        <div class="dash-eyebrow">{{ translations.today_tasks ?? 'Tâches du jour' }}</div>
        <a href="{{ ROOT }}/tasks" class="dash-seelink">{{ translations.see_all ?? 'Tout voir' }}</a>
    </div>
    <div class="dash-card dash-list">
        {% for t in today_tasks %}
        <a href="{{ ROOT }}/tasks" class="dash-row">
            {% if t.done %}
            <span class="dash-row-ic" style="background:rgba(45,122,62,.12);color:#2D7A3E"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="m9 12 2 2 4-4"/></svg></span>
            <div class="dash-row-txt"><div class="dash-row-t" style="text-decoration:line-through;text-decoration-color:rgba(36,26,22,.35)">{{ t.title }}</div><div class="dash-row-s">{{ t.shop }}{% if t.time %} · {{ t.time }}{% endif %}</div></div>
            <span style="font-size:11px;font-weight:600;color:#2D7A3E">{{ translations.done ?? 'Fait' }}</span>
            {% else %}
            <span class="dash-row-ic" style="background:rgba(31,79,107,.1);color:#1F4F6B"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 2v4"/><path d="M8 2v4"/><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 10h18"/></svg></span>
            <div class="dash-row-txt"><div class="dash-row-t">{{ t.title }}</div><div class="dash-row-s">{{ t.shop }}{% if t.time %} · {{ t.time }}{% endif %}</div></div>
            <span class="dash-pill">{{ translations.todo ?? 'À faire' }}</span>
            {% endif %}
        </a>
        {% endfor %}
    </div>
    {% endif %}

    {# ── Alertes ── #}
    {% if alerts is not empty %}
    <div class="dash-eyebrow" style="margin:22px 2px 10px">{{ translations.alerts ?? 'Alertes' }}</div>
    <div class="dash-alerts">
        {% for a in alerts %}
        {% set color = a.type == 'claim' ? '#8D1D2C' : (a.type == 'margin' ? '#8a4a24' : '#C17A2A') %}
        <a href="{{ ROOT }}{{ a.href ?? '/dashboard' }}" class="dash-alert" style="border-left-color:{{ color }}">
            <span style="color:{{ color }};flex-shrink:0">
                {% if a.type == 'claim' %}<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 8v5"/><path d="M12 16h.01"/></svg>
                {% elseif a.type == 'margin' %}<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 17l5-5-5-5"/><path d="M21 12H3"/><path d="M3 5v14"/></svg>
                {% else %}<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 9v4"/><path d="M12 17h.01"/><path d="M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0z"/></svg>{% endif %}
            </span>
            <div class="dash-row-txt"><div class="dash-alert-t">{{ a.title }}</div><div class="dash-row-s">{{ a.subtitle }}</div></div>
            {{ icons.svg('chevron-right', 18) }}
        </a>
        {% endfor %}
    </div>
    {% endif %}

    {# ── Vos boutiques ── #}
    {% if shops is not empty %}
    <div class="dash-secthead">
        <div class="dash-eyebrow">{{ translations.your_shops ?? 'Vos boutiques' }}</div>
        <a href="{{ ROOT }}/shops" class="dash-seelink">{{ translations.pnl_detail ?? 'Détail P&L' }}</a>
    </div>
    <div class="dash-card dash-list">
        {% for s in shops %}
        {% set pct = s.pct ?? 0 %}
        {% set grad = pct >= 85 ? 'linear-gradient(90deg,#2D7A3E,#4bb264)' : (pct >= 70 ? 'linear-gradient(90deg,#C17A2A,#e3a856)' : 'linear-gradient(90deg,#8D1D2C,#c2465a)') %}
        {% set pctcolor = pct >= 85 ? '#2D7A3E' : (pct >= 70 ? '#C17A2A' : '#8D1D2C') %}
        <a href="{{ ROOT }}/shops" class="dash-row">
            <div class="dash-row-txt"><div class="dash-row-t">{{ s.name }}</div><div class="dash-row-s">{{ s.city }}</div></div>
            <div class="dash-bar"><span style="width:{{ pct }}%;background:{{ grad }}"></span></div>
            <span class="dash-pct" style="color:{{ pctcolor }}">{{ pct }}%</span>
        </a>
        {% endfor %}
    </div>
    {% endif %}

    {# ── Raccourcis ── #}
    <div class="dash-eyebrow" style="margin:22px 2px 10px">{{ translations.shortcuts ?? 'Raccourcis' }}</div>
    <div class="dash-shortcuts">
        <a href="{{ ROOT }}/reports" class="dash-sc"><span style="color:#1F4F6B">{{ icons.svg('file-text', 21) }}</span><div>{{ translations.reports ?? 'Rapports' }}</div></a>
        <a href="{{ ROOT }}/claims" class="dash-sc"><span style="color:#8D1D2C">{{ icons.svg('circle-alert', 21) }}</span><div>{{ translations.claims_short ?? 'Réclam.' }}</div></a>
        <a href="{{ ROOT }}/notes" class="dash-sc"><span style="color:#5C4A8A">{{ icons.svg('square-pen', 21) }}</span><div>{{ translations.notes ?? 'Notes' }}</div></a>
        <a href="{{ ROOT }}/targets" class="dash-sc"><span style="color:#C17A2A">{{ icons.svg('target', 21) }}</span><div>{{ translations.targets ?? 'Targets' }}</div></a>
    </div>

</div>
{% endblock %}
