{% extends "layouts/mobile_base.twig" %}
{% import "components/_icons.twig" as icons %}

{% block title %}Panel consultant — Consultant{% endblock %}

{% set jn = translations.day_names ?? ['dimanche','lundi','mardi','mercredi','jeudi','vendredi','samedi'] %}
{% set mn = translations.month_names ?? ['janvier','février','mars','avril','mai','juin','juillet','août','septembre','octobre','novembre','décembre'] %}
{% set frenchdate = (jn[date|date('w')]|capitalize) ~ ' ' ~ date|date('j') ~ ' ' ~ mn[date|date('n') - 1] ~ ' ' ~ date|date('Y') %}

{% block head %}
<style>
    /* État des magasins au moment T */
    .dash-live-badge { display:inline-flex; align-items:center; gap:5px; font-size:.64rem; font-weight:800; color:#2D7A3E; text-transform:uppercase; letter-spacing:.05em; }
    .dash-live-dot { width:7px; height:7px; border-radius:50%; background:#2D7A3E; animation:livePulse 1.6s ease-in-out infinite; }
    @keyframes livePulse { 0%,100% { opacity:1; } 50% { opacity:.25; } }
    .live-tbl { width:100%; border-collapse:collapse; table-layout:fixed; }
    .live-tbl th {
        font-size:.55rem; font-weight:800; text-transform:uppercase; letter-spacing:.04em;
        color:#7a7168; padding:7px 2px 5px 8px; text-align:right; border-bottom:1px solid #f1ede6;
    }
    .live-tbl td { padding:8px 2px 8px 8px; text-align:right; font-size:.72rem; font-weight:800; color:#241f1c; border-bottom:1px solid #f8f5f0; font-variant-numeric:tabular-nums; white-space:nowrap; }
    .live-tbl th.lt-name, .live-tbl td.lt-name { padding-left:2px; }
    .live-tbl tr:last-child td { border-bottom:0; }
    .live-tbl .lt-name { text-align:left; overflow:hidden; text-overflow:ellipsis; }
    .live-tbl th.lt-name { width:22%; }
    .live-tbl td.lt-name { font-size:.72rem; font-weight:800; }
    .lt-skel { display:inline-block; width:34px; height:10px; border-radius:5px; background:linear-gradient(90deg,#f0ece5 25%,#e4dfd6 50%,#f0ece5 75%); background-size:200% 100%; animation:shimmer 1.4s infinite; }
    @keyframes shimmer { 0% { background-position:200% 0; } 100% { background-position:-200% 0; } }
    .lt-err { color:#adb5bd; font-weight:700; }
</style>
{% endblock %}

{# ── Custom header: logo (left) · date (center) · menu (right) ── #}
{% block topbar %}
<div class="app-topbar">
    <div class="container">
        <div class="dash-head3">
            <img src="{{ ROOT }}/assets/brand/logo.png" alt="L'Atelier" class="dash-logo">
            <div class="dash-date3">{{ frenchdate }}</div>
            <button class="app-hamburger dash-menu-btn" id="appHamburger" aria-label="Menu" aria-expanded="false" aria-controls="appNavSheet">
                {{ icons.svg('menu', 24) }}
            </button>
        </div>
    </div>
</div>
{% endblock %}

{% block content %}
<div class="page-content-loaded dash">

    {# ── KPI grid ── #}
    <div class="dash-kpis">
        <div class="dash-kpi">
            <span class="dash-kpi-ic" style="--tint:141,29,44;color:#8D1D2C"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></span>
            <div class="dash-kpi-val">{{ kpis.ca_today ?? '—' }}</div>
            <div class="dash-kpi-lbl">{{ translations.kpi_ca_today ?? 'CA du jour' }}{% if kpis.ca_delta %} · <span style="color:{{ kpis.ca_delta_up ? '#2D7A3E' : '#8D1D2C' }};font-weight:600">{{ kpis.ca_delta }}</span>{% endif %}</div>
        </div>
        <div class="dash-kpi">
            <span class="dash-kpi-ic" style="--tint:45,122,62;color:#2D7A3E"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="3" width="8" height="4" rx="1"/><path d="M16 5h2a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h2"/><path d="m9 14 2 2 4-4"/></svg></span>
            <div class="dash-kpi-val">{{ kpis.checklist_pct ?? '—' }}</div>
            <div class="dash-kpi-lbl">{{ translations.kpi_checklists ?? 'Checklists' }}{% if kpis.checklist_ratio %} · {{ kpis.checklist_ratio }}{% endif %}</div>
        </div>
        <div class="dash-kpi">
            <span class="dash-kpi-ic" style="--tint:31,79,107;color:#1F4F6B"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="m3 17 2 2 4-4"/><path d="m3 7 2 2 4-4"/><path d="M13 6h8"/><path d="M13 12h8"/><path d="M13 18h8"/></svg></span>
            <div class="dash-kpi-val">{{ kpis.tasks_done ?? 0 }}<span style="font-size:15px;color:#7a7168">/{{ kpis.tasks_total ?? 0 }}</span></div>
            <div class="dash-kpi-lbl">{{ translations.kpi_tasks_done ?? 'Tâches faites' }}</div>
        </div>
        <div class="dash-kpi">
            <span class="dash-kpi-ic" style="--tint:138,74,36;color:#8a4a24"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/><path d="M21 15.5V11a9 9 0 0 0-18 0v4.5L1.5 18h21z"/></svg></span>
            <div class="dash-kpi-val">{{ kpis.alerts_count ?? 0 }}</div>
            <div class="dash-kpi-lbl">{{ translations.kpi_alerts ?? 'Alertes à traiter' }}</div>
        </div>
    </div>

    {# ── Tâches du jour ── #}
    {% if today_tasks is not empty %}
    <div class="dash-secthead">
        <div class="dash-eyebrow">{{ translations.today_tasks ?? 'Tâches du jour' }}</div>
        <a href="{{ ROOT }}/tasks" class="dash-seelink">{{ translations.see_all ?? 'Tout voir' }}</a>
    </div>
    <div class="dash-card dash-list">
        {% for t in today_tasks %}
        <a href="{{ ROOT }}/tasks" class="dash-row">
            {% if t.done %}
            <span class="dash-row-ic" style="background:rgba(45,122,62,.12);color:#2D7A3E"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="m9 12 2 2 4-4"/></svg></span>
            <div class="dash-row-txt"><div class="dash-row-t" style="text-decoration:line-through;text-decoration-color:rgba(36,26,22,.35)">{{ t.title }}</div><div class="dash-row-s">{{ t.shop }}{% if t.time %} · {{ t.time }}{% endif %}</div></div>
            <span style="font-size:11px;font-weight:600;color:#2D7A3E">{{ translations.done ?? 'Fait' }}</span>
            {% else %}
            <span class="dash-row-ic" style="background:rgba(31,79,107,.1);color:#1F4F6B"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 2v4"/><path d="M8 2v4"/><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 10h18"/></svg></span>
            <div class="dash-row-txt"><div class="dash-row-t">{{ t.title }}</div><div class="dash-row-s">{{ t.shop }}{% if t.time %} · {{ t.time }}{% endif %}</div></div>
            <span class="dash-pill">{{ translations.todo ?? 'À faire' }}</span>
            {% endif %}
        </a>
        {% endfor %}
    </div>
    {% endif %}

    {# ── Alertes ── #}
    {% if alerts is not empty %}
    <div class="dash-eyebrow" style="margin:22px 2px 10px">{{ translations.alerts ?? 'Alertes' }}</div>
    <div class="dash-alerts">
        {% for a in alerts %}
        {% set color = a.type == 'claim' ? '#8D1D2C' : (a.type == 'margin' ? '#8a4a24' : '#C17A2A') %}
        <a href="{{ ROOT }}{{ a.href ?? '/dashboard' }}" class="dash-alert" style="border-left-color:{{ color }}">
            <span style="color:{{ color }};flex-shrink:0">
                {% if a.type == 'claim' %}<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 8v5"/><path d="M12 16h.01"/></svg>
                {% elseif a.type == 'margin' %}<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 17l5-5-5-5"/><path d="M21 12H3"/><path d="M3 5v14"/></svg>
                {% else %}<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 9v4"/><path d="M12 17h.01"/><path d="M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0z"/></svg>{% endif %}
            </span>
            <div class="dash-row-txt"><div class="dash-alert-t">{{ a.title }}</div><div class="dash-row-s">{{ a.subtitle }}</div></div>
            {{ icons.svg('chevron-right', 18) }}
        </a>
        {% endfor %}
    </div>
    {% endif %}

    {# ── Vos boutiques — état au moment T (temps réel, un magasin par ligne).
         Remplace l'ancienne liste (% checklist) ; repli sur celle-ci quand
         la liste des magasins n'est pas disponible. ── #}
    {% set live_shops = live_shops|default([]) %}
    {% if live_shops is not empty %}
    <div class="dash-secthead">
        <div class="dash-eyebrow">{{ translations.your_shops ?? 'Vos boutiques' }} <span class="dash-live-badge"><span class="dash-live-dot"></span>{{ translations.live_now ?? 'en direct' }}</span></div>
        <a href="{{ ROOT }}/shops" class="dash-seelink">{{ translations.pnl_detail ?? 'Détail P&L' }}</a>
    </div>
    <div class="dash-card" style="padding:6px 10px 8px;">
        <table class="live-tbl">
            <thead>
                <tr>
                    <th class="lt-name">{{ translations.live_shop ?? 'Magasin' }}</th>
                    <th>{{ translations.live_result ?? 'Résultat' }}</th>
                    <th>%</th>
                    <th>{{ translations.live_ca ?? 'CA' }}</th>
                    <th>{{ translations.live_clients ?? 'Clients' }}</th>
                    <th>{{ translations.live_basket ?? 'Panier' }}</th>
                </tr>
            </thead>
            <tbody>
                {% for s in live_shops %}
                <tr class="live-row" data-shop-id="{{ s.id }}">
                    <td class="lt-name" title="{{ s.name }}">{{ s.name }}</td>
                    <td class="lt-res"><span class="lt-skel"></span></td>
                    <td class="lt-pct-cell"><span class="lt-skel" style="width:22px;"></span></td>
                    <td class="lt-ca"><span class="lt-skel"></span></td>
                    <td class="lt-cli"><span class="lt-skel" style="width:22px;"></span></td>
                    <td class="lt-bas"><span class="lt-skel"></span></td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% elseif shops is not empty %}
    <div class="dash-secthead">
        <div class="dash-eyebrow">{{ translations.your_shops ?? 'Vos boutiques' }}</div>
        <a href="{{ ROOT }}/shops" class="dash-seelink">{{ translations.pnl_detail ?? 'Détail P&L' }}</a>
    </div>
    <div class="dash-card dash-list">
        {% for s in shops %}
        {% set pct = s.pct ?? 0 %}
        {% set grad = pct >= 85 ? 'linear-gradient(90deg,#2D7A3E,#4bb264)' : (pct >= 70 ? 'linear-gradient(90deg,#C17A2A,#e3a856)' : 'linear-gradient(90deg,#8D1D2C,#c2465a)') %}
        {% set pctcolor = pct >= 85 ? '#2D7A3E' : (pct >= 70 ? '#C17A2A' : '#8D1D2C') %}
        <a href="{{ ROOT }}/shops" class="dash-row">
            <div class="dash-row-txt"><div class="dash-row-t">{{ s.name }}</div><div class="dash-row-s">{{ s.city }}</div></div>
            <div class="dash-bar"><span style="width:{{ pct }}%;background:{{ grad }}"></span></div>
            <span class="dash-pct" style="color:{{ pctcolor }}">{{ pct }}%</span>
        </a>
        {% endfor %}
    </div>
    {% endif %}

    {# ── Raccourcis ── #}
    <div class="dash-eyebrow" style="margin:22px 2px 10px">{{ translations.shortcuts ?? 'Raccourcis' }}</div>
    <div class="dash-shortcuts">
        <a href="{{ ROOT }}/reports" class="dash-sc"><span style="color:#1F4F6B">{{ icons.svg('file-text', 21) }}</span><div>{{ translations.reports ?? 'Rapports' }}</div></a>
        <a href="{{ ROOT }}/claims" class="dash-sc"><span style="color:#8D1D2C">{{ icons.svg('circle-alert', 21) }}</span><div>{{ translations.claims_short ?? 'Réclam.' }}</div></a>
        <a href="{{ ROOT }}/notes" class="dash-sc"><span style="color:#5C4A8A">{{ icons.svg('square-pen', 21) }}</span><div>{{ translations.notes ?? 'Notes' }}</div></a>
        <a href="{{ ROOT }}/targets" class="dash-sc"><span style="color:#C17A2A">{{ icons.svg('target', 21) }}</span><div>{{ translations.targets ?? 'Targets' }}</div></a>
    </div>

</div>
{% endblock %}

{% block scripts %}
<script>
/* État des magasins au moment T : pour chaque ligne du tableau, le CA, le
 * labour et la fenêtre du jour viennent du P&L temps réel (period=day),
 * l'overhead mensuel est proratisé au jour, le coût matière vient de
 * /statistics/daily-summary sur la même fenêtre.
 * Résultat = CA − matière − labour − overhead/jour ; % = Résultat / CA.
 * Clients & panier : MÊMES source et formule que le module Boutiques —
 * getSalesKpis via /shops/{id}/day-sales : clients = COUNT(DISTINCT
 * ticket_key) du jour (comptage brut, sans estimation), panier = CA base /
 * tickets base sur la même fenêtre. Cohérence garantie entre les écrans. */
(function () {
    'use strict';
    const rows = document.querySelectorAll('.live-row');
    if (!rows.length || typeof ConsultantAjax === 'undefined') return;

    const eur0 = v => new Intl.NumberFormat('fr-BE', { maximumFractionDigits: 0 }).format(v) + ' €';
    const eur2 = v => new Intl.NumberFormat('fr-BE', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(v) + ' €';
    const nb   = v => new Intl.NumberFormat('fr-BE').format(v);

    // Même barème que la ligne Result du module Boutiques.
    function resultColor(r, t) {
        if (r < 0) return '#8B0000';
        const p = t > 0 ? (r / t) * 100 : 0;
        if (p <= 5)  return '#dc3545';
        if (p <= 10) return '#e67e22';
        if (p <= 15) return '#8FA31E';
        if (p <= 25) return '#27ae60';
        return '#C9A227';
    }

    const numOf = v => (typeof v === 'number') ? v
        : (typeof v === 'string' && v !== '' && isFinite(v)) ? Number(v)
        : (v && typeof v === 'object' && typeof v.value === 'number') ? v.value : null;

    // Coût matière : UNE SEULE clé de coût retenue (material_cost prioritaire),
    // sommée sur les buckets — additionner des clés redondantes doublerait le
    // food cost et fausserait le Résultat.
    function extractFood(node) {
        const SKIP = /(pct|percent|ratio|rate|delta|margin)/i;
        const names = [];
        (function collect(n) {
            if (Array.isArray(n)) { n.forEach(collect); return; }
            if (!n || typeof n !== 'object') return;
            for (const k in n) {
                if (/(material|food)/i.test(k) && /(cost|value|amount)/i.test(k) && !SKIP.test(k) && numOf(n[k]) != null) {
                    if (names.indexOf(k) === -1) names.push(k);
                }
                if (n[k] && typeof n[k] === 'object') collect(n[k]);
            }
        })(node);
        if (!names.length) return null;

        const PREFS = ['material_cost', 'materials_cost', 'food_cost', 'goods_cost', 'cost_of_goods'];
        let key = null;
        for (let p = 0; p < PREFS.length && !key; p++) {
            key = names.find(n2 => n2.toLowerCase() === PREFS[p]) || null;
        }
        if (!key) key = names[0];

        let sum = 0, found = false;
        (function walk(n) {
            if (Array.isArray(n)) { n.forEach(walk); return; }
            if (!n || typeof n !== 'object') return;
            for (const k in n) {
                if (k === key) {
                    const x = numOf(n[k]);
                    if (x != null) { sum += x; found = true; continue; }
                }
                if (n[k] && typeof n[k] === 'object') walk(n[k]);
            }
        })(node);
        return found ? sum : null;
    }

    function daysInCurrentMonth() {
        const d = new Date();
        return new Date(d.getFullYear(), d.getMonth() + 1, 0).getDate();
    }

    function cell(row, cls) { return row.querySelector(cls); }
    function fail(row) {
        ['.lt-res', '.lt-pct-cell', '.lt-ca', '.lt-cli', '.lt-bas'].forEach(c => { cell(row, c).innerHTML = '<span class="lt-err">—</span>'; });
    }

    function render(row, ca, result, clients, basket, approx) {
        const color = resultColor(result, ca);
        const pct = ca > 0 ? Math.round((result / ca) * 100) : null;
        const pre = approx ? '≈ ' : '';
        cell(row, '.lt-res').innerHTML = '<span style="color:' + color + ';">' + eur0(result) + '</span>';
        cell(row, '.lt-pct-cell').innerHTML = pct != null
            ? '<span style="color:' + color + ';">' + (result >= 0 ? '+' : '') + pct + ' %</span>'
            : '<span class="lt-err">—</span>';
        cell(row, '.lt-ca').textContent = eur0(ca);
        cell(row, '.lt-cli').textContent = clients != null ? pre + nb(clients) : '—';
        cell(row, '.lt-bas').textContent = basket != null ? pre + eur2(basket) : '—';
    }

    const ROOT = window.__consultantRoot || '';
    const ajax = opts => new Promise(resolve => ConsultantAjax.load(Object.assign({}, opts, {
        onSuccess: d => resolve(d),
        onError: () => resolve(null),
    })));

    rows.forEach(row => {
        const shopId = parseInt(row.dataset.shopId, 10);
        if (!shopId) { fail(row); return; }

        ajax({ endpoint: '/consultant/shops/' + shopId + '/pnl', params: { period: 'day' } }).then(day => {
            if (!day) { fail(row); return; }
            const ca = Number(day.turnover && day.turnover.value) || 0;
            const labour = Number(day.labour && day.labour.value) || 0;
            const from = day.date_from ? String(day.date_from).slice(0, 10) : null;
            const to = day.date_to ? String(day.date_to).slice(0, 10) : null;

            const pMonth = ajax({ endpoint: '/consultant/shops/' + shopId + '/pnl', params: { period: 'month' } });
            const pFood = (from && to)
                ? ajax({ endpoint: '/shops/' + shopId + '/statistics/daily-summary', params: { date_from: from, date_to: to, from: from, to: to } }).then(s => s ? extractFood(s) : null)
                : Promise.resolve(null);
            // Clients & panier : d'abord le COMPTAGE BRUT du jour
            // (COUNT(DISTINCT ticket_key), même formule que les Boutiques).
            // La base locale est alimentée avec retard (constaté : 7 jours) —
            // si elle n'a rien pour aujourd'hui, estimation TRANSPARENTE
            // préfixée ≈ : CA API du jour / panier moyen du mois (base).
            const fetchDb = (f, t) => fetch(ROOT + '/shops/' + shopId + '/day-sales?from=' + f + '&to=' + t, { credentials: 'same-origin' })
                .then(r => r.ok ? r.json() : null)
                .then(j => (j && j.ok && j.data) ? j.data : null)
                .catch(() => null);
            const dbFrom = from || null, dbTo = to || from || null;
            const pDbDay = (dbFrom && dbTo) ? fetchDb(dbFrom, dbTo) : Promise.resolve(null);
            const pDbMonth = pMonth.then(month => {
                const mFrom = month && month.date_from ? String(month.date_from).slice(0, 10) : null;
                const mTo = month && month.date_to ? String(month.date_to).slice(0, 10) : null;
                return (mFrom && mTo) ? fetchDb(mFrom, mTo) : null;
            });

            Promise.all([pMonth, pFood, pDbDay, pDbMonth]).then(([month, food, dbDay, dbMonth]) => {
                const ocMonth = Number(month && month.overhead && month.overhead.value) || 0;
                const result = ca - (food || 0) - labour - (ocMonth / daysInCurrentMonth());

                let clients = null, basket = null, approx = false;
                const dayTickets = dbDay ? Number(dbDay.tickets) || 0 : 0;
                if (dayTickets > 0) {
                    clients = dayTickets;
                    const b = dbDay.avg_basket != null ? Number(dbDay.avg_basket) : NaN;
                    basket = isFinite(b) ? b : null;
                } else if (ca > 0 && dbMonth && Number(dbMonth.avg_basket) > 0) {
                    basket = Number(dbMonth.avg_basket);
                    clients = Math.round(ca / basket);
                    approx = true;
                }
                render(row, ca, result, clients, basket, approx);
            });
        });
    });
})();
</script>
{% endblock %}
