{% extends "layouts/mobile_base.twig" %}

{% import "components/_icons.twig" as icons %}
{% set active_nav = 'checklists' %}
{% set net = data.network ?? {} %}
{% set shops = data.shops ?? [] %}
{% set today_date = today ?? ('now' | date('Y-m-d')) %}
{% set date = date ?? selected_date %}

{% set jn = ['dimanche','lundi','mardi','mercredi','jeudi','vendredi','samedi'] %}
{% set mn = ['janv.','févr.','mars','avr.','mai','juin','juil.','août','sept.','oct.','nov.','déc.'] %}
{% set day_label = date|date('j') ~ ' ' ~ mn[date|date('n') - 1] %}

{% block title %}{{ translations.title ?? 'Checklists' }} — Panel consultant{% endblock %}

{% block topbar %}
<div class="app-topbar">
    <div class="container">
        <div class="scr-head">
            <div>
                <div class="scr-title">{{ translations.title ?? 'Checklists' }}</div>
                <div class="scr-sub">{{ date|date('d.m.Y') }} · {{ translations.day_realization ?? 'réalisation du jour' }}</div>
            </div>
            <button class="app-hamburger" id="appHamburger" aria-label="Menu" aria-expanded="false" aria-controls="appNavSheet">
                {{ icons.svg('menu', 22) }}
            </button>
        </div>
    </div>
</div>
{% endblock %}

{% block content %}
<div class="page-content-loaded cl">

    {# ── Navigation par date ── #}
    {% set prev_date = date | date_modify('-1 day') | date('Y-m-d') %}
    {% set next_date = date | date_modify('+1 day') | date('Y-m-d') %}
    <div class="cl-datenav">
        <a href="{{ ROOT }}/checklists?date={{ prev_date }}" class="cl-datenav-arrow" aria-label="{{ translations.prev_day ?? 'Jour précédent' }}">{{ icons.svg('chevron-left', 16) }}</a>
        <button type="button" class="cl-datenav-cur" onclick="document.getElementById('clDatePicker').showPicker()">
            {{ icons.svg('calendar', 15) }} {{ day_label }}
        </button>
        <input type="date" id="clDatePicker" value="{{ date }}" max="{{ today_date }}" style="position:absolute;opacity:0;pointer-events:none;width:0;height:0;" onchange="window.location.href='{{ ROOT }}/checklists?date='+this.value">
        {% if next_date <= today_date %}
            <a href="{{ ROOT }}/checklists?date={{ next_date }}" class="cl-datenav-arrow" aria-label="{{ translations.next_day ?? 'Jour suivant' }}">{{ icons.svg('chevron-right', 16) }}</a>
        {% endif %}
        {% if date != today_date %}
            <a href="{{ ROOT }}/checklists" class="cl-datenav-today">{{ translations.today ?? "Aujourd'hui" }}</a>
        {% endif %}
    </div>

    {# ── Héro ── #}
    {% set rate = net.completion_rate ?? null %}
    {% set rate_int = rate is not null ? rate | round : 0 %}
    {% set circ = 188.5 %}
    {% set dash_offset = rate is not null ? (circ - (rate / 100 * circ)) | round(2) : circ %}
    <div class="cl-hero">
        <div class="cl-hero-main">
            <div class="cl-ring">
                <svg width="74" height="74" viewBox="0 0 74 74">
                    <circle cx="37" cy="37" r="30" fill="none" stroke="rgba(255,255,255,.16)" stroke-width="8"/>
                    <circle cx="37" cy="37" r="30" fill="none" stroke="#F2C9A0" stroke-width="8" stroke-linecap="round" stroke-dasharray="{{ circ }}" stroke-dashoffset="{{ dash_offset }}"/>
                </svg>
                <div class="cl-ring-txt">{{ rate is not null ? rate_int ~ '%' : '—' }}</div>
            </div>
            <div>
                <div class="cl-hero-eyebrow">{{ translations.subtitle ?? 'Réalisation checklists' }}</div>
                <div class="cl-hero-big">{{ net.tasks_done ?? 0 }}<span>/{{ net.tasks_total ?? 0 }}</span></div>
                <div class="cl-hero-note">{{ translations.tasks_done_suffix ?? 'tâches faites' }} · {{ net.shops_closed ?? 0 }}/{{ net.shops_total ?? 0 }} {{ translations.shops_closed_note ?? 'boutiques clôturées' }}</div>
            </div>
        </div>
        <div class="cl-hero-pills">
            <span class="cl-pill cl-pill-done">{{ icons.svg('check', 13) }}{{ net.tasks_done ?? 0 }} {{ translations.done_pl ?? 'faites' }}</span>
            <span class="cl-pill">{{ net.tasks_skipped ?? 0 }} {{ translations.skipped_pl ?? 'ignorées' }}</span>
            <span class="cl-pill">{{ net.tasks_failed ?? 0 }} {{ translations.failed_pl ?? 'échecs' }}</span>
        </div>
    </div>

    {# ── Classement boutiques ── #}
    {% if shops | length > 0 %}
        <div class="cl-eyebrow">{{ translations.shop_ranking ?? 'Classement boutiques' }}</div>
        <div class="cl-ranklist">
            {% for s in shops %}
                {% set rank = loop.index %}
                {% set cr = s.completion_rate ?? 0 %}
                {% set pending = (s.tasks_total ?? 0) - (s.tasks_done ?? 0) - (s.tasks_skipped ?? 0) - (s.tasks_failed ?? 0) %}
                {% if pending < 0 %}{% set pending = 0 %}{% endif %}
                {% set grad = cr >= 85 ? 'linear-gradient(90deg,#2D7A3E,#4bb264)' : (cr >= 70 ? 'linear-gradient(90deg,#C17A2A,#e3a856)' : 'linear-gradient(90deg,#8D1D2C,#c2465a)') %}
                {% set pctcolor = cr >= 85 ? '#2D7A3E' : (cr >= 70 ? '#C17A2A' : '#8D1D2C') %}
                {% set rankcls = rank == 1 ? 'gold' : (rank == 2 ? 'silver' : (rank == 3 ? 'bronze' : '')) %}
                <a href="{{ ROOT }}/checklists/shops/{{ s.shop_id }}/tasks?date={{ date }}" class="cl-rank">
                    <div class="cl-rank-head">
                        <span class="cl-rank-badge {{ rankcls }}">{{ rank }}</span>
                        <div class="cl-rank-id">
                            <div class="cl-rank-name-row">
                                <span class="cl-rank-name">{{ s.shop_name }}</span>
                                {% if s.day_closed %}
                                    <span class="cl-chip cl-chip-closed">{{ translations.closed ?? 'Clôturé' }}</span>
                                {% elseif (s.mandatory_missed ?? 0) > 0 or cr < 60 %}
                                    <span class="cl-chip cl-chip-late">{{ translations.late ?? 'En retard' }}</span>
                                {% else %}
                                    <span class="cl-chip cl-chip-open">{{ translations.open ?? 'Ouvert' }}</span>
                                {% endif %}
                            </div>
                            <div class="cl-rank-city">{{ s.shop_city }}</div>
                        </div>
                        <span class="cl-rank-pct" style="color:{{ pctcolor }}">{{ s.completion_rate is not null ? (s.completion_rate|round) ~ '%' : '—' }}</span>
                    </div>
                    <div class="cl-rank-bar"><span style="width:{{ cr }}%;background:{{ grad }}"></span></div>
                    <div class="cl-rank-stats">
                        <div class="cl-stat"><div class="cl-stat-v" style="color:#2D7A3E">{{ s.tasks_done ?? 0 }}</div><div class="cl-stat-l">{{ translations.done ?? 'faites' }}</div></div>
                        <div class="cl-stat"><div class="cl-stat-v" style="color:#7a7168">{{ pending }}</div><div class="cl-stat-l">{{ translations.pending ?? 'attente' }}</div></div>
                        <div class="cl-stat"><div class="cl-stat-v" style="color:#C17A2A">{{ s.tasks_skipped ?? 0 }}</div><div class="cl-stat-l">{{ translations.skipped ?? 'ignorée' }}</div></div>
                        <div class="cl-stat"><div class="cl-stat-v" style="color:#8D1D2C">{{ s.tasks_failed ?? 0 }}</div><div class="cl-stat-l">{{ translations.failed ?? 'échecs' }}</div></div>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% else %}
        <div class="cl-empty">{{ icons.svg('clipboard-check', 34) }}<div>{{ translations.none_today ?? 'Aucune donnée de checklist pour ce jour.' }}</div></div>
    {% endif %}

</div>
{% endblock %}
