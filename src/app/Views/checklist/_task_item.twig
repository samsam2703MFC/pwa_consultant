{% import "components/_icons.twig" as icons %}
{% set status = t.status ?? 'PENDING' %}
<div class="task-card">
    <div class="task-status-icon {{ status == 'DONE' ? 'status-done' : (status == 'SKIPPED' ? 'status-skipped' : (status == 'FAILED' ? 'status-failed' : 'status-pending')) }}">
        {% if status == 'DONE' %}{{ icons.svg('check-circle') }}{% elseif status == 'SKIPPED' %}{{ icons.svg('skip-forward') }}{% elseif status == 'FAILED' %}{{ icons.svg('circle-x') }}{% else %}{{ icons.svg('hourglass') }}{% endif %}
    </div>
    <div class="flex-grow-1">
        <div class="task-name">{{ t.task_name }}</div>{% if t.checklist_name and not hide_checklist|default(false) %}<div class="task-meta"><span class="me-1">{{ icons.svg('clipboard-check') }}</span>{{ t.checklist_name }}</div>{% endif %}
        <div class="task-meta">
            {% if t.is_mandatory %}<span class="task-badge badge-mandatory">{{ icons.svg('alert-triangle') }}{{ translations.badge_mandatory ?? 'obligatoire' }}</span>{% endif %}
            {% if t.requires_photo %}<span class="task-badge badge-photo">{{ icons.svg('camera') }}{{ translations.badge_photo ?? 'photo' }}</span>{% endif %}
            {% if t.execution_time %}<span class="task-badge badge-time">{{ icons.svg('clock') }}{{ t.execution_time | slice(0, 5) }}</span>{% endif %}
        </div>
        {% if t.completed_by and status == 'DONE' %}
            <div class="task-by"><span class="me-1">{{ icons.svg('user-check') }}</span>{{ t.completed_by }}{% if t.completed_at %} · {{ t.completed_at | date('H:i') }}{% endif %}</div>
        {% endif %}
        {% if t.note %}<div class="task-note"><span class="me-1">{{ icons.svg('message-square') }}</span>{{ t.note }}</div>{% endif %}
    </div>
</div>
