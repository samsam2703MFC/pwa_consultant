{% extends "layouts/mobile_base.twig" %}

{% import "components/_icons.twig" as icons %}
{% set active_nav = 'checklists' %}
{% set summary = data.summary ?? {} %}
{% set tasks = data.tasks ?? [] %}
{% set trend = data.trend ?? [] %}
{% set today_date = today ?? ('now' | date('Y-m-d')) %}
{% set id_shop = id_shop ?? shop_id %}

{% block title %}{{ translations.shop_tasks_title ?? 'Tâches de la boutique' }} — Consultant Panel{% endblock %}
{% block page_title %}{{ translations.shop_tasks_title ?? 'Tâches de la boutique' }}{% endblock %}
{% block page_subtitle %}{{ date | date('d.m.Y') }}{% endblock %}

{% block topbar_actions %}
<div class="d-flex align-items-center gap-1">
    {% set prev_date = date | date_modify('-1 day') | date('Y-m-d') %}
    <a href="{{ ROOT }}/checklists/shops/{{ id_shop }}/tasks?date={{ prev_date }}" class="btn btn-sm btn-light rounded-circle p-0 d-flex align-items-center justify-content-center" style="width:32px;height:32px;"><span style="font-size:.8rem;">{{ icons.svg('chevron-left') }}</span></a>
    <button type="button" class="btn btn-sm btn-light rounded-pill px-2" style="font-size:.75rem;font-weight:700;min-width:80px;" onclick="document.getElementById('stDatePicker').showPicker()"><span class="me-1">{{ icons.svg('calendar') }}</span>{{ date | date('d.m.Y') }}</button>
    <input type="date" id="stDatePicker" value="{{ date }}" max="{{ today_date }}" style="position:absolute;opacity:0;pointer-events:none;width:0;height:0;" onchange="window.location.href='{{ ROOT }}/checklists/shops/{{ id_shop }}/tasks?date='+this.value">
    {% set next_date = date | date_modify('+1 day') | date('Y-m-d') %}
    {% if next_date <= today_date %}<a href="{{ ROOT }}/checklists/shops/{{ id_shop }}/tasks?date={{ next_date }}" class="btn btn-sm btn-light rounded-circle p-0 d-flex align-items-center justify-content-center" style="width:32px;height:32px;"><span style="font-size:.8rem;">{{ icons.svg('chevron-right') }}</span></a>{% endif %}
</div>
{% endblock %}

{% block head %}
<style>
    .back-link { display:inline-flex; align-items:center; gap:6px; font-size:.78rem; font-weight:700; color:#435ebe; text-decoration:none; margin-bottom:10px; }
    .rate-card { background:#fff; border-radius:16px; padding:14px; margin-bottom:12px; box-shadow:0 2px 8px rgba(0,0,0,.06); }
    .rate-num { font-size:2rem; font-weight:900; line-height:1; }
    .rate-track { height:8px; border-radius:4px; background:#eef0f5; overflow:hidden; margin:8px 0; }
    .rate-fill { height:100%; border-radius:4px; }
    .rate-fill.ex { background:linear-gradient(90deg,#27ae60,#2ecc71); }
    .rate-fill.ok { background:linear-gradient(90deg,#f39c12,#f1c40f); }
    .rate-fill.no { background:linear-gradient(90deg,#e74c3c,#c0392b); }
    .summary-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:8px; margin-bottom:12px; }
    .sum-cell { background:#fff; border-radius:12px; padding:10px 6px; text-align:center; box-shadow:0 1px 6px rgba(0,0,0,.05); }
    .sum-val { font-size:1.2rem; font-weight:900; line-height:1; }
    .sum-lbl { font-size:.6rem; color:#6c757d; margin-top:3px; }
    .trend-card { background:#fff; border-radius:16px; padding:14px; margin-bottom:12px; box-shadow:0 2px 8px rgba(0,0,0,.06); }
    .trend-bars { display:flex; gap:6px; align-items:flex-end; height:56px; }
    .trend-col { flex:1; display:flex; flex-direction:column; align-items:center; gap:3px; }
    .trend-bar { width:100%; border-radius:4px 4px 0 0; min-height:4px; background:#e9ecef; }
    .trend-bar.ex { background:#2ecc71; } .trend-bar.ok { background:#f1c40f; } .trend-bar.no { background:#e74c3c; }
    .trend-dot { width:6px; height:6px; border-radius:50%; background:#ffc107; } .trend-dot.closed { background:#27ae60; }
    .trend-label { font-size:.56rem; color:#adb5bd; text-transform:uppercase; }
    .section-title { font-size:.72rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:#6c757d; padding:8px 4px 6px; }
    .task-card { background:#fff; border-radius:14px; padding:12px; margin-bottom:8px; box-shadow:0 1px 5px rgba(0,0,0,.05); display:flex; align-items:flex-start; gap:12px; }
    .task-status-icon { width:34px; height:34px; border-radius:10px; flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:1rem; }
    .status-done { background:#d1fae5; color:#065f46; } .status-skipped { background:#fef3c7; color:#92400e; } .status-failed { background:#fee2e2; color:#991b1b; } .status-pending { background:#f0f0f5; color:#6c757d; }
    .task-name { font-size:.88rem; font-weight:800; color:#212529; }
    .task-meta { font-size:.7rem; color:#adb5bd; margin-top:3px; }
    .task-badge { display:inline-flex; align-items:center; gap:3px; padding:1px 6px; border-radius:8px; font-size:.62rem; font-weight:700; margin-right:4px; }
    .badge-mandatory { background:#fee2e2; color:#991b1b; } .badge-photo { background:#e0e7ff; color:#3730a3; } .badge-time { background:#f0fdf4; color:#166534; }
    .task-by { font-size:.68rem; color:#6c757d; margin-top:4px; }
    .task-note { font-size:.72rem; color:#6c757d; background:#f8f9fa; border-radius:6px; padding:4px 8px; margin-top:4px; font-style:italic; }
    .empty-state { text-align:center; padding:32px 20px; color:#adb5bd; }

    /* Accordéon : une checklist → drop-list de ses tâches */
    .cl-group { background:#fff; border-radius:14px; margin-bottom:8px; box-shadow:0 1px 5px rgba(0,0,0,.05); overflow:hidden; }
    .cl-head { display:flex; align-items:center; gap:8px; min-height:52px; padding:10px 12px; cursor:pointer; list-style:none; -webkit-tap-highlight-color:transparent; }
    .cl-head::-webkit-details-marker { display:none; }
    .cl-ico { width:30px; height:30px; border-radius:9px; flex-shrink:0; display:flex; align-items:center; justify-content:center; background:#eef2ff; color:#435ebe; }
    .cl-name { flex:1; min-width:0; font-size:.86rem; font-weight:800; color:#212529; line-height:1.25; }
    .cl-flag { display:inline-flex; align-items:center; gap:3px; flex-shrink:0; padding:2px 7px; border-radius:999px; font-size:.66rem; font-weight:800; background:#fee2e2; color:#991b1b; }
    .cl-count { flex-shrink:0; padding:3px 8px; border-radius:999px; font-size:.7rem; font-weight:800; background:#f0f0f5; color:#6c757d; }
    .cl-count.part { background:#fef3c7; color:#92400e; }
    .cl-count.all { background:#d1fae5; color:#065f46; }
    .cl-caret { flex-shrink:0; color:#adb5bd; transition:transform .15s ease; display:flex; }
    .cl-group[open] .cl-caret { transform:rotate(180deg); }
    .cl-group[open] .cl-head { border-bottom:1px solid #f1f3f5; }
    .cl-body { padding:8px 8px 4px; background:#fafbfc; }
    .cl-body .task-card { box-shadow:none; border:1px solid #f1f3f5; }
</style>
{% endblock %}

{% block content %}
<div id="shop-checklists-skeleton" aria-hidden="true">
    <div class="skeleton-hero" style="min-height:90px;border-radius:16px;"></div>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:12px;">
        <div class="skeleton-card" style="padding:12px;min-height:70px;"></div>
        <div class="skeleton-card" style="padding:12px;min-height:70px;"></div>
        <div class="skeleton-card" style="padding:12px;min-height:70px;"></div>
        <div class="skeleton-card" style="padding:12px;min-height:70px;"></div>
    </div>
    <div class="skeleton-card" style="min-height:70px;margin-bottom:8px;"></div>
    <div class="skeleton-card"><div class="skeleton-line"></div><div class="skeleton-line" style="width:80%;"></div><div class="skeleton-line" style="width:60%;"></div></div>
</div>

<div id="shop-checklists-content" style="display:none;" class="page-content-loaded">
    <a href="{{ ROOT }}/checklists?date={{ date }}" class="back-link">{{ icons.svg('arrow-left-circle') }}{{ translations.back_to_ranking ?? 'Retour au classement' }}</a>

    {% set cr = summary.completion_rate ?? null %}
    {% set rate_class = cr is not null ? (cr >= 80 ? 'ex' : (cr >= 50 ? 'ok' : 'no')) : 'no' %}
    <div class="rate-card">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <div style="font-size:.7rem;color:#6c757d;text-transform:uppercase;letter-spacing:.06em;">{{ translations.realization ?? 'Réalisation' }}</div>
                <div class="rate-num" style="color:{{ cr is not null ? (cr >= 80 ? '#27ae60' : (cr >= 50 ? '#e67e22' : '#e74c3c')) : '#adb5bd' }}">{{ cr is not null ? cr ~ '%' : '—' }}</div>
            </div>
            <div style="text-align:right;font-size:.78rem;color:#6c757d;">{{ summary.tasks_done ?? 0 }} / {{ summary.tasks_total ?? 0 }}<br>{{ translations.tasks_done_suffix ?? 'tâches faites' }}</div>
        </div>
        <div class="rate-track"><div class="rate-fill {{ rate_class }}" style="width:{{ cr ?? 0 }}%"></div></div>
        <div style="font-size:.7rem;color:#adb5bd;">{{ summary.tasks_pending ?? 0 }} {{ translations.pending ?? 'attente' }}{% if (summary.tasks_skipped ?? 0) > 0 %} · {{ summary.tasks_skipped }} {{ translations.skipped_pl ?? 'ignorées' }}{% endif %}{% if (summary.tasks_failed ?? 0) > 0 %} · {{ summary.tasks_failed }} {{ translations.failed_pl ?? 'échecs' }}{% endif %}</div>
    </div>

    <div class="summary-grid">
        <div class="sum-cell"><div class="sum-val" style="color:#27ae60;">{{ summary.tasks_done ?? 0 }}</div><div class="sum-lbl">{{ translations.state_done ?? 'faites' }}</div></div>
        <div class="sum-cell"><div class="sum-val" style="color:#435ebe;">{{ summary.tasks_pending ?? 0 }}</div><div class="sum-lbl">{{ translations.state_pending ?? 'attente' }}</div></div>
        <div class="sum-cell"><div class="sum-val" style="color:#e67e22;">{{ summary.tasks_skipped ?? 0 }}</div><div class="sum-lbl">{{ translations.state_skipped ?? 'ignorée' }}</div></div>
        <div class="sum-cell"><div class="sum-val" style="color:#e74c3c;">{{ summary.tasks_failed ?? 0 }}</div><div class="sum-lbl">{{ translations.state_failed ?? 'échec' }}</div></div>
    </div>

    {% if trend | length > 0 %}
        <div class="trend-card">
            <div style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#6c757d;margin-bottom:10px;"><span class="me-1">{{ icons.svg('bar-chart') }}</span>{{ translations.last_7_days ?? '7 derniers jours' }}</div>
            <div class="trend-bars">
                {% for tr in trend %}
                    {% set tr_class = tr.completion_rate >= 80 ? 'ex' : (tr.completion_rate >= 50 ? 'ok' : (tr.completion_rate > 0 ? 'no' : '')) %}
                    {% set bar_h = (tr.completion_rate * 0.56) | round %}
                    <div class="trend-col"><div class="trend-bar {{ tr_class }}" style="height:{{ bar_h }}px;"></div><div class="trend-dot {{ tr.day_closed ? 'closed' : '' }}"></div><div class="trend-label">{{ tr.day | date('D') | slice(0,1) }}</div></div>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    {% set checklist_groups = checklist_groups|default([]) %}
    {% if checklist_groups | length > 0 %}
        <div class="section-title"><span class="me-1">{{ icons.svg('list-checks') }}</span>{{ translations.checklists_of_day ?? 'Checklists du jour' }}</div>
        {% for g in checklist_groups %}
            <details class="cl-group">
                <summary class="cl-head">
                    <span class="cl-ico">{{ icons.svg('clipboard-check') }}</span>
                    <span class="cl-name">{{ g.name != '' ? g.name : (translations.no_checklist ?? 'Sans checklist') }}</span>
                    {% if g.mandatory_pending > 0 %}<span class="cl-flag" title="{{ translations.mandatory_tasks ?? 'Tâches obligatoires' }}">{{ icons.svg('circle-alert') }}{{ g.mandatory_pending }}</span>{% endif %}
                    <span class="cl-count {{ g.done >= g.total ? 'all' : (g.done > 0 ? 'part' : '') }}">{{ g.done }}/{{ g.total }}</span>
                    <span class="cl-caret">{{ icons.svg('chevron-down') }}</span>
                </summary>
                <div class="cl-body">
                    {% for t in g.tasks %}{% include 'checklist/_task_item.twig' with { 't': t, 'hide_checklist': true } %}{% endfor %}
                </div>
            </details>
        {% endfor %}
    {% else %}
        <div class="empty-state"><span style="font-size:2rem;">{{ icons.svg('check-check') }}</span><p class="mt-2 mb-0">{{ translations.none_for_day ?? 'Aucune tâche pour ce jour.' }}</p></div>
    {% endif %}
</div>
{% endblock %}

{% block scripts %}
<script>
const shopChecklistSkeleton = document.getElementById('shop-checklists-skeleton');
const shopChecklistContent = document.getElementById('shop-checklists-content');
if (shopChecklistSkeleton) shopChecklistSkeleton.style.display = 'none';
if (shopChecklistContent) shopChecklistContent.style.display = '';
</script>
{% endblock %}
