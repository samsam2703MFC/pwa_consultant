{% extends "layouts/mobile_base.twig" %}

{% block title %}Notatki — Consultant Panel{% endblock %}
{% block page_title %}Notatki{% endblock %}
{% block page_subtitle %}Wybierz sklep, aby zobaczyc notatki{% endblock %}

{% block content %}
<div class="page-content-loaded">
    {% if shops is empty %}
        <div class="text-center text-muted py-5">
            <i class="bi bi-journal-x" style="font-size:2.5rem;opacity:.3;"></i>
            <p class="mt-3 mb-0">Brak sklepow przypisanych do konsultanta.</p>
        </div>
    {% else %}
        <div class="d-flex flex-column gap-2">
            {% for shop in shops %}
                <a href="{{ ROOT }}/shops/{{ shop.id }}/notes" class="text-decoration-none">
                    <div class="card border-0 shadow-sm" style="border-radius:14px;">
                        <div class="card-body py-3 px-3 d-flex align-items-center justify-content-between gap-3">
                            <div>
                                <div class="fw-700 text-dark" style="font-size:.95rem;">
                                    {{ shop.representative_name ?? shop.name ?? ('Sklep #' ~ shop.id) }}
                                </div>
                                {% if shop.city is defined or shop.address is defined %}
                                    <div class="text-muted mt-1" style="font-size:.78rem;">
                                        {{ shop.city ?? '' }}{% if shop.city is defined and shop.address is defined %}, {% endif %}{{ shop.address ?? '' }}
                                    </div>
                                {% endif %}
                            </div>
                            <span class="btn btn-sm btn-light rounded-pill text-muted">
                                <i class="bi bi-chevron-right"></i>
                            </span>
                        </div>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
