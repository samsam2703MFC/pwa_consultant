{% extends "layouts/mobile_base.twig" %}

{% import "components/_icons.twig" as icons %}
{% set is_employee_context = employee_id is defined and employee_id %}
{% set list_url = is_employee_context ? (ROOT ~ '/shops/' ~ shop_id ~ '/employees/' ~ employee_id ~ '/notes') : (ROOT ~ '/shops/' ~ shop_id ~ '/notes') %}
{% set create_url = list_url ~ '/new' %}
{% set employee_label = employee.display_name ?? employee.employee_name ?? ((employee.name ?? '') ~ ' ' ~ (employee.surname ?? ''))|trim %}

{% block title %}{{ translations.title ?? 'Notes' }} — Consultant Panel{% endblock %}
{% block page_title %}{{ translations.title ?? 'Notes' }}{% endblock %}
{% block page_subtitle %}{{ is_employee_context ? ((translations.employee_prefix ?? 'Employé : ') ~ (employee_label ?: ('#' ~ employee_id))) : (translations.shop_notes_list ?? 'Liste des notes de la boutique') }}{% endblock %}

{% block topbar_actions %}
    <a href="{{ create_url }}"
       class="btn btn-sm btn-primary rounded-pill px-3">
        <span class="me-1">{{ icons.svg('plus') }}</span> Nowa
    </a>
{% endblock %}

{% block content %}
<div class="page-content-loaded">

    <a href="{{ is_employee_context ? (ROOT ~ '/shops/' ~ shop_id ~ '/notes') : (ROOT ~ '/notes') }}"
       class="d-inline-flex align-items-center gap-1 text-muted mb-3"
       style="font-size:.82rem;text-decoration:none;">
        {{ icons.svg('chevron-left') }} {{ is_employee_context ? (translations.shop_notes ?? 'Notes de la boutique') : (translations.choose_shop ?? 'Choisir une boutique') }}
    </a>

    {% if not is_employee_context and employees is defined and employees is not empty %}
        <div class="card border-0 shadow-sm mb-3" style="border-radius:16px;">
            <div class="card-body p-3">
                <div class="fw-700 mb-2" style="font-size:.88rem;">{{ translations.employee_notes ?? 'Notes des employés' }}</div>
                <div class="d-flex flex-column gap-2">
                    {% for emp in employees %}
                        {% set emp_label = emp.display_name ?? emp.employee_name ?? ((emp.name ?? '') ~ ' ' ~ (emp.surname ?? ''))|trim %}
                        <a href="{{ ROOT }}/shops/{{ shop_id }}/employees/{{ emp.id }}/notes"
                           class="d-flex align-items-center justify-content-between text-decoration-none px-3 py-2"
                           style="border:1px solid rgba(0,0,0,.06);border-radius:12px;">
                            <span class="text-dark" style="font-size:.86rem;">{{ emp_label ?: ('Pracownik #' ~ emp.id) }}</span>
                            <span class="text-muted">{{ icons.svg('chevron-right') }}</span>
                        </a>
                    {% endfor %}
                </div>
            </div>
        </div>
    {% endif %}

    {% if notes is empty %}
        <div class="text-center text-muted py-5">
            <span style="font-size:2.5rem;opacity:.3;">{{ icons.svg('notebook') }}</span>
            <p class="mt-3 mb-2">{{ is_employee_context ? 'Brak notatek dla tego pracownika.' : 'Brak notatek dla tej placowki.' }}</p>
            <a href="{{ create_url }}"
               class="btn btn-primary btn-sm rounded-pill px-4">
                {{ translations.add_first_note ?? 'Ajouter une première note' }}
            </a>
        </div>
    {% else %}
        <div class="d-flex flex-column gap-2">
            {% for note in notes %}
                <a href="{{ ROOT }}/notes/{{ note.id }}" class="text-decoration-none">
                    <div class="card border-0 shadow-sm" style="border-radius:14px;">
                        <div class="card-body py-3 px-3">
                            <div class="d-flex align-items-start justify-content-between gap-2 mb-1">
                                {% if note.type_name %}
                                    <span class="badge rounded-pill"
                                          style="background:rgba(67,94,190,.12);color:#435ebe;font-size:.72rem;font-weight:700;">
                                        {{ note.type_name }}
                                    </span>
                                {% else %}
                                    <span class="badge rounded-pill bg-secondary bg-opacity-10 text-secondary"
                                          style="font-size:.72rem;">{{ translations.no_category ?? 'Sans catégorie' }}</span>
                                {% endif %}
                                <span class="text-muted flex-shrink-0" style="font-size:.72rem;">
                                    {{ note.created_at|slice(0,10) }}
                                </span>
                            </div>
                            {% if note.employee_id is defined and note.employee_id %}
                                {% set note_employee = note.employee_name ?? ((note.employee_first_name ?? '') ~ ' ' ~ (note.employee_last_name ?? ''))|trim %}
                                <div class="text-muted mb-1" style="font-size:.74rem;">
                                    <span class="me-1">{{ icons.svg('user') }}</span>{{ note_employee ?: ('Pracownik #' ~ note.employee_id) }}
                                </div>
                            {% endif %}
                            <p class="mb-0 text-dark" style="font-size:.88rem;
                               display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                                {{ note.content }}
                            </p>
                            {% if note.deleted_at %}
                                <div class="mt-1">
                                    <span class="badge bg-danger bg-opacity-10 text-danger" style="font-size:.65rem;">
                                        usunieta
                                    </span>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
