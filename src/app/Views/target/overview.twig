{% extends "layouts/mobile_base.twig" %}

{% block title %}Targety{% endblock %}
{% block page_title %}Targety sklepów{% endblock %}
{% block page_subtitle %}Wybierz sklep{% endblock %}

{% block content %}
<div class="page-content-loaded">

    {% if shops is empty %}
        <div class="text-center text-muted py-5">
            <i class="bi bi-bullseye" style="font-size:2.5rem;opacity:.3;"></i>
            <p class="mt-3">Brak dostępnych sklepów.</p>
        </div>
    {% else %}
        <div class="d-flex flex-column gap-2 px-3">
            {% for shop in shops %}
                <a href="{{ ROOT }}/targets/{{ shop.id }}?year={{ current_year }}&month={{ current_month }}"
                   class="text-decoration-none">
                    <div class="card border-0 shadow-sm" style="border-radius:14px;">
                        <div class="card-body d-flex align-items-center gap-3 py-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center"
                                 style="width:44px;height:44px;background:#f0f4f8;flex-shrink:0;">
                                <i class="bi bi-bullseye" style="font-size:1.3rem;color:#495057;"></i>
                            </div>
                            <div>
                                <div class="fw-semibold text-dark">{{ shop.representative_name ?? shop.name ?? 'Sklep' }}</div>
                                <small class="text-muted">Ustaw targety</small>
                            </div>
                            <i class="bi bi-chevron-right ms-auto text-muted"></i>
                        </div>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}

