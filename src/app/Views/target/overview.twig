{% extends "layouts/mobile_base.twig" %}

{% import "components/_icons.twig" as icons %}
{% set active_nav = 'targets' %}
{% block title %}{{ translations.title ?? 'Targets' }} — Panel consultant{% endblock %}

{% block topbar %}
<div class="app-topbar">
    <div class="container">
        <div class="scr-head">
            <div>
                <div class="scr-title">{{ translations.franchise_title ?? 'Targets' }}</div>
                <div class="scr-sub">{{ translations.franchise_sub ?? 'Les 3 objectifs du franchisé' }}</div>
            </div>
            <button class="app-hamburger" id="appHamburger" aria-label="Menu" aria-expanded="false" aria-controls="appNavSheet">
                {{ icons.svg('menu', 22) }}
            </button>
        </div>
    </div>
</div>
{% endblock %}

{% block head %}
<style>
    .tg-shopsel {
        width: 100%; padding: 10px 12px; border: 1px solid #e7ded2; border-radius: 12px;
        background: #fff; font-size: .82rem; font-weight: 700; color: #241f1c; margin-bottom: 8px;
    }
    .tg-period { display: flex; gap: 6px; margin-bottom: 12px; }
    .tg-period .tg-badge {
        flex: 1; text-align: center; padding: 6px 0; border-radius: 20px;
        border: 1px solid #e0d8cd; background: #fff; font-size: .72rem;
        font-weight: 700; color: #7a7168; -webkit-tap-highlight-color: transparent;
        transition: all .15s;
    }
    .tg-period .tg-badge.active { background: #8D1D2C; border-color: #8D1D2C; color: #fff; }
    .tg-card {
        background: #fff; border: 1px solid #e7ded2; border-radius: 16px; padding: 4px 14px;
        box-shadow: 0 10px 24px -18px rgba(70,40,25,.25);
    }
    .tg-row { border-top: 1px solid #f3ece2; }
    .tg-row:first-child { border-top: 0; }
    .tg-hd { display: flex; align-items: center; gap: 10px; padding: 12px 0; cursor: pointer; -webkit-tap-highlight-color: transparent; }
    .tg-st { font-size: 1rem; font-weight: 900; width: 22px; text-align: center; flex-shrink: 0; }
    .tg-mid { flex: 1; min-width: 0; }
    .tg-nm { font-size: .76rem; font-weight: 800; }
    .tg-trio { display: flex; gap: 14px; margin-top: 3px; font-size: .62rem; color: #7a7168; }
    .tg-trio b { color: #241f1c; font-size: .72rem; display: block; }
    .tg-pct { text-align: right; flex-shrink: 0; }
    .tg-pct b { font-size: 1.02rem; display: block; }
    .tg-pct small { font-size: .56rem; color: #7a7168; }
    .g { color: #2D7A3E; } .o { color: #e67e22; } .r { color: #c0182b; } .nd { color: #adb5bd; }
    .tg-chart {
        display: none; background: #fffdf9; border: 1px solid #f3ece2; border-radius: 12px;
        padding: 10px 8px 6px; margin: 0 0 12px 32px;
    }
    .tg-row.open .tg-chart { display: block; }
    .tg-chart .cap { font-size: .58rem; color: #7a7168; margin: 4px 0 2px 4px; }
    .tg-chart .empty { font-size: .68rem; color: #adb5bd; font-style: italic; padding: 8px 4px; }
    .tg-legend { display: flex; flex-wrap: wrap; gap: 8px 14px; padding: 10px 0 12px; font-size: .58rem; color: #7a7168; }
    .tg-legend i { display: inline-block; width: 9px; height: 9px; border-radius: 50%; margin-right: 4px; vertical-align: -1px; }
    .tg-encode {
        display: inline-flex; align-items: center; gap: 5px; margin-top: 12px;
        font-size: .68rem; font-weight: 700; color: #8D1D2C; text-decoration: none;
    }
    .tg-skel { padding: 12px 0; }
    .tg-skel .l { height: 12px; border-radius: 6px; background: rgba(0,0,0,.06); margin: 10px 0; animation: tgPulse 1.2s ease-in-out infinite; }
    @keyframes tgPulse { 50% { opacity: .45; } }
</style>
{% endblock %}

{% block content %}
<div class="page-content-loaded">

    {% if shops is empty %}
        <div class="text-center text-muted py-5">
            <span style="font-size:2.5rem;opacity:.3;">{{ icons.svg('target') }}</span>
            <p class="mt-3">{{ translations.no_shops ?? 'Aucune boutique disponible.' }}</p>
        </div>
    {% else %}

        <select class="tg-shopsel" id="tgShop" aria-label="{{ translations.shop_fallback ?? 'Boutique' }}">
            {% for s in shops %}
                <option value="{{ s.id }}">{{ s.representative_name ?? s.name }}</option>
            {% endfor %}
        </select>

        {# ── Période : mois / trimestre / année (en cours, vs N-1) ── #}
        <div class="tg-period" id="tgPeriod">
            <button class="tg-badge active" data-period="month">{{ translations.period_month ?? 'Mois' }}</button>
            <button class="tg-badge" data-period="quarter">{{ translations.period_quarter ?? 'Trimestre' }}</button>
            <button class="tg-badge" data-period="year">{{ translations.period_year ?? 'Année' }}</button>
        </div>

        <div class="tg-card">
            <div class="tg-skel" id="tgSkel">
                <div class="l" style="width:85%;"></div>
                <div class="l" style="width:70%;"></div>
                <div class="l" style="width:78%;"></div>
            </div>
            <div id="tgRows"></div>
            <div class="tg-legend">
                <span><i style="background:#2D7A3E;"></i>✓ ≥ {{ thresholds.green|number_format(0, ',', ' ') }} % {{ translations.of_objective ?? "de l'objectif" }}</span>
                <span><i style="background:#e67e22;"></i>⚠ {{ thresholds.orange|number_format(0, ',', ' ') }}–{{ thresholds.green|number_format(0, ',', ' ') }} %</span>
                <span><i style="background:#c0182b;"></i>● &lt; {{ thresholds.orange|number_format(0, ',', ' ') }} %</span>
                <span><i style="background:#adb5bd;"></i>— {{ translations.to_encode ?? 'à encoder' }}</span>
            </div>
        </div>

        <a class="tg-encode" id="tgEncodeLink" href="{{ ROOT }}/targets/{{ shops[0].id }}?year={{ current_year }}&month={{ current_month }}">
            {{ icons.svg('square-pen', 14) }} {{ translations.encode_targets ?? 'Encoder les targets de cette boutique' }}
        </a>

    {% endif %}
</div>
{% endblock %}

{% block scripts %}
{% if shops is not empty %}
<script>
const TG_SHOPS = [{% for s in shops %}{ id: {{ s.id }}, name: {{ (s.representative_name ?? s.name)|json_encode|raw }} }{{ loop.last ? '' : ',' }}{% endfor %}];
const TG_THR   = {{ thresholds|json_encode|raw }};   // % de l'objectif (vert/orange) — configurables côté contrôleur
const TG_YEAR  = {{ current_year }};
const TG_MONTH = {{ current_month }};
const TG_I18N = {
    b2b:      {{ (translations.kpi_b2b ?? 'Clients B2B développés')|json_encode|raw }},
    clients:  {{ (translations.kpi_clients ?? 'Clients en magasin vs N-1')|json_encode|raw }},
    basket:   {{ (translations.kpi_basket ?? 'Panier moyen')|json_encode|raw }},
    n1:       {{ (translations.lbl_n1 ?? 'N-1')|json_encode|raw }},
    current:  {{ (translations.lbl_current ?? 'Actuel')|json_encode|raw }},
    objective:{{ (translations.lbl_objective ?? 'Objectif')|json_encode|raw }},
    ofObj:    {{ (translations.of_objective ?? "de l'objectif")|json_encode|raw }},
    toEncode: {{ (translations.to_encode ?? 'à encoder')|json_encode|raw }},
    chartCap: {{ (translations.chart_cap ?? 'Barres grises = N-1 · barres colorées = actuel (statut de la période) · pointillé = objectif')|json_encode|raw }},
    chartB2b: {{ (translations.chart_b2b_empty ?? 'Pas de série mensuelle : valeurs B2B à encoder par le franchiseur.')|json_encode|raw }},
    loading:  {{ (translations.load ?? 'Chargement…')|json_encode|raw }},
    qLetter:  {{ (translations.quarter_letter ?? 'T')|json_encode|raw }}
};

(function () {
    'use strict';
    const ROOT = window.__consultantRoot || '';
    const rowsEl = document.getElementById('tgRows');
    const skelEl = document.getElementById('tgSkel');
    const shopSel = document.getElementById('tgShop');
    const perBar = document.getElementById('tgPeriod');
    const encodeLink = document.getElementById('tgEncodeLink');
    if (!rowsEl) return;

    const nf0 = new Intl.NumberFormat('fr-BE', { maximumFractionDigits: 0 });
    const nf2 = new Intl.NumberFormat('fr-BE', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    const fmtBy = (v, unit) => v == null ? '—' : (unit === 'amount' ? nf2.format(v) + ' €' : (unit === 'pct' ? nf0.format(v) + ' %' : nf0.format(Math.round(v))));
    const pad = n => (n < 10 ? '0' : '') + n;
    const iso = d => d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate());

    // Statut vs objectif : % = valeur/objectif (objectif/valeur si « plus
    // bas = mieux »). Seuils TG_THR configurables côté contrôleur.
    function pctOf(v, obj, lower) {
        if (v == null || obj == null || obj <= 0 || (lower && v <= 0)) return null;
        return (lower ? obj / v : v / obj) * 100;
    }
    function stOf(pct) {
        if (pct == null) return 'nd';
        if (pct >= TG_THR.green) return 'g';
        if (pct >= TG_THR.orange) return 'o';
        return 'r';
    }
    const ST_ICON = { g: '✓', o: '⚠', r: '●', nd: '—' };
    const ST_HEX  = { g: '#2D7A3E', o: '#e67e22', r: '#c0182b', nd: '#adb5bd' };

    // ── Périodes : mois / trimestre / année EN COURS, vs N-1 (mêmes
    // dates un an plus tôt). Objectif : les targets sont MENSUELLES →
    // pour les compteurs (B2B, clients) l'objectif de période = mensuel
    // × nb de mois (3, 12) ; le panier moyen est une moyenne → inchangé.
    const P_MONTHS = { month: 1, quarter: 3, year: 12 };

    function periodStart(period, y, m) {
        if (period === 'year') return new Date(y, 0, 1);
        if (period === 'quarter') return new Date(y, Math.floor(m / 3) * 3, 1);
        return new Date(y, m, 1);
    }
    function curWindows(period) {
        const now = new Date();
        const from = periodStart(period, now.getFullYear(), now.getMonth());
        const fromP = periodStart(period, now.getFullYear() - 1, now.getMonth());
        const toP = new Date(now.getFullYear() - 1, now.getMonth(), now.getDate());
        return { n: { from: iso(from), to: iso(now) }, p: { from: iso(fromP), to: iso(toP) } };
    }
    function scaleObj(objective, unit, period) {
        if (objective == null) return null;
        return unit === 'amount' ? Number(objective) : Number(objective) * P_MONTHS[period];
    }

    function fetchSales(shopId, w, done) {
        ConsultantAjax.load({
            endpoint: '/shops/' + shopId + '/day-sales',
            params: { from: w.from, to: w.to },
            onSuccess: r => done((r && r.data) || null),
            onError: () => done(null),
        });
    }

    // ── Chargement des 3 lignes pour un magasin × une période ──
    const _cache = {};   // 'shopId|period' → state
    let curShop = Number(shopSel.value);
    let curPeriod = 'month';

    function load(shopId, period) {
        skelEl.style.display = '';
        rowsEl.innerHTML = '';
        const st = { fr: null, n: null, p: null, series: {} };
        let pending = 3;
        const step = () => {
            if (--pending === 0) {
                _cache[shopId + '|' + period] = st;
                if (shopId === curShop && period === curPeriod) render(st);
            }
        };

        ConsultantAjax.load({
            endpoint: '/targets/' + shopId + '/franchise-data',
            params: { year: TG_YEAR, month: TG_MONTH },
            onSuccess: r => { st.fr = ((r || {}).data || {}).kpis || null; step(); },
            onError: step,
        });
        const w = curWindows(period);
        fetchSales(shopId, w.n, d => { st.n = d; step(); });
        fetchSales(shopId, w.p, d => { st.p = d; step(); });
    }

    function kpiModel(st, period) {
        const fr = st.fr || {};
        const un = (fr.basket && fr.basket.unit) || 'amount';
        return [
            { key: 'b2b', nm: TG_I18N.b2b, unit: (fr.b2b && fr.b2b.unit) || '',
              n1: null, val: fr.b2b ? fr.b2b.value : null,
              obj: fr.b2b ? scaleObj(fr.b2b.objective, (fr.b2b.unit || ''), period) : null,
              lower: !!(fr.b2b && fr.b2b.lower) },
            { key: 'clients', nm: TG_I18N.clients, unit: '',
              n1: st.p ? Number(st.p.tickets) || null : null,
              val: st.n ? Number(st.n.tickets) || null : null,
              obj: fr.clients ? scaleObj(fr.clients.objective, '', period) : null,
              lower: !!(fr.clients && fr.clients.lower) },
            { key: 'basket', nm: TG_I18N.basket, unit: un,
              n1: st.p && st.p.avg_basket != null ? Number(st.p.avg_basket) : null,
              val: st.n && st.n.avg_basket != null ? Number(st.n.avg_basket) : null,
              obj: fr.basket ? scaleObj(fr.basket.objective, 'amount', period) : null,
              lower: !!(fr.basket && fr.basket.lower) },
        ];
    }

    function render(st) {
        skelEl.style.display = 'none';
        rowsEl.innerHTML = kpiModel(st, curPeriod).map(k => {
            const pct = pctOf(k.val, k.obj, k.lower);
            const s = stOf(pct);
            const pctTxt = pct == null
                ? '<b class="nd">—</b><small>' + TG_I18N.toEncode + '</small>'
                : '<b class="' + s + '">' + String(Math.round(pct * 10) / 10).replace('.', ',') + ' %</b><small>' + TG_I18N.ofObj + '</small>';
            return '<div class="tg-row" data-kpi="' + k.key + '">'
                + '<div class="tg-hd" role="button" aria-expanded="false">'
                + '<span class="tg-st ' + s + '">' + ST_ICON[s] + '</span>'
                + '<div class="tg-mid"><div class="tg-nm">' + k.nm + '</div>'
                + '<div class="tg-trio">'
                + '<span>' + TG_I18N.n1 + '<b>' + fmtBy(k.n1, k.unit) + '</b></span>'
                + '<span>' + TG_I18N.current + '<b class="' + s + '">' + fmtBy(k.val, k.unit) + '</b></span>'
                + '<span>' + TG_I18N.objective + '<b>' + fmtBy(k.obj, k.unit) + '</b></span>'
                + '</div></div>'
                + '<div class="tg-pct">' + pctTxt + '</div>'
                + '</div>'
                + '<div class="tg-chart"><div class="empty">' + TG_I18N.loading + '</div></div>'
                + '</div>';
        }).join('');

        rowsEl.querySelectorAll('.tg-hd').forEach(hd => hd.addEventListener('click', function () {
            const row = this.closest('.tg-row');
            const open = row.classList.toggle('open');
            this.setAttribute('aria-expanded', open ? 'true' : 'false');
            rowsEl.querySelectorAll('.tg-row').forEach(r2 => { if (r2 !== row) r2.classList.remove('open'); });
            if (open) drawChart(curShop, row.dataset.kpi, row.querySelector('.tg-chart'), curPeriod);
        }));
    }

    // ── Graphique V2 : barres N (colorées) vs N-1 (grises) ──
    // Mois → 6 derniers mois · Trimestre → 4 derniers trimestres ·
    // Année → 3 dernières années. Couleur de chaque barre N = statut de
    // la période vs l'objectif (pointillé). B2B : pas de série POS.
    function chartBars(period) {
        const now = new Date();
        const y = now.getFullYear(), m = now.getMonth(), d = now.getDate();
        const out = [];
        if (period === 'quarter') {
            const q0 = Math.floor(m / 3);
            for (let i = 3; i >= 0; i--) {
                const first = new Date(y, (q0 - i) * 3, 1);
                const last = i === 0 ? new Date(y, m, d) : new Date(first.getFullYear(), first.getMonth() + 3, 0);
                const firstP = new Date(first.getFullYear() - 1, first.getMonth(), 1);
                const lastP = new Date(last.getFullYear() - 1, last.getMonth(), Math.min(last.getDate(), 28));
                out.push({ label: TG_I18N.qLetter + (Math.floor(first.getMonth() / 3) + 1) + '·' + String(first.getFullYear()).slice(2),
                           n: { from: iso(first), to: iso(last) }, p: { from: iso(firstP), to: iso(lastP) } });
            }
            return out;
        }
        if (period === 'year') {
            for (let i = 2; i >= 0; i--) {
                const first = new Date(y - i, 0, 1);
                const last = i === 0 ? new Date(y, m, d) : new Date(y - i, 11, 31);
                const firstP = new Date(first.getFullYear() - 1, 0, 1);
                const lastP = new Date(last.getFullYear() - 1, last.getMonth(), Math.min(last.getDate(), 28));
                out.push({ label: String(y - i),
                           n: { from: iso(first), to: iso(last) }, p: { from: iso(firstP), to: iso(lastP) } });
            }
            return out;
        }
        for (let i = 5; i >= 0; i--) {
            const first = new Date(y, m - i, 1);
            const last = i === 0 ? new Date(y, m, d) : new Date(first.getFullYear(), first.getMonth() + 1, 0);
            const firstP = new Date(first.getFullYear() - 1, first.getMonth(), 1);
            const lastP = new Date(last.getFullYear() - 1, last.getMonth(), Math.min(last.getDate(), 28));
            out.push({ label: first.toLocaleDateString(document.documentElement.lang || 'fr', { month: 'short' }),
                       n: { from: iso(first), to: iso(last) }, p: { from: iso(firstP), to: iso(lastP) } });
        }
        return out;
    }

    function drawChart(shopId, kpi, host, period) {
        const st = _cache[shopId + '|' + period];
        if (!st) return;
        if (kpi === 'b2b') { host.innerHTML = '<div class="empty">' + TG_I18N.chartB2b + '</div>'; return; }
        const sKey = kpi + '|' + period;
        if (st.series[sKey]) { host.innerHTML = st.series[sKey]; return; }

        const bars = chartBars(period);
        const pts = bars.map(b => ({ label: b.label, n: null, p: null }));
        let pending = bars.length * 2;
        bars.forEach((b, idx) => {
            fetchSales(shopId, b.n, d => { pts[idx].n = metricOf(d, kpi); if (--pending === 0) finish(); });
            fetchSales(shopId, b.p, d => { pts[idx].p = metricOf(d, kpi); if (--pending === 0) finish(); });
        });

        function metricOf(d, kpi) {
            if (!d) return null;
            if (kpi === 'clients') { const t = Number(d.tickets); return isFinite(t) && t > 0 ? t : null; }
            const b = Number(d.avg_basket); return isFinite(b) && b > 0 ? b : null;
        }

        function finish() {
            const fr = (st.fr || {})[kpi] || {};
            const obj = fr.objective != null
                ? scaleObj(fr.objective, kpi === 'basket' ? 'amount' : '', period)
                : null;
            const lower = !!fr.lower;
            const vals = pts.flatMap(p => [p.n, p.p]).filter(v => v != null);
            if (obj != null) vals.push(obj);
            if (!vals.length) { host.innerHTML = '<div class="empty">' + TG_I18N.toEncode + '</div>'; st.series[sKey] = host.innerHTML; return; }
            const max = Math.max.apply(null, vals) * 1.12;
            const W = 320, H = 120, base = 106, top = 10, span = base - top;
            const groupW = (W - 28) / pts.length;
            const bw = Math.min(16, groupW / 3);
            let svg = '';
            if (obj != null) {
                const yl = base - (obj / max) * span;
                svg += '<line x1="24" y1="' + yl.toFixed(1) + '" x2="' + (W - 4) + '" y2="' + yl.toFixed(1) + '" stroke="#241f1c" stroke-width="1.5" stroke-dasharray="5 4"/>'
                    + '<text x="' + (W - 4) + '" y="' + (yl - 4).toFixed(1) + '" font-size="8" fill="#241f1c" text-anchor="end" font-weight="700">' + TG_I18N.objective + '</text>';
            }
            pts.forEach((p, idx) => {
                const x0 = 26 + idx * groupW + (groupW - 2 * bw - 3) / 2;
                if (p.p != null) {
                    const h = (p.p / max) * span;
                    svg += '<rect x="' + x0.toFixed(1) + '" y="' + (base - h).toFixed(1) + '" width="' + bw + '" height="' + h.toFixed(1) + '" rx="3" fill="#d9d1c6"/>';
                }
                if (p.n != null) {
                    const h = (p.n / max) * span;
                    const col = ST_HEX[stOf(pctOf(p.n, obj, lower))] || ST_HEX.nd;
                    svg += '<rect x="' + (x0 + bw + 3).toFixed(1) + '" y="' + (base - h).toFixed(1) + '" width="' + bw + '" height="' + h.toFixed(1) + '" rx="3" fill="' + col + '"/>';
                }
                svg += '<text x="' + (x0 + bw + 1.5).toFixed(1) + '" y="118" font-size="7.5" fill="#9a9086" text-anchor="middle">' + p.label + '</text>';
            });
            host.innerHTML = '<svg viewBox="0 0 ' + W + ' ' + H + '" width="100%">' + svg + '</svg>'
                + '<div class="cap">' + TG_I18N.chartCap + '</div>';
            st.series[sKey] = host.innerHTML;
        }
    }

    function refresh() {
        const key = curShop + '|' + curPeriod;
        _cache[key] ? render(_cache[key]) : load(curShop, curPeriod);
    }
    shopSel.addEventListener('change', function () {
        curShop = Number(this.value);
        if (encodeLink) encodeLink.href = ROOT + '/targets/' + curShop + '?year=' + TG_YEAR + '&month=' + TG_MONTH;
        refresh();
    });
    perBar.querySelectorAll('.tg-badge').forEach(b => b.addEventListener('click', function () {
        perBar.querySelectorAll('.tg-badge').forEach(x => x.classList.remove('active'));
        this.classList.add('active');
        curPeriod = this.dataset.period;
        refresh();
    }));
    load(curShop, curPeriod);
})();
</script>
{% endif %}
{% endblock %}
