{% extends "layouts/mobile_base.twig" %}

{% import "components/_icons.twig" as icons %}
{% block title %}{{ translations.title ?? 'Targets' }}{% endblock %}
{% block page_title %}{{ translations.shops_targets ?? 'Targets des boutiques' }}{% endblock %}
{% block page_subtitle %}{{ translations.choose_shop ?? 'Choisir une boutique' }}{% endblock %}

{% block content %}
<div class="page-content-loaded">

    {% if shops is empty %}
        <div class="text-center text-muted py-5">
            <span style="font-size:2.5rem;opacity:.3;">{{ icons.svg('target') }}</span>
            <p class="mt-3">{{ translations.no_shops ?? 'Aucune boutique disponible.' }}</p>
        </div>
    {% else %}
        <div class="d-flex flex-column gap-2 px-3">
            {% for shop in shops %}
                <a href="{{ ROOT }}/targets/{{ shop.id }}?year={{ current_year }}&month={{ current_month }}"
                   class="text-decoration-none">
                    <div class="card border-0 shadow-sm" style="border-radius:14px;">
                        <div class="card-body d-flex align-items-center gap-3 py-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center"
                                 style="width:44px;height:44px;background:#f0f4f8;flex-shrink:0;">
                                <span style="font-size:1.3rem;color:#495057;">{{ icons.svg('target') }}</span>
                            </div>
                            <div>
                                <div class="fw-semibold text-dark">{{ shop.representative_name ?? shop.name ?? 'Sklep' }}</div>
                                <small class="text-muted">{{ translations.set_targets ?? 'Définir les targets' }}</small>
                            </div>
                            <span class="ms-auto text-muted">{{ icons.svg('chevron-right') }}</span>
                        </div>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}

