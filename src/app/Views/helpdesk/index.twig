{% extends "layouts/mobile_base.twig" %}

{% import "components/_icons.twig" as icons %}
{% block title %}{{ translations.title ?? 'Demandes' }} — Consultant Panel{% endblock %}
{% block page_title %}{{ translations.title ?? 'Demandes' }}{% endblock %}
{% block page_subtitle %}{{ translations.subtitle2 ?? 'Helpdesk de vos zones de responsabilité' }}{% endblock %}

{% block head %}
<style>
    .task-filter-card {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 2px 10px rgba(0,0,0,.06);
        padding: 14px;
        margin-bottom: 14px;
    }
    .task-filter-label {
        font-size: .72rem;
        font-weight: 700;
        color: #6c757d;
        text-transform: uppercase;
        letter-spacing: .04em;
        margin-bottom: 4px;
    }
    .task-filter-input,
    .task-filter-select,
    .case-action-select,
    .case-action-textarea {
        width: 100%;
        padding: 8px 10px;
        border: 1.5px solid #e9ecef;
        border-radius: 10px;
        font-size: .86rem;
        background: #f8f9ff;
        color: #212529;
        outline: none;
    }
    .task-filter-input:focus,
    .task-filter-select:focus,
    .case-action-select:focus,
    .case-action-textarea:focus {
        border-color: #435ebe;
        background: #fff;
    }
    .task-case-card {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 1px 8px rgba(0,0,0,.06);
        padding: 14px;
        margin-bottom: 10px;
        cursor: pointer;
    }
    .task-case-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 8px;
    }
    .task-case-title {
        font-weight: 800;
        font-size: .92rem;
        color: #212529;
        line-height: 1.25;
    }
    .task-case-ref {
        font-size: .72rem;
        color: #6c757d;
        margin-top: 2px;
    }
    .task-case-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 8px;
    }
    .task-chip {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        border-radius: 999px;
        padding: 4px 8px;
        font-size: .72rem;
        font-weight: 700;
        background: #f1f3f5;
        color: #495057;
    }
    .task-status {
        border-radius: 999px;
        padding: 4px 8px;
        font-size: .68rem;
        font-weight: 800;
        white-space: nowrap;
    }
    .status-new { background: rgba(13,110,253,.12); color: #0d6efd; }
    .status-progress { background: rgba(255,193,7,.2); color: #9a6b00; }
    .status-resolved { background: rgba(40,167,69,.12); color: #198754; }
    .status-closed { background: rgba(108,117,125,.12); color: #6c757d; }
    .status-cancelled { background: rgba(220,53,69,.1); color: #dc3545; }
    .task-case-description,
    .task-case-reply {
        font-size: .82rem;
        color: #495057;
        line-height: 1.45;
        margin: 8px 0 0;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .task-case-reply {
        padding: 8px 10px;
        border-radius: 10px;
        background: #f8f9ff;
        border: 1px solid #edf0f2;
    }
    .details-modal .modal-content {
        border-radius: 18px;
        overflow: hidden;
    }
    .case-section {
        padding: 14px 16px;
        border-bottom: 1px solid #f0f1f3;
    }
    .case-section:last-child { border-bottom: 0; }
    .case-section-title {
        font-size: .72rem;
        font-weight: 800;
        color: #6c757d;
        text-transform: uppercase;
        letter-spacing: .05em;
        margin-bottom: 10px;
    }
    .case-info-row {
        display: flex;
        gap: 10px;
        margin-bottom: 7px;
        font-size: .84rem;
        align-items: flex-start;
    }
    .case-info-label {
        width: 92px;
        flex-shrink: 0;
        color: #6c757d;
    }
    .case-info-value {
        color: #212529;
        flex: 1;
        min-width: 0;
        word-break: break-word;
    }
    .case-description-full,
    .case-reply-view {
        background: #f8f9ff;
        border-radius: 10px;
        padding: 10px 12px;
        font-size: .84rem;
        color: #495057;
        white-space: pre-wrap;
    }
    .case-actions {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }
    .case-action-row {
        display: flex;
        flex-direction: column;
        gap: 8px;
        background: #fff;
        border: 1px solid #edf0f2;
        border-radius: 12px;
        padding: 10px;
    }
    .case-action-label {
        font-size: .74rem;
        font-weight: 800;
        color: #6c757d;
        text-transform: uppercase;
        letter-spacing: .05em;
    }
    .case-action-textarea {
        min-height: 90px;
        resize: vertical;
    }
    .case-action-button {
        width: 100%;
        border: none;
        border-radius: 999px;
        background: #435ebe;
        color: #fff;
        font-size: .84rem;
        font-weight: 700;
        padding: 9px 12px;
    }
    .case-action-button:disabled { opacity: .55; }
    .case-feedback {
        font-size: .76rem;
        font-weight: 600;
        min-height: 18px;
    }
    .case-feedback.ok { color: #198754; }
    .case-feedback.err { color: #dc3545; }
    .attachments-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }
    .attachment-card {
        border: 1px solid #edf0f2;
        border-radius: 12px;
        padding: 10px;
        text-align: center;
        background: #fff;
    }
    .attachment-card button {
        width: 100%;
        border: none;
        background: none;
        color: #435ebe;
        font-size: .8rem;
        font-weight: 700;
    }
    .modal-loader {
        padding: 28px 16px;
        text-align: center;
        color: #6c757d;
    }
</style>
{% endblock %}

{% block content %}
<div class="page-content-loaded">
    <form method="GET" action="{{ ROOT }}/helpdesk" class="task-filter-card">
        <div class="mb-2">
            <label class="task-filter-label">{{ translations.search ?? 'Rechercher' }}</label>
            <input class="task-filter-input" type="search" name="q" value="{{ filters.q }}" placeholder="{{ translations.search_ph ?? 'Réf, titre ou boutique' }}">
        </div>
        <div class="row g-2">
            <div class="col-6">
                <label class="task-filter-label">{{ translations.area ?? 'Zone' }}</label>
                <select class="task-filter-select" name="area_key">
                    <option value="">{{ translations.all ?? 'Toutes' }}</option>
                    {% for area in areas %}
                        <option value="{{ area.key }}" {{ filters.area_key == area.key ? 'selected' : '' }}>{{ area.label }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-6">
                <label class="task-filter-label">{{ translations.status ?? 'Statut' }}</label>
                <select class="task-filter-select" name="status">
                    <option value="">{{ translations.all ?? 'Toutes' }}</option>
                    {% for key, label in statuses %}
                        <option value="{{ key }}" {{ filters.status == key ? 'selected' : '' }}>{{ label }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>
        <button type="submit" class="btn btn-primary btn-sm w-100 mt-3 rounded-pill">{{ translations.filter ?? 'Filtrer' }}</button>
    </form>

    {% if cases is empty %}
        <div class="text-center text-muted py-5">
            <span style="font-size:2.5rem;opacity:.35;">{{ icons.svg('inbox') }}</span>
            <p class="mt-3 mb-0">{{ translations.none ?? 'Aucun ticket Helpdesk assigné à vos zones.' }}</p>
        </div>
    {% else %}
        <div class="d-flex flex-column">
            {% for case in cases %}
                {% set status_class = {
                    'NEW': 'status-new',
                    'IN_PROGRESS': 'status-progress',
                    'RESOLVED': 'status-resolved',
                    'CLOSED': 'status-closed',
                    'CANCELLED': 'status-cancelled'
                }[case.status] ?? 'status-closed' %}
                <article class="task-case-card" data-case-id="{{ case.id }}">
                    <div class="task-case-top">
                        <div class="min-w-0">
                            <div class="task-case-title">{{ case.title }}</div>
                            <div class="task-case-ref">{{ case.ref }} · {{ case.created_at|slice(0,16)|replace({'T': ' '}) }}</div>
                        </div>
                        <span class="task-status {{ status_class }}">{{ statuses[case.status] ?? case.status }}</span>
                    </div>

                    {% if case.description %}
                        <p class="task-case-description">{{ case.description }}</p>
                    {% endif %}
                    {% if case.admin_reply %}
                        <p class="task-case-reply"><strong>{{ translations.response_colon ?? 'Réponse :' }}</strong> {{ case.admin_reply }}</p>
                    {% endif %}

                    <div class="task-case-meta">
                        <span class="task-chip">{{ icons.svg('network') }}{{ case.area_label ?? case.area_key }}</span>
                        {% if case.shop_name %}
                            <span class="task-chip">{{ icons.svg('store') }}{{ case.shop_name }}</span>
                        {% endif %}
                        {% if case.requester_name %}
                            <span class="task-chip">{{ icons.svg('user') }}{{ case.requester_name }}</span>
                        {% endif %}
                        {% if case.meeting_title %}
                            <span class="task-chip">{{ icons.svg('calendar-days') }}{{ case.meeting_title }}</span>
                        {% endif %}
                    </div>
                </article>
            {% endfor %}
        </div>
    {% endif %}
</div>

<div class="modal fade details-modal" id="helpdeskDetailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">{{ translations.details ?? 'Détails du ticket' }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ translations.close ?? 'Fermer' }}"></button>
            </div>
            <div class="modal-body p-0" id="helpdeskDetailsContent">
                <div class="modal-loader">
                    <div class="spinner-border spinner-border-sm me-2"></div>{{ translations.loading ?? 'Chargement…' }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
(function () {
    const ROOT = '{{ ROOT }}';
    const STATUS_LABELS = {{ statuses|json_encode|raw }};
    const modalEl = document.getElementById('helpdeskDetailsModal');
    const modalBody = document.getElementById('helpdeskDetailsContent');
    const modal = new bootstrap.Modal(modalEl);
    let currentCaseId = null;

    function escHtml(str) {
        return String(str == null ? '' : str)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
    }

    function statusClass(status) {
        return {
            NEW: 'status-new',
            IN_PROGRESS: 'status-progress',
            RESOLVED: 'status-resolved',
            CLOSED: 'status-closed',
            CANCELLED: 'status-cancelled'
        }[status] || 'status-closed';
    }

    function maybe(v) {
        return v ? escHtml(v) : '<span class="text-muted">—</span>';
    }

    async function fetchJson(url, options = {}) {
        const res = await fetch(url, Object.assign({
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' }
        }, options));
        const data = await res.json();
        if (!res.ok || data.ok === false) {
            throw new Error(data.message || 'Operacja nie powiodła się.');
        }
        return data;
    }

    async function openCase(id) {
        currentCaseId = id;
        modalBody.innerHTML = '<div class="modal-loader"><div class="spinner-border spinner-border-sm me-2"></div>{{ translations.loading ?? 'Chargement…' }}</div>';
        modal.show();

        try {
            const [details, meetings] = await Promise.all([
                fetchJson(`${ROOT}/helpdesk/cases/${id}`),
                fetchJson(`${ROOT}/helpdesk/cases/${id}/meetings`)
            ]);
            renderCase(details.data, meetings.data || []);
            bindActions();
        } catch (err) {
            modalBody.innerHTML = `<div class="p-4 text-danger">${escHtml(err.message)}</div>`;
        }
    }

    function renderCase(data, meetings) {
        const meetingOptions = ['<option value="">{{ translations.unpin_meeting ?? '— retirer le rendez-vous —' }}</option>']
            .concat(meetings.map(item => {
                const title = `${item.title || '{{ translations.meeting_fallback ?? 'Rendez-vous' }}'} · ${item.meeting_date || ''} ${item.meeting_time || ''}`.trim();
                const selected = String(item.id) === String(data.id_meeting || '') ? 'selected' : '';
                return `<option value="${item.id}" ${selected}>${escHtml(title)}</option>`;
            }))
            .join('');

        const statusOptions = Object.entries(STATUS_LABELS).map(([key, label]) => {
            const selected = key === data.status ? 'selected' : '';
            return `<option value="${key}" ${selected}>${escHtml(label)}</option>`;
        }).join('');

        const attachments = (data.attachments || []).map(att => `
            <div class="attachment-card">
                <button type="button" class="open-attachment" data-attachment-id="${att.id}">
                    <i class="bi bi-paperclip me-1"></i>${escHtml(att.original_name || 'Załącznik')}
                </button>
            </div>
        `).join('');

        modalBody.innerHTML = `
            <div class="case-section">
                <div class="d-flex align-items-start justify-content-between gap-2">
                    <div>
                        <div class="fw-bold" style="font-size:.9rem;">${escHtml(data.title || '')}</div>
                        <div class="text-muted" style="font-size:.75rem;">${escHtml(data.ref || '')}</div>
                    </div>
                    <span class="task-status ${statusClass(data.status)}">${escHtml(STATUS_LABELS[data.status] || data.status || '')}</span>
                </div>
                <div class="task-case-meta mt-2">
                    <span class="task-chip"><i class="bi bi-diagram-3"></i>${escHtml(data.area_key || '')}</span>
                    ${data.shop_name ? `<span class="task-chip"><i class="bi bi-shop"></i>${escHtml(data.shop_name)}</span>` : ''}
                    ${data.requester_name ? `<span class="task-chip"><i class="bi bi-person"></i>${escHtml(data.requester_name)}</span>` : ''}
                </div>
            </div>

            <div class="case-section">
                <div class="case-section-title">{{ translations.description ?? 'Description du ticket' }}</div>
                <div class="case-description-full">${escHtml(data.description || '')}</div>
                ${data.context ? `<div class="case-section-title mt-3">{{ translations.context ?? 'Contexte' }}</div><div class="case-description-full">${escHtml(data.context)}</div>` : ''}
            </div>

            <div class="case-section">
                <div class="case-section-title">{{ translations.info ?? 'Informations' }}</div>
                <div class="case-info-row"><div class="case-info-label">{{ translations.reporter ?? 'Demandeur' }}</div><div class="case-info-value">${maybe(data.requester_name)}</div></div>
                <div class="case-info-row"><div class="case-info-label">{{ translations.email ?? 'Email' }}</div><div class="case-info-value">${maybe(data.requester_email)}</div></div>
                <div class="case-info-row"><div class="case-info-label">{{ translations.shop ?? 'Boutique' }}</div><div class="case-info-value">${maybe(data.shop_name)}</div></div>
                <div class="case-info-row"><div class="case-info-label">{{ translations.consultant ?? 'Consultant' }}</div><div class="case-info-value">${maybe(data.consultant_name)}</div></div>
                <div class="case-info-row"><div class="case-info-label">{{ translations.meeting ?? 'Rendez-vous' }}</div><div class="case-info-value">${maybe(data.meeting_title)}</div></div>
                <div class="case-info-row"><div class="case-info-label">{{ translations.created ?? 'Créé le' }}</div><div class="case-info-value">${maybe(data.created_at)}</div></div>
                <div class="case-info-row"><div class="case-info-label">{{ translations.updated ?? 'Mise à jour' }}</div><div class="case-info-value">${maybe(data.updated_at)}</div></div>
            </div>

            <div class="case-section">
                <div class="case-section-title">{{ translations.response ?? 'Réponse' }}</div>
                <div class="case-reply-view">${data.admin_reply ? escHtml(data.admin_reply) : '{{ translations.no_reply ?? 'Pas encore de réponse.' }}'}</div>
            </div>

            ${(data.attachments || []).length ? `
            <div class="case-section">
                <div class="case-section-title">{{ translations.attachments ?? 'Pièces jointes' }}</div>
                <div class="attachments-grid">${attachments}</div>
            </div>` : ''}

            <div class="case-section">
                <div class="case-section-title">{{ translations.actions ?? 'Actions' }}</div>
                <div class="case-actions">
                    <div class="case-action-row">
                        <div class="case-action-label">{{ translations.status ?? 'Statut' }}</div>
                        <select class="case-action-select" id="case-status-select">${statusOptions}</select>
                        <button class="case-action-button" data-action="status">{{ translations.save_status ?? 'Enregistrer le statut' }}</button>
                        <div class="case-feedback" id="feedback-status"></div>
                    </div>

                    <div class="case-action-row">
                        <div class="case-action-label">{{ translations.meeting ?? 'Rendez-vous' }}</div>
                        <select class="case-action-select" id="case-meeting-select">${meetingOptions}</select>
                        <button class="case-action-button" data-action="meeting">{{ translations.save_meeting ?? 'Enregistrer le rendez-vous' }}</button>
                        <div class="case-feedback" id="feedback-meeting"></div>
                    </div>

                    <div class="case-action-row">
                        <div class="case-action-label">{{ translations.response ?? 'Réponse' }}</div>
                        <textarea class="case-action-textarea" id="case-reply-input" placeholder="{{ translations.response_ph ?? 'Écrire une réponse…' }}">${escHtml(data.admin_reply || '')}</textarea>
                        <button class="case-action-button" data-action="reply">{{ translations.save_response ?? 'Enregistrer la réponse' }}</button>
                        <div class="case-feedback" id="feedback-reply"></div>
                    </div>
                </div>
            </div>
        `;
    }

    function setFeedback(key, message, ok) {
        const el = document.getElementById(`feedback-${key}`);
        if (!el) return;
        el.className = `case-feedback ${ok ? 'ok' : 'err'}`;
        el.textContent = message;
    }

    async function submitAction(action) {
        if (!currentCaseId) return;
        try {
            if (action === 'status') {
                const status = document.getElementById('case-status-select').value;
                const json = await fetchJson(`${ROOT}/helpdesk/cases/${currentCaseId}/status`, {
                    method: 'POST',
                    body: JSON.stringify({ status })
                });
                setFeedback('status', json.message || '{{ translations.status_saved ?? 'Statut enregistré.' }}', true);
            }
            if (action === 'meeting') {
                const id_meeting = document.getElementById('case-meeting-select').value || null;
                const json = await fetchJson(`${ROOT}/helpdesk/cases/${currentCaseId}/meeting`, {
                    method: 'POST',
                    body: JSON.stringify({ id_meeting })
                });
                setFeedback('meeting', json.message || '{{ translations.meeting_saved ?? 'Rendez-vous enregistré.' }}', true);
            }
            if (action === 'reply') {
                const admin_reply = document.getElementById('case-reply-input').value;
                const json = await fetchJson(`${ROOT}/helpdesk/cases/${currentCaseId}/reply`, {
                    method: 'POST',
                    body: JSON.stringify({ admin_reply })
                });
                setFeedback('reply', json.message || '{{ translations.reply_saved ?? 'Réponse enregistrée.' }}', true);
            }
            setTimeout(() => window.location.reload(), 700);
        } catch (err) {
            setFeedback(action, err.message, false);
        }
    }

    function bindActions() {
        modalBody.querySelectorAll('[data-action]').forEach(btn => {
            btn.addEventListener('click', () => submitAction(btn.dataset.action));
        });
        modalBody.querySelectorAll('.open-attachment').forEach(btn => {
            btn.addEventListener('click', async () => {
                try {
                    const json = await fetchJson(`${ROOT}/helpdesk/attachments/${btn.dataset.attachmentId}/url`);
                    if (json.data && json.data.url) {
                        window.open(json.data.url, '_blank', 'noopener');
                    }
                } catch (err) {
                    alert(err.message);
                }
            });
        });
    }

    document.querySelectorAll('[data-case-id]').forEach(card => {
        card.addEventListener('click', () => openCase(card.dataset.caseId));
    });
})();
</script>
{% endblock %}
