RewriteEngine On
RewriteBase /pwa_consultant/

# TEST MODE (DEV_NO_AUTH) disabled — real authentication is now required.
# To temporarily re-enable the no-auth bypass, uncomment the line below and
# redeploy (requires Apache "AllowOverride" to permit SetEnv / mod_env).
# See config/app.php > DEV_NO_AUTH.
# SetEnv DEV_NO_AUTH 1

# Consultant backend API base (hosted on a separate host).
SetEnv CONSULTANT_API_BASE https://atelierby.tfbuddy.com/api/v1

# TEMPORARY login diagnostic — enables /auth?diag=1 (see AuthController).
# Remove this line once login is verified.
SetEnv AUTH_DIAG 1

# Nie przepisywuj istniejących plików i katalogów
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Nie przepisywuj, jeśli już trafiono do index.php
RewriteCond %{REQUEST_URI} !^/index\.php$

# Przepisuj wszystko inne na index.php
RewriteRule ^(.*)$ index.php?url=$1 [L,QSA]

